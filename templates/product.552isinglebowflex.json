ky":true,"display_complementary":true,"complementary_heading":"Perfect Match","complementary_layout":"slider","products_limit":3,"complementary_show_vendor":true,"display_mini_card":true,"mini_card_show_vendor":true,"padding_bottom":"no-indent"}},"product-recommendations":{"type":"product-recommendations","disabled":true,"settings":{"color_scheme":"","heading":"You May Also Like","heading_size":"h3","description":"","products_limit":6,"show_vendor":false,"show_desc":false,"show_iventory":true,"columns_mobile":"2","show_button":false,"button_label":"Shop All","button_link":"","padding_top":"no-indent","padding_bottom":"xl"}},"banner_slider_JKyQy7":{"type":"banner-slider","blocks":{"banner_A3EFYc":{"type":"banner","settings":{"color_scheme":"","show_video":true,"video":"shopify:\/\/files\/videos\/2025_10_21_bowflex_552i_6-_V02_16x9_ENG.mp4","overlay_opacity":0,"overlay_opacity_mobile":0,"subheading":"","heading":"","heading_font":"accent","heading_size":"custom","heading_size_custom":56,"description":"","text_align":"center","link":""}}},"block_order":["banner_A3EFYc"],"name":"t:sections.banner-slider.name","settings":{"heading":"","heading_size":"h2","heading_level":"h2","description":"","image_ratio_desktop":"21\/9","image_ratio_mobile":"4\/5","enable_animation":false,"enable_autoplay":false,"slide_duration":5,"enable_pagination":true,"enable_navigation":true,"enable_loop":true,"margin_top":"no-indent","margin_bottom":"no-indent"}},"rich_text_VDxtFU":{"type":"rich-text","blocks":{"heading_E7Etei":{"type":"heading","settings":{"heading":"Replaces 15 Dumbbells – Full Strength Rack in One Compact System","heading_size":"h2","heading_level":"h1","alignment":"center"}},"text_DAgE8R":{"type":"text","settings":{"text":"<p>The BowFlex 552i gives you the full range of dumbbell weights without needing a home gym rack. Each dumbbell adjusts from <strong>2 kg to 24 kg<\/strong>, replacing <strong>15 individual pairs<\/strong>, making it one of the most space-efficient solutions for UK homes. Ideal for Google searchers looking for <strong>space-saving adjustable dumbbells<\/strong> or <strong>dumbbell sets for home gym UK<\/strong>.<\/p>","alignment":"center"}}},"block_order":["heading_E7Etei","text_DAgE8R"],"name":"t:sections.rich-text.presets.name","settings":{"color_scheme":"","full_width":true,"position":"center","padding_top":"l","padding_bottom":"no-indent","margin_top":"no-indent","margin_bottom":"no-indent"}},"rich_text_Lek6n9":{"type":"rich-text","blocks":{"heading_HxhKLD":{"type":"heading","settings":{"heading":"Smooth SelectTech Dial System for Fast, Fluid Workouts","heading_size":"h2","heading_level":"h2","alignment":"center"}},"text_6gxxHy":{"type":"text","settings":{"text":"<p>The signature BowFlex SelectTech dial allows rapid weight adjustments so you can switch exercises without losing intensity. Perfect for <strong>HIIT strength<\/strong>, <strong>supersets<\/strong>, <strong>circuit training<\/strong>, and <strong>progressive overload<\/strong>—one of the main reasons the 552i ranks among the most searched <strong>adjustable dumbbells in the UK<\/strong>.<\/p>","alignment":"center"}}},"block_order":["heading_HxhKLD","text_6gxxHy"],"name":"t:sections.rich-text.presets.name","settings":{"color_scheme":"","full_width":true,"position":"center","padding_top":"l","padding_bottom":"xs","margin_top":"no-indent","margin_bottom":"no-indent"}},"rich_text_iq8QMz":{"type":"rich-text","blocks":{"heading_CkAKtN":{"type":"heading","settings":{"heading":"Premium Build Quality with JRNY® Adaptive Coaching","heading_size":"h2","heading_level":"h2","alignment":"center"}},"text_VyDzRQ":{"type":"text","settings":{"text":"<p><br\/>Built with high-grade steel plates, reinforced alignment tracks and ergonomic contoured grips, the BowFlex 552i provides stability and reliability under heavy training. Connect to the <strong>JRNY® app<\/strong> to receive tailored weight recommendations, track performance, and follow trainer-led strength sessions—ideal for users searching for <strong>smart dumbbells<\/strong>, <strong>connected fitness<\/strong>, and <strong>strength training coaching<\/strong>.<br\/><br\/><\/p>","alignment":"center"}}},"block_order":["heading_CkAKtN","text_VyDzRQ"],"name":"t:sections.rich-text.presets.name","settings":{"color_scheme":"","full_width":true,"position":"center","padding_top":"l","padding_bottom":"xs","margin_top":"no-indent","margin_bottom":"no-indent"}},"image_with_text_bDEmY6":{"type":"image-with-text","name":"t:sections.image-with-text.name","settings":{"color_scheme":"","heading":"","heading_size":"h1","heading_level":"h1","description":"<p>Built for lifters who want maximum versatility without the clutter, the BowFlex 552i SelectTech Adjustable Dumbbells deliver a truly seamless strength experience at home. Instead of switching between multiple free weights, you can rotate the dial and move straight into your next lift, keeping your heart rate high and your training flow uninterrupted. This makes the 552i ideal for anyone following structured programmes, quick morning sessions, or intense evening workouts. With a solid, dependable feel and precision-engineered weight plates, these dumbbells bring the reliability of a commercial gym directly into your living room — helping you stay consistent, challenge your limits and build real, measurable strength.<\/p>","text_align":"center","vertical_content_alignment":"center","image":"shopify:\/\/shop_images\/BFX_ATF_SelectTech_552_Single_Feature_02_NoGraphic.jpg","img_position":"left","aspect_ratio":"1\/1","full_width":false,"show_button":false,"button_label":"Shop Now","button_link":"","button_style":"primary","show_button_2":false,"button_label_2":"See Details","button_link_2":"","button_style_2":"tertiary","padding_top":"xs","padding_bottom":"xs","margin_top":"no-indent","margin_bottom":"no-indent"}},"featured_product_CgnWmr":{"type":"featured-product","blocks":{"text_dTe94w":{"type":"text","settings":{"text":"{{ section.settings.pr