{"sections":{"main":{"type":"main-page","settings":{"padding_top":"no-indent","padding_bottom":"m"}},"custom_liquid_LTkRXw":{"type":"custom-liquid","name":"t:sections.custom-liquid.presets.name","settings":{"custom_liquid":"<!-- Ask Johnson AI Chatbot (Chat Box Section Version) -->\n<div id=\"ask-johnson-chat\" style=\"width: 100%; max-width: 600px; margin: 30px auto; background: #fff; border-radius: 10px; box-shadow: 0 0 15px rgba(0,0,0,0.1); overflow: hidden; font-family: sans-serif;\">\n  <div style=\"background: purple; color: white; padding: 15px; font-weight: bold; font-size: 18px;\">Ask Johnson<\/div>\n  <div id=\"chat-history\" style=\"padding: 20px; height: 400px; overflow-y: auto; font-size: 14px; border-bottom: 1px solid #eee;\"><\/div>\n  <div style=\"display: flex; padding: 15px;\">\n    <input id=\"user-message\" type=\"text\" placeholder=\"Ask me anything...\" style=\"flex: 1; padding: 10px; border: 1px solid #ccc; border-radius: 5px; font-size: 14px;\">\n    <button onclick=\"sendMessage()\" style=\"margin-left: 10px; padding: 10px 15px; background: purple; color: white; border: none; border-radius: 5px; cursor: pointer;\">Send<\/button>\n  <\/div>\n<\/div>\n\n<script>\n  const productDatabase = [\n    { name: 'Horizon 5.0AT Treadmill', type: 'treadmill', price: 819.99, features: ['folding', 'bluetooth'], goal: 'cardio', url: '\/products\/horizon-5-0at' },\n    { name: 'Horizon 7.0AT Treadmill', type: 'treadmill', price: 1499.99, features: ['incline', 'folding', 'bluetooth'], goal: 'running', url: '\/products\/horizon-7-0at' },\n    { name: 'BowFlex 552i Dumbbells', type: 'strength', price: 399.99, features: ['adjustable'], goal: 'strength', url: '\/products\/bowflex-552i' },\n    { name: 'Horizon 3.0SC Indoor Cycle', type: 'bike', price: 569.99, features: ['compact'], goal: 'cardio', url: '\/products\/horizon-3-0sc' },\n    { name: 'Synca CirC 3 Massage Chair', type: 'wellness', price: 899.99, features: ['compact', 'heat'], goal: 'relaxation', url: '\/products\/synca-circ-3' },\n    { name: 'Horizon Oxford 6 Rower', type: 'rower', price: 599.99, features: ['folding', 'smooth'], goal: 'cardio', url: '\/products\/horizon-oxford-6' },\n    { name: 'Horizon EX-59 Elliptical Trainer', type: 'elliptical', price: 999.99, features: ['compact', 'heart rate'], goal: 'cardio', url: '\/products\/horizon-ex-59' },\n    { name: 'BowFlex BFX56 Folding Treadmill', type: 'treadmill', price: 3399.99, features: ['folding', 'touchscreen', 'incline'], goal: 'performance', url: '\/products\/bowflex-bfx56' }\n  ];\n\n  function sendMessage() {\n    const input = document.getElementById('user-message');\n    const message = input.value.trim();\n    if (!message) return;\n\n    appendMessage('You', message);\n    const reply = getJohnsonReply(message);\n    appendMessage('Johnson', reply);\n\n    input.value = '';\n  }\n\n  function appendMessage(sender, message) {\n    const history = document.getElementById('chat-history');\n    const entry = document.createElement('div');\n    entry.innerHTML = `<strong>${sender}:<\/strong> ${message}`;\n    history.appendChild(entry);\n    history.scrollTop = history.scrollHeight;\n  }\n\n  function getJohnsonReply(query) {\n    query = query.toLowerCase();\n    const budgetMatch = query.match(\/under \\£?(\\d+)\/);\n    const budget = budgetMatch ? parseFloat(budgetMatch[1]) : Infinity;\n\n    const matched = productDatabase.filter(p => {\n      return (\n        (query.includes(p.type) || p.features.some(f => query.includes(f)) || query.includes(p.goal)) &&\n        p.price <= budget\n      );\n    });\n\n    if (matched.length === 0) return \"Sorry, I couldn't find a perfect match. Try mentioning product type, features, or price.\";\n\n    let response = 'Here are your best matches:<br><ul>';\n    matched.slice(0, 3).forEach(p => {\n      response += `<li><a href=\"${p.url}\" target=\"_blank\">${p.name}<\/a> – £${p.price.toFixed(2)}<\/li>`;\n    });\n    response += '<\/ul>';\n    return response;\n  }\n<\/script>"}}},"order":["main","custom_liquid_LTkRXw"]}