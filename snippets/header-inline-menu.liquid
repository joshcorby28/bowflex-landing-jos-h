<nav class="header-inline-menu{% if class != blank %} {{ class }}{% endif %}">
  {%- if section.settings.menu != blank -%}
    <ul class="list-menu list-menu--inline list-unstyled" role="list">
      {%- for link in section.settings.menu.links -%}
        {% liquid
          assign mega_menu = false
          assign mega_menu_cards = false
          assign mega_menu_tabs = false

          for block in section.blocks
            assign mega_menu_cards_trigger = block.settings.mega_menu_cards_trigger | handle | strip
            assign mega_menu_tabs_trigger = block.settings.mega_menu_tabs_trigger | handle | strip

            if link.handle == mega_menu_cards_trigger
              assign mega_menu = true
              assign mega_menu_cards = true
              assign mega_menu_tabs = false
              assign shopify_attributes = block.shopify_attributes
            elsif link.handle == mega_menu_tabs_trigger
              assign mega_menu = true
              assign mega_menu_cards = false
              assign mega_menu_tabs = true
              assign shopify_attributes = block.shopify_attributes
            endif
          endfor
        %}

        <li
          class="header-inline-menu__item list-menu-item{% if mega_menu %}{% if mega_menu_cards %} list-menu--megamenu-cards{% elsif mega_menu_tabs %} list-menu--megamenu-tabs{% endif %}{% elsif link.links != blank %} list-menu--submenu{% endif %}"
          {% if mega_menu %}
            {{ shopify_attributes }}
          {% endif %}
        >
          <a
            href="{{ link.url }}"
            {% if settings.links_blank and link.type == 'http_link' %}
              target="_blank"
            {% endif %}
            class="header-inline-menu__item-link header-link-style list-menu__item focus-inset{% if link.current and link.url != '/' %} header-inline-menu__item-link--current{% endif %}{% if link.title == section.settings.main_menu_sale_trigger %} header-inline-menu__item-link--sale{% endif %}"
            {% if link.current and link.url != '/' %}
              aria-current="page"
            {% endif %}
            aria-label="{{ link.title | escape }}"
          >
            {%- if link.title == section.settings.main_menu_sale_trigger and section.settings.main_menu_sale_icon -%}
              {% render 'icon-menu-sale' %}
            {%- endif -%}
            <span
              class="header-inline-menu__item-label{% if link.title == section.settings.main_menu_sale_trigger and section.settings.main_menu_sale_color %} header-inline-menu__item-label--sale-color{% endif %}"
              title="{{ link.title | escape }}"
            >
              {{ link.title | escape }}
            </span>
          </a>

          {%- if mega_menu -%}
            {%- if mega_menu_cards -%}
              {%- render 'header-mega-menu-cards-desktop', link: link, blocks: section.blocks -%}
            {%- endif -%}
            {%- if mega_menu_tabs -%}
              {%- render 'header-mega-menu-tabs-desktop', link: link, blocks: section.blocks -%}
            {%- endif -%}

          {%- elsif link.links != blank -%}
            {%- render 'header-submenu', link: link -%}
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</nav>
