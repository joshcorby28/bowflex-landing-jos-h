  {{ scheme_classes | prepend: 'body' }} {
    color: rgba(var(--color-foreground));
    background: rgb(var(--color-background));
    background-attachment: fixed;
  }

  :root {
    --color-shadow: var(--color-foreground);
    --payment-terms-background-color: {{ settings.colors_background_1 }};
    --color-modal-overlay: {{ settings.color_modal_overlay.red }},{{ settings.color_modal_overlay.green }},{{ settings.color_modal_overlay.blue }};;
  }

  {% for scheme in settings.color_schemes -%}
    {% assign scheme_classes = scheme_classes | append: ', .color-' | append: scheme.id %}
    [data-scheme=dark] .color-{{ scheme.id }} {
      --color-background: 31, 31, 31;
      --color-background-secondary: 41, 41, 41;
      --color-foreground: 255, 255, 255;
      --color-foreground-secondary: 220, 220, 220;
      --color-background-input: 52, 52, 53;
      --color-foreground-input: 255, 255, 255;
      --color-border: 67, 67, 67;
      --color-button: 10, 10, 10;
      --color-button-hover: 45, 45, 45;
      --color-button-text: 255, 255, 255;
      --color-button-text-hover: 255, 255, 255;
      --color-button-secondary: 58, 58, 58;
      --color-button-secondary-hover: 68, 68, 68;
      --color-button-secondary-text: 255, 255, 255;
      --color-button-secondary-text-hover: 255, 255, 255;
      --color-button-tertiary: 90, 90, 90;
      --color-button-tertiary-hover: 100, 100, 100;
      --color-button-tertiary-text: 255, 255, 255;
      --color-button-tertiary-text-hover: 255, 255, 255;
      --color-button-transparent: 255, 255, 255;
      --color-button-transparent-hover: 255, 255, 255;
      --color-card-price-regular: 229, 229, 229;
      --color-card-price-sale: 169, 169, 169;
      --color-error-background: 0, 0, 0;
      --color-shadow: 1, 22, 36;
      --sold-out-badge-bg: 142, 142, 143;
      --sold-out-badge-color: 255, 255, 255;
      --sale-badge-bg: 142, 142, 143;
      --sale-badge-color: 255, 255, 255;
      --custom-badge-bg: 142, 142, 143;
      --custom-badge-color: 255, 255, 255;
      --color-overlay: 0, 0, 0;
      --color-accent: 255, 255, 255;
      --color-accent-secondary: 31, 31, 31;
      --color-alert: 255, 70, 70;
      --color-countdown-date-bg: 41, 41, 41;

      .cards-grid-item__heading,
      .cards-grid-item__promo-text,
      .cards-grid-item__text,
      .article-card-overlay-title,
      .article-card-overlay-excerpt,
      .article-card-overlay-date:not(:first-of-type):before {
        --color-foreground: {{ scheme.settings.colors_text.red }}, {{ scheme.settings.colors_text.green }}, {{ scheme.settings.colors_text.blue }};
      }

      .cards-grid-item__promo-input,
      .slideshow__promo-input {
        --color-background-input: {{ scheme.settings.colors_input_background.red }}, {{ scheme.settings.colors_input_background.green }}, {{ scheme.settings.colors_input_background.blue }};
        --color-placeholder-input: {{ scheme.settings.colors_input_placeholder.red }}, {{ scheme.settings.colors_input_placeholder.green }}, {{ scheme.settings.colors_input_placeholder.blue }};
        --color-foreground-input: {{ scheme.settings.colors_input_foreground.red }}, {{ scheme.settings.colors_input_foreground.green }}, {{ scheme.settings.colors_input_foreground.blue }};
      }

      .cards-grid-item__text,
      .article-card-overlay-author,
      .article-card-overlay-date,
      .article-card-overlay-comments {
        --color-foreground-secondary: {{ scheme.settings.colors_secondary_text.red }}, {{ scheme.settings.colors_secondary_text.green }}, {{ scheme.settings.colors_secondary_text.blue }};
      }

      .article-card-overlay-tag {
        --color-button-tertiary-text: {{ scheme.settings.colors_tertiary_button_labels.red }}, {{ scheme.settings.colors_tertiary_button_labels.green }}, {{ scheme.settings.colors_tertiary_button_labels.blue }};
        --color-button-tertiary-text-hover: {{ scheme.settings.colors_tertiary_button_labels_hover.red }}, {{ scheme.settings.colors_tertiary_button_labels_hover.green }}, {{ scheme.settings.colors_tertiary_button_labels_hover.blue }};
        --color-button-tertiary: {{ scheme.settings.colors_tertiary_button_background.red }}, {{ scheme.settings.colors_tertiary_button_background.green }}, {{ scheme.settings.colors_tertiary_button_background.blue }};
        --color-button-tertiary-hover: {{ scheme.settings.colors_tertiary_button_background_hover.red }}, {{ scheme.settings.colors_tertiary_button_background_hover.green }}, {{ scheme.settings.colors_tertiary_button_background_hover.blue }};
      }

      .cards-grid-item__subheading {
        --color-background: {{ scheme.settings.colors_background_1.red }},{{ scheme.settings.colors_background_1.green }},{{ scheme.settings.colors_background_1.blue }};
        --color-accent: {{ scheme.settings.color_accent.red }}, {{ scheme.settings.color_accent.green }}, {{ scheme.settings.color_accent.blue }};
        --color-foreground: {{ scheme.settings.colors_text.red }}, {{ scheme.settings.colors_text.green }}, {{ scheme.settings.colors_text.blue }};
      }

      >.collection-card__information .collection-card__title,
      >.collection-card__information .collection-card__desc {
        --color-foreground: {{ scheme.settings.colors_text.red }}, {{ scheme.settings.colors_text.green }}, {{ scheme.settings.colors_text.blue }};
      }

      .countdown__promo-banner-text-container {
        --color-foreground: {{ scheme.settings.colors_text.red }}, {{ scheme.settings.colors_text.green }}, {{ scheme.settings.colors_text.blue }};
        --color-foreground-secondary: {{ scheme.settings.colors_secondary_text.red }}, {{ scheme.settings.colors_secondary_text.green }}, {{ scheme.settings.colors_secondary_text.blue }};
        --color-background: {{ scheme.settings.colors_background_1.red }},{{ scheme.settings.colors_background_1.green }},{{ scheme.settings.colors_background_1.blue }};
        --color-accent: {{ scheme.settings.color_accent.red }}, {{ scheme.settings.color_accent.green }}, {{ scheme.settings.color_accent.blue }};
      }

      .featured-collection__promo-text,
      .featured-collection__card-text {
        --color-foreground: {{ scheme.settings.colors_text.red }}, {{ scheme.settings.colors_text.green }}, {{ scheme.settings.colors_text.blue }};
        --color-foreground-secondary: {{ scheme.settings.colors_secondary_text.red }}, {{ scheme.settings.colors_secondary_text.green }}, {{ scheme.settings.colors_secondary_text.blue }};
        --color-background: {{ scheme.settings.colors_background_1.red }},{{ scheme.settings.colors_background_1.green }},{{ scheme.settings.colors_background_1.blue }};
        --color-accent: {{ scheme.settings.color_accent.red }}, {{ scheme.settings.color_accent.green }}, {{ scheme.settings.color_accent.blue }};
