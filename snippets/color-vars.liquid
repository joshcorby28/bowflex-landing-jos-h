        --color-placeholder-input: {{ scheme.settings.colors_input_placeholder.red }}, {{ scheme.settings.colors_input_placeholder.green }}, {{ scheme.settings.colors_input_placeholder.blue }};
        --color-foreground-input: {{ scheme.settings.colors_input_foreground.red }}, {{ scheme.settings.colors_input_foreground.green }}, {{ scheme.settings.colors_input_foreground.blue }};
