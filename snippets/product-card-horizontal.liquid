{% comment %}
  	Renders a horizontal product card
  	Accepts:
  	- product_card_product: {Object} Product Liquid object (optional)
  	- media_ratio: {String} Size of the product image card. Values are "square", "portrait", "landscape" (optional)
  	- show_vendor: {Boolean} Show the product vendor. Default: true
    - additional_class: {String} Additional classes to add to the card.
  	Usage:
  {% render 'product-card-horizontal',
  	product_card_product: product,
  	show_vendor: true
  %}
{% endcomment %}

{% liquid
  if media_ratio == blank
    assign media_ratio = settings.card_image_ratio
  endif

  case media_ratio
    when 'landscape'
      assign padding_bottom = '66%'
    when 'portrait'
      assign padding_bottom = '133.3%'
    when 'square'
      assign padding_bottom = '100%'
    else
      assign padding_bottom = '100%'
  endcase
%}

<div
  class="card-horizontal-wrapper{% if show_image != true %} card-horizontal-wrapper_no-image{% endif %}{% if color_scheme %} color-{{ color_scheme }}{% else %} color-{{ settings.card_color_scheme }}{% endif %}{% if additional_class != blank %} {{ additional_class }}{% endif %} js-color-swatches-wrapper"
  data-product="{{ product_card_product.handle }}"
>
  <span class="visually-hidden">{{ product_card_product.title | escape }}</span>
  {%- if product_card_product.url -%}
    <a
      href="{{ product_card_product.url | default: '#' }}"
      class="link link--overlay card-wrapper__link--overlay js-color-swatches-link focus-inset"
      aria-label="{{ product_card_product.title }}"
      title="{{ product_card_product.title }}"
    ></a>
  {%- endif -%}

  <div class="card-horizontal-wrapper__inner">
    {% if show_image == true %}
      <div class="card-horizontal__image" tabindex="-1">
        <div
          class="media"
          style="padding-bottom: {{ padding_bottom }}; --object-fit: {{ settings.card_image_fit }};"
        >
          {%- if product_card_product.featured_media -%}
            {% liquid
              if media_ratio == 'landscape'
                assign settings_aspect_ratio = 1.33
              elsif media_ratio == 'portrait'
                assign settings_aspect_ratio = 0.75
              else
                assign settings_aspect_ratio = 1
              endif

              assign calc_ratio = 1
              if product_card_product.featured_media.aspect_ratio > settings_aspect_ratio
                assign calc_ratio = product_card_product.featured_media.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
              endif
            %}
            {%- capture sizes -%}
            calc(200px * {{ calc_ratio }})
          {%- endcapture -%}
            {{
              product_card_product.featured_media
              | image_url: width: 200
              | image_tag: loading: 'lazy', sizes: sizes, widths: '200, 400', class: 'motion-reduce media--first'
            }}
          {%- else -%}
            {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>
    {% endif %}

    <div class="card-horizontal__information">
      <div class="card-horizontal__text">
        {%- if show_vendor -%}
          <span class="visually-hidden">{{- 'accessibility.vendor' | t -}}</span>
          <div class="card-horizontal__vendor body-xs {% if settings.enable_vendor_link %} card-horizontal__vendor_link {% endif %}">
            {% if settings.enable_vendor_link %}
              {{ product_card_product.vendor | link_to_vendor: class: 'focus-inset' }}
            {% else %}
              {{ product_card_product.vendor }}
            {% endif %}
          </div>
        {%- endif -%}

        <h3 class="card-horizontal__title">
          {%- if product_card_product.title -%}
            <span class="link--hover-underline">
              {{- product_card_product.title | escape -}}
            </span>
          {%- else -%}
            <span>{{- 'products.product.product_heading' | t -}}</span>
          {%- endif -%}
        </h3>

        {% render 'price', product: product_card_product, price_class: '' %}

        {% if hide_swatches != true %}
          <div class="product-parameters">
            {%- unless product_card_product.has_only_default_variant -%}
              {%- for option in product_card_product.options_with_values -%}
                {%- liquid
                  assign is_color_option = false
                  assign color_trigger = settings.trigger_swatch | strip | newline_to_br | split: '<br />'
                  assign name_option = option.name | handle | strip
                  for item in color_trigger
                    assign item_temp = item | handle | strip
                    if settings.enable_color_swatch and name_option == item_temp and settings.card_swatch_type != 'none'
                      assign is_color_option = true
                    endif
                  endfor
                -%}
                {%- if is_color_option and option.values.size > 1 -%}
                  <div class="product-form__controls js-color-swatches" data-index="{{ forloop.index }}">
                    <div class="product-form__controls-group product-form__controls-group--{{ settings.color_swatch_type }}">
                      {% render 'product-variant-options',
                        product: product_card_product,
                        option: option,
                        is_product_card: true,
                        is_product_card_small: true,
                        has_color_swatch: true,
                        is_dropdown: false,
                        swatch_type: settings.card_swatch_type
                      %}
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}

              <script type="application/json">
                {{ product_card_product.variants | json }}
              </script>
            {%- endunless -%}
          </div>
        {% endif %}
      </div>
      {% if show_arrow == true %}
        <span class="card-horizontal__arrow">
          {% render 'icon-btn-arrow' %}
        </span>
      {% endif %}
    </div>
  </div>
</div>
