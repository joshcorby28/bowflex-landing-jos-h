{% comment %}
  Renders cart drawer

  Usage:
  {% render 'cart-drawer' %}
{% endcomment %}

<cart-drawer class="cart-drawer{% if cart == empty %} is-empty{% endif %}">
  <style>
    .cart-drawer {
      visibility: hidden;
    }
  </style>
  <div id="CartDrawer" class="cart-drawer__wrapper">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="cart-drawer__inner color-{{ settings.drawer_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'general.cart.cart' | t }}"
      tabindex="-1"
    >
      {% comment %} CART DRAWER HEADER {% endcomment %}
      <div class="cart-drawer__header">
        <div class="cart-drawer__header-wrapper">
          <div class="cart-drawer__header-title">
            <span class="h3">{{- 'general.cart.cart' | t -}}</span>
            {%- if cart.empty? == false -%}
              <span class="cart-drawer__header-count">
                {%- if cart.item_count < 100 -%}
                  {{- cart.item_count -}}
                {%- else -%}
                  99+
                {%- endif -%}
              </span>
            {%- endif -%}
          </div>
          <button
            type="button"
            class="cart-drawer__header-close focus-inset modal-close-button focus-inset"
            onclick="this.closest('cart-drawer').close()"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            {% render 'icon-close' %}
          </button>
        </div>

        {% comment %} CART DRAWER FREE SHIPPING {% endcomment %}
        <div class="cart-drawer__header-apps">
          {% render 'cart-shipping-slider', cart: cart %}
        </div>
      </div>

      {% comment %} CART DRAWER EMPTY BLOCK {% endcomment %}
      {%- if cart == empty -%}
        <div class="cart-drawer__empty">
          <div class="cart-drawer__empty-wrapper">
            <p class="cart-drawer__empty-title">
              {%- if settings.title_empty_cart_drawer != blank -%}
                {{- settings.title_empty_cart_drawer -}}
              {%- else -%}
                {{- 'general.cart.empty_cart_title' | t -}}
              {%- endif -%}
            </p>
            {%- if settings.text_empty_cart_drawer != blank -%}
              <p class="cart-drawer__empty-desc">
                {{- settings.text_empty_cart_drawer -}}
              </p>
            {%- endif -%}

            {%- if settings.button_label_empty_cart_drawer != blank -%}
              {% liquid
                assign button_link = routes.collections_url | sort_by: 'best-selling'
                if settings.button_link_empty_cart_drawer != blank
                  assign button_link = settings.button_link_empty_cart_drawer
                endif
              %}

              {% render 'button',
                btn_label: settings.button_label_empty_cart_drawer,
                btn_style: 'primary',
                btn_link: button_link,
                btn_arrow: false,
                enable_arrow: false,
                class: 'cart-drawer__empty-button'
              %}
            {%- endif -%}
          </div>

          {%- if settings.show_products_cart_drawer -%}
            {%- if settings.products_cart_drawer_1 != blank or settings.products_cart_drawer_2 != blank -%}
              <div class="cart-drawer__recommended">
                {%- if settings.products_label_cart_drawer != blank -%}
                  <span class="h4">{{- settings.products_label_cart_drawer -}}</span>
                {%- endif -%}

                {%- if settings.products_cart_drawer_1 != blank and settings.products_cart_drawer_2 != blank -%}
                  <div class="cart-drawer__recommended-tabs">
                    {%- if settings.products_cart_drawer_1 != blank -%}
                      <button
                        class="button cart-drawer__recommended-tab focus-inset active"
                        data-index="1"
                      >
                        <span class="button__label">
                          {{- settings.products_tab_cart_drawer_1 | default: ' ' -}}
                        </span>
                      </button>
                    {%- endif -%}
                    {%- if settings.products_cart_drawer_2 != blank -%}
                      <button
                        class="button cart-drawer__recommended-tab focus-inset"
                        data-index="2"
                      >
                        <span class="button__label">
                          {{- settings.products_tab_cart_drawer_2 | default: ' ' -}}
                        </span>
                      </button>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {%- if settings.products_cart_drawer_1 != blank or settings.products_cart_drawer_2 != blank -%}
                  <span class="cart-drawer__recommended-line"></span>
                {%- endif -%}

                {%- if settings.products_cart_drawer_1 != blank -%}
                  <div
                    class="cart-drawer__recommended-list active"
                    data-index="1"
                  >
                    {%- for recom_product in settings.products_cart_drawer_1 -%}
                      {% render 'product-card-horizontal',
                        show_image: true,
                        product_card_product: recom_product,
                        show_vendor: settings.products_vendor_cart_drawer,
                        color_scheme: settings.drawer_color_scheme,
                        hide_swatches: false,
                        show_arrow: false
                      %}

                      <span class="cart-drawer__recommended-line"></span>
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- if settings.products_cart_drawer_2 != blank -%}
                  <div
                    class="cart-drawer__recommended-list{% if settings.products_cart_drawer_1 == blank %} active{% endif %}"
                    data-index="2"
                  >
                    {%- for recom_product in settings.products_cart_drawer_2 -%}
                      {% render 'product-card-horizontal',
                        show_image: true,
                        product_card_product: recom_product,
                        show_vendor: settings.products_vendor_cart_drawer,
                        color_scheme: settings.drawer_color_scheme,
                        hide_swatches: false,
                        show_arrow: false
                      %}

                      <span class="cart-drawer__recommended-line"></span>
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- if settings.show_products_button_cart_drawer
                  and settings.products_button_label_cart_drawer != blank
                -%}
                  {% liquid
                    assign products_button_link = routes.collections_url | sort_by: 'created-descending'
                    if settings.products_button_link_cart_drawer != blank
                      assign products_button_link = settings.products_button_link_cart_drawer
                    endif
                  %}

                  {% render 'button',
                    btn_label: settings.products_button_label_cart_drawer,
                    btn_style: 'tertiary',
                    btn_link: products_button_link,
                    btn_arrow: false,
                    enable_arrow: false,
                    class: 'cart-drawer__recommended-button'
                  %}
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endif -%}

      {% comment %} DRAWER CART ITEMS {% endcomment %}
      <cart-drawer-items class="{% if cart == empty %}is-empty{% endif %}">
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="cart-drawer__contents js-contents">
            {%- if cart != empty -%}
              {%- liquid
                case settings.card_image_ratio
                  when 'landscape'
                    assign image_ratio = '4/3'
                    assign settings_aspect_ratio = 1.33
                  when 'portrait'
                    assign image_ratio = '3/4'
                    assign settings_aspect_ratio = 0.75
                  when 'square'
                    assign image_ratio = '1/1'
                    assign settings_aspect_ratio = 1
                endcase

                assign aspect_ratio = image_ratio | split: '/'
                assign first_symbol_ratio = aspect_ratio[0] | append: '.0'
                assign padding_bottom = aspect_ratio[1] | divided_by: first_symbol_ratio | times: 100 | round: 2
              -%}

              <div class="cart-drawer__cart-items">
                {%- for item in cart.items -%}
                  <div
                    id="CartDrawer-Item-{{ item.index | plus: 1 }}"
                    class="cart-item"
                  >
                    <div class="cart-item__media">
                      <style>
                        .cart-item__media::after {
                          content: '';
                          display: block;
                          width: 0;
                          padding-bottom: {{ padding_bottom }}%;
                        }
                      </style>

                      <a
                        href="{{ item.url }}"
                        class="cart-item__link focus-inset"
                        aria-label="{{ 'accessibility.product_link' | t }}"
                      ></a>
                      {%- if item.image -%}
                        {%- liquid
                          assign calc_ratio = 1
                          if settings.card_image_fit == 'cover' and item.image.aspect_ratio > settings_aspect_ratio
                            assign calc_ratio = item.image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
                          endif
                        -%}
                        {%- capture img_sizes -%}
                          (min-width: 576px) calc({{ calc_ratio }} * 90px), calc({{ calc_ratio }} * 60px)
                        {%- endcapture -%}
                        {%- capture image_styles -%}
                          object-fit: {{ settings.card_image_fit }};
                        {%- endcapture -%}

                        {{
                          item.image
                          | image_url: width: item.image.width
                          | image_tag:
                            loading: 'lazy',
                            widths: '90, 180, 270, 550, 750, 990, 1200, 1500, 1800, 2000',
                            sizes: img_sizes,
                            class: 'cart-item__image',
                            style: image_styles
                        }}

                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg cart-item__image' }}
                      {%- endif -%}
                    </div>

                    <div class="cart-item__details">
                      <div class="cart-item__info">
                        {% comment %} render vendor {% endcomment %}
                        {%- if settings.show_vendor_cart_drawer -%}
                          <div class="cart-item__vendor body-xs">
                            {%- if settings.enable_vendor_link -%}
                              {{- item.product.vendor | link_to_vendor: class: 'focus-inset' -}}
                            {%- else -%}
                              {{- item.product.vendor -}}
                            {%- endif -%}
                          </div>
                        {%- endif -%}

                        <div class="cart-item__info-line">
                          <a href="{{ item.url }}" class="cart-item__name focus-inset">
                            <span class="link--hover-underline">{{- item.product.title | escape -}}</span>
                          </a>

                          <cart-remove-button
                            id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                            data-index="{{ item.index | plus: 1 }}"
                          >
                            <button
                              type="button"
                              class="button button--unstyled focus-inset"
                              aria-label="{{ 'general.cart.remove_product' | t: title: item.title }}"
                            >
                              {% render 'icon-remove' %}
                            </button>
                          </cart-remove-button>
                        </div>

                        {% comment %} render price per item {% endcomment %}
                        {% comment %}
                          <div class="cart-item__price-wrapper">
                            {%- if item.original_price != item.final_price -%}
                              <div class="cart-item__discounted-prices">
                                <span class="visually-hidden">
                                  {{- 'products.product.price.sale_price' | t -}}
                                </span>
                                <span class="cart-item__final-price cart-item__final-price_sale">
                                  {%- if settings.currency_code_enabled -%}
                                    {{- item.final_price | money_with_currency -}}
                                  {%- else -%}
                                    {{- item.final_price | money -}}
                                  {%- endif -%}
                                </span>
                                <span class="visually-hidden">
                                  {{- 'products.product.price.regular_price' | t -}}
                                </span>
                                <s class="cart-item__old-price">
                                  {%- if settings.currency_code_enabled -%}
                                    {{- item.original_price | money_with_currency -}}
                                  {%- else -%}
                                    {{- item.original_price | money -}}
                                  {%- endif -%}
                                </s>
                              </div>
                            {%- else -%}
                              <div class="cart-item__final-price">
                                {%- if settings.currency_code_enabled -%}
                                  {{- item.original_price | money_with_currency -}}
                                {%- else -%}
                                  {{- item.original_price | money -}}
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                          </div>
                        {% endcomment %}
                      </div>

                      {% comment %} render info lines (options, properties, discounts) {% endcomment %}
                      {%- if item.product.has_only_default_variant == false
                        or item.properties != blank
                        or item.selling_plan_allocation != blank
                        or item.line_level_discount_allocations != blank
                      -%}
                        <div class="cart-item__lines">
                          {% comment %} render options {% endcomment %}
                          {%- if item.product.has_only_default_variant == false -%}
                            <dl class="product-option__group">
                              {%- for option in item.options_with_values -%}
                                <div class="product-option body-xs">
                                  <dt>{{ option.name }}:</dt>
                                  <dd>{{ option.value }}</dd>
                                </div>
                              {%- endfor -%}
                            </dl>
                          {%- endif -%}

                          {% comment %} render properties {% endcomment %}
                          {%- if item.properties != blank -%}
                            <dl class="product-option__group">
                              {%- for property in item.properties -%}
                                {%- assign property_first_char = property.first | slice: 0 -%}
                                {%- if property.last != blank and property_first_char != '_' -%}
                                  <div class="product-option body-xs">
                                    <dt>{{ property.first }}:</dt>
                                    <dd>
                                      {%- if property.last contains '/uploads/' -%}
                                        <a
                                          href="{{ property.last }}"
                                          class="link"
                                          target="_blank"
                                        >
                                          {{ property.last | split: '/' | last }}
                                        </a>
                                      {%- else -%}
                                        {{ property.last }}
                                      {%- endif -%}
                                    </dd>
                                  </div>
                                {%- endif -%}
                              {%- endfor -%}
                            </dl>
                          {%- endif -%}

                          {% comment %} render selling_plan_allocation {% endcomment %}
                          {%- if item.selling_plan_allocation != blank -%}
                            <p class="product-option body-xs">
                              {{- item.selling_plan_allocation.selling_plan.name -}}
                            </p>
                          {%- endif -%}

                          {% comment %} render discounts {% endcomment %}
                          {%- if item.line_level_discount_allocations != blank -%}
                            <ul
                              class="discounts list-unstyled"
                              role="list"
                              aria-label="{{ 'customer.order.discount' | t }}"
                            >
                              {%- for discount in item.line_level_discount_allocations -%}
                                {% liquid
                                  if settings.currency_code_enabled
                                    assign discount_total = discount.discount_application.total_allocated_amount | money_with_currency
                                  else
                                    assign discount_total = discount.discount_application.total_allocated_amount | money
                                  endif
                                %}
                                <li class="discounts__discount body-xs">
                                  {%- render 'icon-discount' -%}
                                  <span>{{ discount.discount_application.title }} -{{ discount_total }}</span>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      {%- endif -%}

                      {% comment %} render quantity and total price {% endcomment %}
                      <div class="cart-item__bottom">
                        <div class="cart-item__quantity">
                          <label class="visually-hidden" for="Drawer-quantity-{{ item.index | plus: 1 }}">
                            {{- 'products.product.quantity.label' | t -}}
                          </label>
                          <quantity-input class="quantity">
                            <button
                              class="quantity__button no-js-hidden focus-inset"
                              name="minus"
                              type="button"
                            >
                              <span class="visually-hidden">
                                {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
                              </span>
                              {% render 'icon-minus' %}
                            </button>
                            <input
                              class="quantity__input focus-inset"
                              type="number"
                              name="updates[]"
                              value="{{ item.quantity }}"
                              min="0"
                              aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                              id="Drawer-quantity-{{ item.index | plus: 1 }}"
                              data-index="{{ item.index | plus: 1 }}"
                            >
                            <button
                              class="quantity__button no-js-hidden focus-inset"
                              name="plus"
                              type="button"
                            >
                              <span class="visually-hidden">
                                {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
                              </span>
                              {% render 'icon-plus' %}
                            </button>
                          </quantity-input>
                        </div>

                        {% comment %} render total line price (per item * quantity) {% endcomment %}
                        {% comment %}{%- if item.quantity > 1 -%}{% endcomment %}
                        <div class="cart-item__price-wrapper">
                          {%- if item.original_line_price != item.final_line_price -%}
                            <dl class="cart-item__discounted-prices">
                              <dt class="visually-hidden">
                                {{- 'products.product.price.sale_price' | t -}}
                              </dt>
                              <dd class="cart-item__final-price cart-item__final-price_sale">
                                {%- if settings.currency_code_enabled -%}
                                  {{- item.final_line_price | money_with_currency -}}
                                {%- else -%}
                                  {{- item.final_line_price | money -}}
                                {%- endif -%}
                              </dd>
                              <dt class="visually-hidden">
                                {{ 'products.product.price.regular_price' | t }}
                              </dt>
                              <dd>
                                <s class="cart-item__old-price">
                                  {%- if settings.currency_code_enabled -%}
                                    {{- item.original_line_price | money_with_currency -}}
                                  {%- else -%}
                                    {{- item.original_line_price | money -}}
                                  {%- endif -%}
                                </s>
                              </dd>
                            </dl>
                          {%- else -%}
                            <span class="cart-item__final-price">
                              {%- if settings.currency_code_enabled -%}
                                {{- item.original_line_price | money_with_currency -}}
                              {%- else -%}
                                {{- item.original_line_price | money -}}
                              {%- endif -%}
                            </span>
                          {%- endif -%}

                          {% comment %} render unit price {% endcomment %}
                          {%- if item.variant.available and item.unit_price_measurement -%}
                            <div class="unit-price">
                              <span class="visually-hidden">
                                {{- 'products.product.price.unit_price' | t -}}
                              </span>
                              {%- if settings.currency_code_enabled -%}
                                {{- item.variant.unit_price | money_with_currency -}}
                              {%- else -%}
                                {{- item.variant.unit_price | money -}}
                              {%- endif -%}
                              <span aria-hidden="true">/</span>
                              <span class="visually-hidden"
                                >&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span
                              >
                              {%- if item.variant.unit_price_measurement.reference_value != 1 -%}
                                {{- item.variant.unit_price_measurement.reference_value -}}
                              {%- endif -%}
                              {{- item.variant.unit_price_measurement.reference_unit -}}
                            </div>
                          {%- endif -%}
                        </div>
                        {% comment %}{%- endif -%}{% endcomment %}
                      </div>

                      {% comment %} render error {% endcomment %}
                      <div
                        id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}"
                        class="cart-item__error"
                        role="alert"
                      >
                        <small class="cart-item__error-text body-xs"></small>
                        {% render 'icon-error' %}
                      </div>
                    </div>

                    <div class="loading-overlay hidden">
                      <div class="loading-overlay__spinner">
                        {% render 'icon-loading-circle' %}
                      </div>
                    </div>
                  </div>
                {% endfor %}
              </div>
            {%- endif -%}
            <p
              id="CartDrawer-LiveRegionText"
              class="visually-hidden"
              role="status"
            ></p>
            <p
              id="CartDrawer-LineItemStatus"
              class="visually-hidden"
              aria-hidden="true"
              role="status"
            >
              {{- 'accessibility.loading' | t -}}
            </p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>

      {% comment %} SUBTOTAL, TX NOTE, BUTTONS {% endcomment %}
      <div class="cart-drawer__footer">
        <div class="totals" role="status">
          <div class="totals__subtotal h5">
            {{- 'sections.cart.subtotal' | t -}}
          </div>
          <div class="totals__subtotal-value">
            <span class="h5">
              {%- if settings.cart_drawer_total_currency -%}
                {{ cart.total_price | money_with_currency }}
              {%- else -%}
                {{ cart.total_price | money }}
              {%- endif -%}
            </span>
            <div class="loading-overlay hidden">
              <div class="loading-overlay__spinner">
                {% render 'icon-loading-circle' %}
              </div>
            </div>
          </div>

          {%- if cart.cart_level_discount_applications.size > 0 -%}
            <ul
              class="discounts list-unstyled"
              role="list"
              aria-label="{{ 'customer.order.discount' | t }}"
            >
              {%- for discount in cart.cart_level_discount_applications -%}
                {% liquid
                  if settings.currency_code_enabled
                    assign discount_total = discount.total_allocated_amount | money_with_currency
                  else
                    assign discount_total = discount.total_allocated_amount | money
                  endif
                %}
                <li class="discounts__discount body-xs">
                  {%- render 'icon-discount' -%}
                  <span>{{ discount.title }} -{{ discount_total }}</span>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>

        <small class="tax-note body-small richtext-link-inside">
          {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
            {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
          {%- elsif cart.taxes_included -%}
            {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
          {%- elsif shop.shipping_policy.body != blank -%}
            {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
          {%- else -%}
            {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
          {%- endif -%}
        </small>

        {% comment %} CART NOTE {% endcomment %}
        {%- if settings.show_cart_note_drawer -%}
          <div class="cart-drawer__note{% if settings.collapsible_cart_note_drawer %} cart-drawer__note--collabsible{% endif %}">
            <details
              id="Details-CartDrawer-Note"
              class="cart-drawer__note-details"
              {% if settings.collapsible_cart_note_drawer == false %}
                open
              {% endif %}
            >
              <summary class="cart-drawer__note-summary{% if settings.collapsible_cart_note_drawer %} focus-inset{% endif %}">
                <span class="h6">
                  {{- 'sections.cart.note_title' | t -}}
                </span>
                {%- if settings.collapsible_cart_note_drawer -%}
                  <div class="cart-drawer__note-icon">
                    {% render 'icon-caret' %}
                  </div>
                {%- endif -%}
              </summary>

              <cart-note class="cart__note field">
                <label for="CartDrawer-note" class="visually-hidden">
                  {{- 'sections.cart.note_title' | t -}}
                </label>
                <textarea
                  class="text-area field__input"
                  name="note"
                  dir="ltr"
                  id="CartDrawer-note"
                  placeholder="{{- 'sections.cart.note_placeholder' | t -}}"
                >{{ cart.note }}</textarea>

                <span class="cart__note-loading">
                  {% render 'icon-loading-circle' %}
                </span>
                <span class="cart__note-success">
                  {% render 'icon-success' %}
                </span>
              </cart-note>
            </details>
          </div>
        {%- endif -%}

        <div class="cart-drawer__buttons">
          <button
            type="submit"
            id="CartDrawer-Checkout"
            class="cart__checkout-button button button--primary button--full-width focus-inset"
            name="checkout"
            form="CartDrawer-Form"
            {% if cart == empty %}
              disabled
            {% endif %}
          >
            <div class="button__content">
              <span class="button__label" data-label="{{- 'general.cart.checkout' | t -}}">
                {{- 'general.cart.checkout' | t -}}
              </span>
            </div>
          </button>
          {% assign cart_btn_label = 'general.cart.view' | t %}
          {% render 'button',
            btn_label: cart_btn_label,
            btn_style: 'tertiary',
            btn_link: routes.cart_url,
            btn_arrow: false,
            enable_arrow: false,
            class: 'cart__link'
          %}
        </div>
      </div>
    </div>
  </div>
</cart-drawer>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function isIE() {
      const ua = window.navigator.userAgent;
      const msie = ua.indexOf('MSIE ');
      const trident = ua.indexOf('Trident/');

      return msie > 0 || trident > 0;
    }

    if (!isIE()) return;
    const cartSubmitInput = document.createElement('input');
    cartSubmitInput.setAttribute('name', 'checkout');
    cartSubmitInput.setAttribute('type', 'hidden');
    document.querySelector('#cart').appendChild(cartSubmitInput);
    document.querySelector('#checkout').addEventListener('click', function (event) {
      document.querySelector('#cart').submit();
    });
  });
</script>
