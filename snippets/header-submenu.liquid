<ul
  class="header-submenu list-menu list-menu--disclosure motion-reduce color-background-1 list-unstyled"
  role="list"
>
  {%- for childlink in link.links -%}
    <li class="header-submenu__item">
      {%- if childlink.links == blank -%}
        <a
          href="{{ childlink.url }}"
          {% if settings.links_blank and childlink.type == 'http_link' %}
            target="_blank"
          {% endif %}
          class="header-submenu__item-link focus-inset{% if childlink.current and childlink.url != '/' %} header-submenu__item-link--current{% endif %}"
          {% if childlink.current and childlink.url != '/' %}
            aria-current="page"
          {% endif %}
        >
          <span class="header-submenu__item-label body-normal">
            {{ childlink.title | escape }}
          </span>
        </a>
      {%- else -%}
        <a
          href="{{ childlink.url }}"
          {% if settings.links_blank and childlink.type == 'http_link' %}
            target="_blank"
          {% endif %}
          class="header-submenu__item-link list-menu__item focus-inset{% if childlink.current and childlink.url != '/' %} header-submenu__item-link--current{% endif %}"
          {% if childlink.current and childlink.url != '/' %}
            aria-current="page"
          {% endif %}
        >
          <span class="header-submenu__item-label body-normal">
            {{ childlink.title | escape }}
          </span>
          {% render 'icon-btn-arrow' %}
        </a>
        <ul
          class="header-submenu list-menu--disclosure list-menu motion-reduce color-background-1 list-unstyled"
        >
          {%- for grandchildlink in childlink.links -%}
            <li class="header-submenu__item">
              <a
                href="{{ grandchildlink.url }}"
                {% if settings.links_blank and grandchildlink.type == 'http_link' %}
                  target="_blank"
                {% endif %}
                class="header-submenu__item-link focus-inset{% if grandchildlink.current and grandchildlink.url != '/' %} header-submenu__item-link--current{% endif %}"
                {% if grandchildlink.current and grandchildlink.url != '/' %}
                  aria-current="page"
                {% endif %}
              >
                <span class="header-submenu__item-label">
                  {{ grandchildlink.title | escape }}
                </span>
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </li>
  {%- endfor -%}
</ul>
