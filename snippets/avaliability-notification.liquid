{% comment %}
  Avaliability notification
   Accepts:
   - product: {Object} product object.
   - section: {Object} section object.
   - block: {Object} block object.

  Usage:
  {% render 'avaliability-notification',
    section: section,
    block: block,
    product: product
  %}
{% endcomment %}

<avaliability-notification-modal
  id="AvaliabilityNotificationModal-{{ section.id }}"
  class="product-popup-modal product-popup--sold-out no-js-hidden"
>
  <div
    role="dialog"
    aria-label="{{ 'products.product.availiability_notification.title' | t }}"
    aria-modal="true"
    class="product-popup-modal__content"
    tabindex="-1"
  >
    <button
      id="ModalClose-{{ section.id }}"
      type="button"
      class="product-popup-modal__close modal-close-button focus-inset"
      aria-label="{{ 'accessibility.close' | t }}"
    >
      {% render 'icon-close' %}
    </button>
    <div class="product-popup-modal__content-info">
      <div class="product-popup-modal__text">
        <h3 class="product-popup-modal__title title h4">
          {{ 'products.product.availiability_notification.title' | t }}
        </h3>
        <p class="product-popup-modal__description">
          {{- 'products.product.availiability_notification.description' | t -}}
        </p>
      </div>
      {%
        render 'product-card-horizontal-extended',
        product_card_product: product,
        show_vendor: true,
      %}
      {% assign subscription_form_id = 'ContactFormSubscribe-' %}
      {%- form 'contact', id: subscription_form_id, class: 'contact-form__form subscription-form' -%}
        <div class="product-popup-modal__form-wrapper">
          <div class="field field--email field--with-error">
            <input
              autocomplete="email"
              type="email"
              id="ContactForm-email"
              class="field__input"
              name="contact[email]"
              dir="ltr"
              spellcheck="false"
              pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
              autocapitalize="off"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="ContactForm-email-error"
              {% endif %}
              placeholder="{{- 'templates.contact.form.email_placeholder' | t -}}"
            >
            <label
              class="field__label h6"
              for="ContactForm-email"
            >
              {{- 'templates.contact.form.email' | t -}}
            </label>
            {%- if form.errors contains 'email' -%}
              <small class="contact-form__field-error" id="ContactForm-email-error">
                <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                <span class="form__message">
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </span>
              </small>
            {%- endif -%}
          </div>
          <input
            type="hidden"
            id="ContactForm-product"
            name="contact[product_subscription]"
            value="{{ product.title }}"
          >

          <input
            id="ContactForm-options"
            type="hidden"
            name="contact[options_subscription]"
            data-product="{{ product.handle }}"
          >

          <button type="submit" class="button button--primary focus-inset">
            <span
              class="button__label"
              data-label="{{- 'products.product.availiability_notification.label' | t -}}"
            >
              {{- 'products.product.availiability_notification.label' | t -}}
            </span>
          </button>
        </div>
        {% if block.settings.additional_text != blank %}
          <div class="contact-form__add-text body-small richtext-link-inside product-popup-modal__additional">
            {{ block.settings.additional_text }}
          </div>
        {% endif %}
      {%- endform -%}
    </div>
  </div>
</avaliability-notification-modal>
