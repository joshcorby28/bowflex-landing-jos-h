{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'component-rte.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{{ 'component-card-horizontal-extended.css' | asset_url | stylesheet_tag }}

{%- for block in section.blocks -%}
  {%- if block.type == 'promo_code' and block.settings.promo_code != blank -%}
    <script src="{{ 'promocode-copy.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- if block.type == 'product_markers' -%}
    {{ 'section-product-markers.css' | asset_url | stylesheet_tag }}
    {{ 'component-card-horizontal.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- if block.type == 'product_banner' -%}
    {{ 'component-product-banner.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- if block.type == 'help_banner' -%}
    {{ 'component-help-banner.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- if block.type == 'recently_viewed' -%}
    {%- style -%}
      .recently-viewed__wrapper {
        position: relative;
      }
      .recently-viewed__empty {
        display: none;
        width: 100%;
        align-items: center;
        justify-content: center;
      }
      .recently-viewed__empty span {
        max-width: 550px;
        text-align: center;
      }
      .recently-viewed--empty .recently-viewed__empty {
        display: flex;
      }
      .recently-viewed .loading-overlay {
        inset: 0;
        z-index: 6;
        display: none;
        width: 100%;
        padding: 0 5rem;
      }
      .recently-viewed.recently-viewed--loading .loading-overlay {
        display: block;
      }
      .recently-viewed.recently-viewed--loading .loading-overlay .loading-overlay__spinner {
        top: 50%;
        transform: translateY(-50%);
      }
      .recently-viewed.recently-viewed--loading .recently-viewed__navigation,
      .recently-viewed.recently-viewed--empty .recently-viewed__navigation {
        display: none;
      }
    {%- endstyle -%}
    <script src="{{ 'recently-viewed.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
{%- endfor -%}

<script src="{{ 'main-product.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'copy.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'update-slider.js' | asset_url }}" defer="defer"></script>

{%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
{%- if first_3d_model -%}
  {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
  <link
    id="ModelViewerStyle"
    rel="stylesheet"
    href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
    media="print"
    onload="this.media='all'"
  >
  <link
    id="ModelViewerOverride"
    rel="stylesheet"
    href="{{ 'component-model-viewer-ui.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
{%- endif -%}

{%- style -%}
  {% render 'section-padding' %}
{%- endstyle -%}

<section
  id="MainProduct-{{ section.id }}"
  data-section="{{ section.id }}"
  class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} background"
>
  <div class="product {% if product.media.size > 0 %}row{% else %}product--no-media{% endif %} container">
    <div
      class="product__outer"
    >
      <div
        class="product__main product__info-column color-{{ section.settings.media_color_scheme }}"
        data-section="main-{{ section.id }}"
        data-layout="{{ section.settings.layout_type }}"
        data-layout-mobile="{{ section.settings.mobile_layout_type }}"
      >
        <div class="product__main-sticky">
          {% if product.media.size > 0 %}
            <div class="product__media-wrapper">
              <div class="product__media-list js-media-list {{ section.settings.layout_type }} {{ section.settings.mobile_layout_type }}--mobile {{ section.settings.aspect_ratio }}">
                <div
                  class="
                    product__media-list-container js-media-wrapper{% if section.settings.layout_type == 'gallery'%} gallery-wrapper columns--{{ section.settings.columns_per_line }}{% endif %}
                    {% if section.settings.mobile_layout_type == 'gallery' %} gallery-wrapper--mobile{% endif %}
                  "
                >
                  {%- liquid
                    assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
                  -%}

                  {%- if product.selected_or_first_available_variant.featured_media != null -%}
                    {%- assign featured_media = product.selected_or_first_available_variant.featured_media -%}
                    {%- case section.settings.aspect_ratio -%}
                      {%- when 'landscape' -%}
                        {%- assign ratio = '4/3' -%}
                      {%- when 'portrait' -%}
                        {%- assign ratio = '457/609' -%}
                      {%- when 'square' -%}
                        {%- assign ratio = '1/1' -%}
                      {%- else -%}
                        {%- assign ratio = '1/1' -%}
                    {%- endcase -%}

                    {% liquid
                      assign aspect_ratio = ratio | split: '/'
                      assign temp = aspect_ratio[0] | append: '.0'
                      assign settings_aspect_ratio = aspect_ratio[0] | append: '.0' | divided_by: aspect_ratio[1]
                    %}
                    <div
                      class="product__media-item active js-media-item{% if section.settings.layout_type == 'gallery'%} gallery-item{% endif %} {% if section.settings.mobile_layout_type == 'gallery' %} gallery-item--mobile{% endif %}{% if section.settings.image_fit == 'contain' %} product__media-item--contain{% endif %}"
                      data-media-id="{{ section.id }}-{{ featured_media.id }}"
                    >
                      {% liquid
                        if section.settings.layout_type == 'gallery'
                          if product.media.size > 1
                            assign columns_per_line = section.settings.columns_per_line
                          else
                            assign columns_per_line = 1
                          endif
                        else
                          assign columns_per_line = blank
                        endif
                      %}
                      {% render 'product-thumbnail',
                        main_product_object: product,
                        media: featured_media,
                        position: 'featured',
                        modal_id: section.id,
                        lazy_load: false,
                        media_fit: section.settings.image_fit,
                        loop: true,
                        settings_aspect_ratio: settings_aspect_ratio,
                        default_aspect_ratio: section.settings.aspect_ratio,
                        desktop_layout: section.settings.layout_type,
                        mobile_layout: section.settings.mobile_layout_type,
                        columns: columns_per_line,
                        is_main: true
                      %}
                      {%- if section.settings.badge_sale_show
                        or section.settings.badge_soldout_show
                        or section.settings.badge_new_show
                        or section.settings.badge_custom_show
                      -%}
                        <div class="product__media-badges">
                          <div class="card__badges body-small">
                            {%- if product.available == false and section.settings.badge_soldout_show -%}
                              <span
                                class="badge badge--sold-out color-{{ settings.badge_soldout_color_scheme }}"
                                aria-hidden="true"
                              >
                                {{- 'products.product.sold_out' | t -}}
                              </span>
                            {%- elsif product.selected_or_first_available_variant.compare_at_price
                                > product.selected_or_first_available_variant.price
                              and product.available
                              and section.settings.badge_sale_show
                            -%}
                              <span
                                class="badge badge--sale color-{{ settings.badge_sale_color_scheme }}"
                                aria-hidden="true"
                              >
                                {% if settings.badge_sale_type == 'sale' %}
                                  {{- 'products.product.on_sale' | t -}}
                                {% else %}
                                  -
                                  <span>
                                    {{
                                      product.selected_or_first_available_variant.compare_at_price
                                      | minus: product.selected_or_first_available_variant.price
                                      | times: 100.0
                                      | divided_by: product.selected_or_first_available_variant.compare_at_price
                                      | round
                                    -}}
                                    %
                                  </span>
                                {% endif %}
                              </span>
                            {%- endif -%}
                            {% if section.settings.badge_new_show %}
                              {% assign today = 'now' | date: '%s' %}
                              {% assign product_published_at = product.published_at | date: '%s' %}
                              {% assign days_difference = today | minus: product_published_at %}
                              {% assign days_difference_in_days = days_difference | divided_by: 86400 %}

                              {% if days_difference_in_days <= settings.new_badge_days %}
                                <span class="badge badge--new color-{{ settings.badge_new_show }}">
                                  {{- 'products.product.new' | t -}}
                                </span>
                              {% endif %}
                            {% endif %}
                            {% if section.settings.badge_custom_show and product.metafields.custom.badges != blank %}
                              {% if product.metafields.custom.badges.list? %}
                                <div class="card__badge-list">
                                  {% for badge in product.metafields.custom.badges.value %}
                                    <span
                                      class="badge badge--custom color-{{ settings.badge_custom_color_scheme }}"
                                      aria-hidden="true"
                                    >
                                      {%- if settings.custom_badge_icon != 'none' %}
                                        {% render 'icon-pack', icon: settings.custom_badge_icon %}
                                      {% endif %}
                                      {{ badge }}
                                    </span>
                                  {% endfor %}
                                </div>
                              {% else %}
                                <span
                                  class="badge badge--custom color-{{ settings.badge_custom_color_scheme }}"
                                  aria-hidden="true"
                                >
                                  {%- if settings.custom_badge_icon != 'none' %}
                                    {% render 'icon-pack', icon: settings.custom_badge_icon %}
                                  {% endif %}
                                  {{ product.metafields.custom.badges }}
                                </span>
                              {% endif %}
                            {% endif %}
                          </div>
                        </div>
                      {% endif %}
                    </div>
                  {%- endif -%}

                  {%- for media in product.media -%}
                    {%- case section.settings.aspect_ratio -%}
                      {%- when 'landscape' -%}
                        {%- assign ratio = '4/3' -%}
                      {%- when 'portrait' -%}
                        {%- assign ratio = '457/609' -%}
                      {%- when 'square' -%}
                        {%- assign ratio = '1/1' -%}
                      {%- else -%}
                        {%- assign ratio = '1/1' -%}
                    {%- endcase -%}

                    {% liquid
                      assign aspect_ratio = ratio | split: '/'
                      assign temp = aspect_ratio[0] | append: '.0'
                      assign settings_aspect_ratio = aspect_ratio[0] | append: '.0' | divided_by: aspect_ratio[1]
                    %}

                    {%- unless media.id == product.selected_or_first_available_variant.featured_media.id -%}
                      <div
                        class="product__media-item js-media-item{% if product.selected_or_first_available_variant.featured_media == null and forloop.index == 1 %} active{% endif %}{% if section.settings.layout_type == 'gallery'%} gallery-item{% endif %}{% if section.settings.mobile_layout_type == 'gallery' %} gallery-item--mobile{% endif %}  {% if media.media_type != 'image' %} product__media-item--full{% endif %} {% if variant_images contains media.src %} product__media-item--variant{% endif %} {% if section.settings.image_fit == 'contain' %} product__media-item--contain{% endif %}"
                        data-media-id="{{ section.id }}-{{ media.id }}"
                      >
                        {% liquid
                          if section.settings.layout_type == 'gallery'
                            if product.media.size > 1
                              assign columns_per_line = section.settings.columns_per_line
                            else
                              assign columns_per_line = 1
                            endif
                          else
                            assign columns_per_line = blank
                          endif
                        %}
                        {% render 'product-thumbnail',
                          main_product_object: product,
                          media: media,
                          position: forloop.index,
                          modal_id: section.id,
                          lazy_load: false,
                          media_fit: section.settings.image_fit,
                          loop: true,
                          settings_aspect_ratio: settings_aspect_ratio,
                          desktop_layout: section.settings.layout_type,
                          mobile_layout: section.settings.mobile_layout_type,
                          columns: columns_per_line,
                          is_main: true
                        %}

                        {%- if section.settings.badge_sale_show
                          or section.settings.badge_soldout_show
                          or section.settings.badge_new_show
                          or section.settings.badge_custom_show
                        -%}
                          <div class="product__media-badges">
                            <div class="card__badges body-small">
                              {%- if product.available == false and section.settings.badge_soldout_show -%}
                                <span
                                  class="badge badge--sold-out color-{{ settings.badge_soldout_color_scheme }}"
                                  aria-hidden="true"
                                >
                                  {{- 'products.product.sold_out' | t -}}
                                </span>
                              {%- elsif product.selected_or_first_available_variant.compare_at_price
                                  > product.selected_or_first_available_variant.price
                                and product.available
                                and section.settings.badge_sale_show
                              -%}
                                <span
                                  class="badge badge--sale color-{{ settings.badge_sale_color_scheme }}"
                                  aria-hidden="true"
                                >
                                  {% if settings.badge_sale_type == 'sale' %}
                                    {{- 'products.product.on_sale' | t -}}
                                  {% else %}
                                    -
                                    <span>
                                      {{
                                        product.selected_or_first_available_variant.compare_at_price
                                        | minus: product.selected_or_first_available_variant.price
                                        | times: 100.0
                                        | divided_by: product.selected_or_first_available_variant.compare_at_price
                                        | round
                                      -}}
                                      %
                                    </span>
                                  {% endif %}
                                </span>
                              {%- endif -%}
                              {% if section.settings.badge_new_show %}
                                {% assign today = 'now' | date: '%s' %}
                                {% assign product_published_at = product.published_at | date: '%s' %}
                                {% assign days_difference = today | minus: product_published_at %}
                                {% assign days_difference_in_days = days_difference | divided_by: 86400 %}

                                {% if days_difference_in_days <= settings.new_badge_days %}
                                  <span class="badge badge--new color-{{ settings.badge_new_show }}">
                                    {{- 'products.product.new' | t -}}
                                  </span>
                                {% endif %}
                              {% endif %}
                              {% if section.settings.badge_custom_show and product.metafields.custom.badges != blank %}
                                {% if product.metafields.custom.badges.list? %}
                                  <div class="card__badge-list">
                                    {% for badge in product.metafields.custom.badges.value %}
                                      <span
                                        class="badge badge--custom color-{{ settings.badge_custom_color_scheme }}"
                                        aria-hidden="true"
                                      >
                                        {%- if settings.custom_badge_icon != 'none' %}
                                          {% render 'icon-pack', icon: settings.custom_badge_icon %}
                                        {% endif %}
                                        {{ badge }}
                                      </span>
                                    {% endfor %}
                                  </div>
                                {% else %}
                                  <span
                                    class="badge badge--custom color-{{ settings.badge_custom_color_scheme }}"
                                    aria-hidden="true"
                                  >
                                    {%- if settings.custom_badge_icon != 'none' %}
                                      {% render 'icon-pack', icon: settings.custom_badge_icon %}
                                    {% endif %}
                                    {{ product.metafields.custom.badges }}
                                  </span>
                                {% endif %}
                              {% endif %}
                            </div>
                          </div>
                        {% endif %}
                      </div>
                    {%- endunless -%}
                  {%- endfor -%}
                </div>
                {%- if product.media.size > 1 -%}
                  <div class="product__slider-nav no-js-hidden">
                    <div class="swiper-button-prev product__slider-nav-prev focus-inset">
                      {% render 'icon-caret-left' %}
                    </div>
                    <div class="swiper-button-next product__slider-nav-next focus-inset">
                      {% render 'icon-caret-right' %}
                    </div>
                  </div>
                {%- endif -%}
              </div>

              {%- if product.media.size > 1 -%}
                {% comment %} render thumbnails {% endcomment %}

                {%- case section.settings.thumbs_aspect_ratio -%}
                  {%- when 'landscape' -%}
                    {%- assign thumbs_ratio = '4/3' -%}
                    {%- assign thumbs_height = '45' -%}
                  {%- when 'portrait' -%}
                    {%- assign thumbs_ratio = '60/80' -%}
                    {%- assign thumbs_height = '80' -%}
                  {%- when 'square' -%}
                    {%- assign thumbs_ratio = '1/1' -%}
                    {%- assign thumbs_height = '60' -%}
                  {%- else -%}
                    {%- assign thumbs_ratio = '1/1' -%}
                    {%- assign thumbs_height = '60' -%}
                {%- endcase -%}

                {% liquid
                  assign thumbs_aspect_ratio = thumbs_ratio | split: '/'
                  assign thumbs_temp = thumbs_aspect_ratio[0] | append: '.0'
                  assign settings_thumbs_aspect_ratio = thumbs_aspect_ratio[0] | append: '.0' | divided_by: thumbs_aspect_ratio[1]
                  assign thumbs_padding_bottom = thumbs_aspect_ratio[1] | divided_by: thumbs_temp | times: 100 | round: 2
                -%}
                <div class="product__media-sublist-outer" style="--thumbs-height: {{ thumbs_height }}px;">
                  <div
                    class="product__media-sublist js-media-sublist swiper"
                    data-thumbs-direction="{{ section.settings.thumbs_direction }}"
                  >
                    <div class="product__media-sublist-container swiper-wrapper">
                      {%- if product.selected_or_first_available_variant.featured_media != null -%}
                        {%- assign featured_media = product.selected_or_first_available_variant.featured_media -%}

                        <div
                          class="product__media-subitem swiper-slide {% if section.settings.image_fit == 'contain' %} product__media-item--contain{% endif %}"
                          data-media-sub-id="{{ section.id }}-{{ featured_media.id }}"
                          tabindex="0"
                        >
                          <div class="product__media" style="padding-bottom: {{ thumbs_padding_bottom }}%;">
                            {%- capture style -%}
                              object-position: {{ featured_media.presentation.focal_point }};
                              object-fit: {{ section.settings.thumbs_image_fit | default: 'cover' }};
                            {%- endcapture -%}
                            {%- liquid
                              assign thumbs_calc_ratio = 1
                              if section.settings.thumbs_image_fit == 'cover' and featured_media.preview_image.aspect_ratio > settings_thumbs_aspect_ratio
                                assign thumbs_calc_ratio = featured_media.preview_image.aspect_ratio | divided_by: settings_thumbs_aspect_ratio | round: 2
                              endif
                            -%}
                            {%- capture subitem_sizes -%}
                              calc(60px * {{ thumbs_calc_ratio }})
                            {%- endcapture -%}
                            {% liquid
                              assign feat_media_img_alt = product.title

                              if featured_media.preview_image.alt != blank
                                assign feat_media_img_alt = featured_media.preview_image.alt
                              endif
                            %}
                            {{
                              featured_media.preview_image
                              | image_url: width: featured_media.preview_image.width
                              | image_tag:
                                loading: 'lazy',
                                sizes: subitem_sizes,
                                widths: '60, 120, 180',
                                style: style,
                                alt: feat_media_img_alt
                            }}
                          </div>
                        </div>
                      {%- endif -%}

                      {%- for media in product.media -%}
                        {%- unless media.id == product.selected_or_first_available_variant.featured_media.id -%}
                          <div
                            class="product__media-subitem swiper-slide {% if variant_images contains media.src %} product__media-item--variant{% endif %} {% if section.settings.image_fit == 'contain' %} product__media-item--contain{% endif %}"
                            data-media-sub-id="{{ section.id }}-{{ media.id }}"
                          >
                            <div class="product__media" style="padding-bottom: {{ thumbs_padding_bottom }}%;">
                              {%- capture style -%}
                                object-position: {{ media.presentation.focal_point }};
                                object-fit: {{ section.settings.thumbs_image_fit | default: 'cover' }};
                              {%- endcapture -%}
                              {%- liquid
                                assign thumbs_calc_ratio = 1
                                if section.settings.thumbs_image_fit == 'cover' and media.preview_image.aspect_ratio > settings_thumbs_aspect_ratio
                                  assign thumbs_calc_ratio = media.preview_image.aspect_ratio | divided_by: settings_thumbs_aspect_ratio | round: 2
                                endif
                              -%}
                              {%- capture subitem_sizes -%}
                                calc(60px * {{ thumbs_calc_ratio }})
                              {%- endcapture -%}
                              {% liquid
                                assign media_img_alt = product.title

                                if media.preview_image.alt != blank
                                  assign media_img_alt = media.preview_image.alt
                                endif
                              %}
                              {{
                                media.preview_image
                                | image_url: width: media.preview_image.width
                                | image_tag:
                                  loading: 'lazy',
                                  sizes: subitem_sizes,
                                  widths: '64, 128, 192',
                                  style: style,
                                  alt: media_img_alt
                              }}
                            </div>
                          </div>
                        {%- endunless -%}
                      {%- endfor -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- else -%}
            {%- case section.settings.aspect_ratio -%}
              {%- when 'landscape' -%}
                {%- assign ratio = '4/3' -%}
              {%- when 'portrait' -%}
                {%- assign ratio = '457/609' -%}
              {%- when 'square' -%}
                {%- assign ratio = '1/1' -%}
              {%- else -%}
                {%- assign ratio = '1/1' -%}
            {%- endcase -%}

            {% liquid
              assign aspect_ratio = ratio | split: '/'
              assign temp = aspect_ratio[0] | append: '.0'
              assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
            %}

            <div class="product__media-wrapper">
              <div class="product__media-list slider slider--mobile {{ section.settings.aspect_ratio }}">
                <div
                  class="product__media-list-container js-media-wrapper"
                >
                  <div class="product__media-item active js-media-item">
                    <div class="product__media media" style="padding-bottom: {{ padding_bottom }}%">
                      {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          {% endif %}

          {% if settings.show_breadcrumbs %}
            <nav
              class="breadcrumb breadcrumb body-small color-{{ section.settings.color_scheme }}"
              role="navigation"
              aria-label="breadcrumbs"
            >
              <a href="{{ routes.root_url }}" title="{{ 'general.breadcrumbs.home' | t }}">
                {{- 'general.breadcrumbs.home' | t -}}
              </a>
              <div class="breadcrumb__delimiter">/</div>
              {%- if product.collections[0] -%}
                <a href="{{ product.collections[0].url }}">{{ product.collections[0].title }}</a>
                <div class="breadcrumb__delimiter">/</div>
              {%- else -%}
                <a href="{{ routes.all_products_collection_url }}">{{ 'products.product.shop' | t }}</a>
                <div class="breadcrumb__delimiter">/</div>
              {%- endif -%}
              <span>{{ product.title }}</span>
            </nav>
          {% endif %}
        </div>
      </div>
      {%- assign product_form_id = 'product-form-' | append: section.id -%}
      {%- assign content_before_divider = '' -%}
      {%- assign content_after_divider = '' -%}

      {%- for block in section.blocks -%}
        {%- capture block_content -%}
            {%- case block.type -%}
              {%- when 'text' -%}
                {%- if block.settings.text != blank -%}
                  <div class="product__text" {{ block.shopify_attributes }}>
                      {%- if product.vendor == block.settings.text and settings.enable_vendor_link -%}
                        {{ block.settings.text | link_to_vendor: class: 'focus-inset'  | strip }}
                      {%- else -%}
                        {{ block.settings.text | strip}}
                      {%- endif -%}
                  </div>
                {%- endif -%}
              {%- when 'title' -%}
                <div class="product__title__wrapper">
                  <h1
                    class="product__title"
                    style="font-size: {{ block.settings.title_size }}px;"
                    {{ block.shopify_attributes }}
                  >
                    {{- product.title | escape -}}
                  </h1>
                </div>
              {%- when 'tags' -%}
                {%- if product.tags != blank -%}
                  <ul class="product-tags product__tags list-unstyled" {{ block.shopify_attributes }}>
                    {% for tag in product.tags %}
                      <li class="product-tags__tag ">
                        <a class="button button--{{ block.settings.button_style }}" href="{{ routes.all_products_collection_url }}/{{ tag | handleize }}"> 
                        <span class="tag__label button__label">{{ tag }}</span>
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                {%- endif -%}
              {%- when 'rating' -%}
                {%- if product.metafields.reviews.rating.value != blank -%}
                  <div class="rating-wrapper" {{ block.shopify_attributes }}>
                    <p class="rating-text caption body-normal">
                      {% liquid 
                        assign product_rating = product.metafields.reviews.rating.value 
                        assign product_rating_sides = product_rating | split: '.'
                        assign integer_part = product_rating_sides[0] 
                        assign decimal_part = product_rating_sides[1] | slice: 0, 2 
                      %}
                      <span aria-hidden="true">
                        {{ integer_part }}.{{ decimal_part }}
                        {%- if block.settings.show_rating_max -%} 
                          / {{- product.metafields.reviews.rating.value.scale_max -}} 
                        {%- endif -%}
                      </span>
                    </p>
                    {%- if block.settings.show_review_count -%}
                      <p class="rating-count caption body-normal">
                        <span aria-hidden="true ">{{ "accessibility.total_reviews" | t: rating_count: product.metafields.reviews.rating_count | strip }}</span>
                        <span class="visually-hidden">
                          {{ "accessibility.total_reviews" | t: rating_count: product.metafields.reviews.rating_count | strip }}
                        </span>
                      </p>
                    {%- endif -%}
                    {%- if block.settings.show_button -%}
                      {% liquid
                        if block.settings.button_label != blank
                          assign btn_label = block.settings.button_label

                          if block.settings.button_style != blank
                            assign btn_style = block.settings.button_style
                          else
                            assign btn_style = 'primary'
                          endif
                        endif

                        assign underline_arrow_class = false

                        if btn_style == 'link--primary' or btn_style == 'link--secondary' or btn_style == 'link--tertiary'
                          assign underline_arrow_class = true
                        endif
                      %}
                      <button
                        id="ScrollToReviews-{{ block.id }}"
                        class="rating__button button button--{{ block.settings.button_style}}{% if underline_arrow_class %} link--underline_arrow{% endif %} focus-inset"
                        type="button"
                        aria-label="{{ btn_label }}"
                        tabindex="0"
                      >
                        <span class="button__label">
                          {{- btn_label -}}
                        </span>
                      </button>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- when 'price' -%}
                <div
                  class="no-js-hidden price-wrapper "
                  id="price-{{ section.id }}"
                  {{ block.shopify_attributes }}
                >
                  {%- render 'price',
                    product: product,
                    use_variant: true,
                    price_class: 'price--product'
                  -%}
                  {%- if product.quantity_price_breaks_configured? -%}
                    <div class="volume-pricing-note" id="Volume-Note-{{ section.id }}">
                      <span>{{ 'products.product.volume_pricing.note' | t }}</span>
                    </div>
                  {%- endif -%}
                  {% if block.settings.show_tax_info == true %}
                    {%- if cart.taxes_included or cart.duties_included or shop.shipping_policy.body != blank -%}
                      <div class="product__tax caption body-small richtext-link-inside-secondary">
                        {%- if cart.duties_included and cart.taxes_included -%}
                          {{ 'products.product.duties_and_taxes_included' | t }}
                        {%- elsif cart.taxes_included -%}
                          {{ 'products.product.taxes_included' | t }}
                        {%- elsif cart.duties_included -%}
                          {{ 'products.product.duties_included' | t }}
                        {%- endif -%}
                        {%- if shop.shipping_policy.body != blank -%}
                          {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  {% endif %}
                </div>
                <div class="installment-wrapper" {{ block.shopify_attributes }}>
                  {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                  {%- form 'product', product, id: product_form_installment_id, class: 'installment' -%}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    {{ form | payment_terms }}
                  {%- endform -%}
                </div>
              {%- when 'custom_badges' -%}
                {%- if product.metafields.custom.badges != blank -%}
                  <div class="product__custom-badges" {{ block.shopify_attributes }}>
                    {%- if product.metafields.custom.badges.list? -%}
                      {%- for badge in product.metafields.custom.badges.value -%}
                        <span
                          class="badge badge--custom color-{{ section.settings.color_scheme }}"
                          aria-hidden="true"
                        >
                        {%- if settings.custom_badge_icon != 'none' -%}
                          {% render 'icon-pack', icon: settings.custom_badge_icon -%}
                        {%- endif -%}
                          {{ badge }}
                        </span>
                      {%- endfor -%}
                    {%- else -%}
                      <span class="badge badge--custom color-{{ settings.color_scheme }}" aria-hidden="true">
                        {{ product.metafields.custom.badges | strip }}
                      </span>
                    {%- endif -%}
                  </div>
                {% endif %}
              {%- when 'sku' -%}
                {% if product.selected_or_first_available_variant.sku != blank %}
                  <p
                    class="product__sku no-js-hidden {% if product.selected_or_first_available_variant.sku.size == 0 %} visibility-hidden{% endif %}"
                    id="Sku-{{ section.id }}"
                    role="status"
                    {{ block.shopify_attributes }}
                  >
                    <span class="product__sku-title">{{- 'products.product.sku' | t -}}: </span>
                    {{- product.selected_or_first_available_variant.sku -}}
                  </p>
                {% endif %}
              {%- when 'variant_picker' -%}
                {% if product.has_only_default_variant != true %}
                  <div class="product-parameters product-parameters--main" {{ block.shopify_attributes }}>
                    {% assign use_option_popup_on_page = false %}
                    {% unless product.has_only_default_variant %}
                      {% if block.settings.picker_type == 'button' %}
                        <variant-radios
                          id="variant-radios-{{ section.id }}"
                          class="no-js-hidden"
                          data-section="{{ section.id }}"
                          data-url="{{ product.url }}"
                          data-unavailable-options-clickable="{{ block.settings.enable_notification_modal  }}"
                          {{ block.shopify_attributes }}
                        >
                        {%- for option in product.options_with_values -%}
                          {% liquid
                            assign is_color_option = false
                            assign option_position = option.position | times: 1.00 

                            # for metafields color
                            for value in option.values
                              if settings.enable_color_swatch and value.swatch.color != blank
                                assign is_color_option = true
                              endif
                            endfor

                            # for custom option color
                            assign color_trigger = settings.trigger_swatch | strip | newline_to_br | split: '<br />'
                            assign name_option = option.name | handle | strip
                            for item in color_trigger
                              assign item_temp = item | handle | strip
                              if settings.enable_color_swatch and name_option == item_temp
                                assign is_color_option = true
                              endif
                            endfor

                            # check for size guide popup
                            assign has_popup_option = false
                            assign size_guide_option_name = block.settings.size_guide_option_name | handle | strip
                            if block.settings.enable_size_guide and name_option == size_guide_option_name and use_option_popup_on_page == false and block.settings.button_label != blank
                              assign has_popup_option = true
                            endif
                          %}
                          <fieldset
                            class="product-form__controls{% if is_color_option %} product-form__controls--colors{% endif %}"
                            id="SingleOptionSelector-{{ forloop.index0 }}"
                            data-option-name="{{ option.name }}"
                          >
                            <div class="product-form__group-wrapper">
                              <legend class="product-form__group-name">
                                {{- option.name |  append: ':' -}}
                                  <span id="ColorName-{{ section.id }}-{{name_option}}">
                                    {{- option.selected_value -}}
                                  </span>
                              </legend>
                              {% if block.settings.display_inventory and option_position == product.options_with_values.size %}
                                <div
                                  id="Inventory-{{ section.id }}"
                                  class="product__inventory{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} visibility-hidden{% endif %}"
                                  role="status">
                                    {% liquid
                                      assign limited_stock = block.settings.limited_stock
                                    %}
                                    {%- if product.selected_or_first_available_variant.inventory_management == 'shopify'   -%}
                                      {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                                        <span class="product__inventory-inner product__inventory-inner--{% if product.selected_or_first_available_variant.inventory_quantity <= limited_stock %}error{% endif %}">
                                          {%- if product.selected_or_first_available_variant.inventory_quantity <= limited_stock-%}
                                            {{- 'products.product.quantity.in_stock' | t: quantity: product.selected_or_first_available_variant.inventory_quantity | strip -}}
                                          {%- elsif product.selected_or_first_available_variant.inventory_quantity == 1 -%}
                                            {{ 'products.product.quantity.one_in_stock' | t }}
                                          {%- endif -%}
                                        </span>
                                      {%- else -%}
                                        {%- if product.selected_or_first_available_variant.inventory_policy != 'continue' -%}
                                          <span class="product__inventory-inner product__inventory-inner--empty">
                                            {{- 'products.product.quantity.out_of_stock' | t -}}
                                          </span>
                                        {%- endif -%}
                                      {%- endif -%}
                                    {%- endif -%}
                                </div>
                              {% endif %}
                            </div>
                            <div class="product-form__controls-group">
                              {% render 'product-variant-options',
                                product: product,
                                option: option,
                                block: block,
                                has_color_swatch: is_color_option,
                                is_dropdown: false,
                                swatch_type: block.settings.swatch_type,
                                swatch_shape: block.settings.color_swatch_shape,
                                unavailable_options_clickable: block.settings.enable_notification_modal
                              %}
                            </div>
                            {%- if has_popup_option -%}
                              {% render 'popup-for-option', block: block %}
                              {% assign use_option_popup_on_page = true %}
                            {%- endif -%}
                          </fieldset>
                          {%- endfor -%}
                          
                          <script type="application/json">
                            {{ product.variants | json }}
                          </script>
                        </variant-radios>
                      
                        {%- render 'avaliability-notification',
                          section: section,
                          block: block,
                          product: product
                        -%}
                        {% assign subscription_form_id = 'ContactFormSubscribe-' %}
                          {%- form 'contact', id: subscription_form_id, class: 'contact-form__form subscription-form' -%}
                          <div class="product-popup-modal__result" data-subscribed-product="{{ product.handle }}">
                            {%- if form.posted_successfully? -%}
                              <div
                                class="form-status form-status-list form__message product-popup-modal__form-message body-normal"
                                tabindex="-1"
                              >
                                {% render 'icon-success' %}
                                {{ 'products.product.availiability_notification.post_success' | t }}
                              </div>
                            {%- elsif form.errors -%}
                              <div
                                class="form-status form-status-list form__message product-popup-modal__form-message body-normal"
                                tabindex="-1"
                              >
                                {% render 'icon-error' %}
                                {{ form.errors.messages.form }}
                              </div>
                            {%- endif -%}
                          </div>
                        {%- endform -%}
                      {% else %}
                        <variant-selects
                          id="variant-selects-{{ section.id }}"
                          class="no-js-hidden"
                          data-section="{{ section.id }}"
                          data-url="{{ product.url }}"
                          {{ block.shopify_attributes }}
                        >
                          {%- for option in product.options_with_values -%}
                            {% liquid
                              assign is_color_option = false
                              assign option_position = option.position | times: 1.00 

                              # for metafields color
                              for value in option.values
                                if settings.enable_color_swatch and value.swatch.color != blank
                                  assign is_color_option = true
                                endif
                              endfor
  
                              # for custom option color
                              assign color_trigger = settings.trigger_swatch | strip | newline_to_br | split: '<br />'
                              assign name_option = option.name | handle | strip
                              for item in color_trigger
                                assign item_temp = item | handle | strip
                                if settings.enable_color_swatch and name_option == item_temp
                                  assign is_color_option = true
                                endif
                              endfor
  
                              # get color_value for selected color option
                              if is_color_option
                                assign color_value = blank
                                for value in option.values
                                  if settings.enable_color_swatch and option.selected_value == value
                                    if value.swatch.image != blank
                                      assign color_image = value.swatch.image | image_url: width: 60
                                      assign color_value = 'url(' | append: color_image | append: ') no-repeat center/cover'
                                    elsif value.swatch.color != blank
                                      assign color_value = 'rgb(' | append: value.swatch.color.rgb | append: ')'
                                    else
                                      assign init_color_value = value.name | handle | strip
                                      assign color_value = init_color_value | remove: '-'
  
                                      if settings.custom_colors != blank
                                        assign custom_colors_string = settings.custom_colors | strip
                                        assign custom_colors_obj = custom_colors_string | newline_to_br | split: '<br />'
  
                                        for obj in custom_colors_obj
                                          assign obj_strip = obj | strip
                                          assign obj_key = obj_strip | split: ':' | first
                                          assign obj_value = obj_strip | split: ':' | last
                                          assign obj_color_name = obj_key | handle | strip
  
                                          if init_color_value == obj_color_name
                                            assign obj_color_value = obj_value | strip
                                            if obj_color_value contains 'gradient'
                                              assign color_value = obj_color_value
                                            else
                                              assign color_value = obj_color_value | remove: '-'
                                            endif
                                            break
                                          endif
                                        endfor
                                      endif
                                    endif
                                  endif
                                endfor
                              endif
  
                              assign has_color_swatch = false
                              if is_color_option and color_value != blank
                                assign has_color_swatch = true
                              endif

                              # check for size guide popup
                              assign has_popup_option = false
                              assign size_guide_option_name = block.settings.size_guide_option_name | handle | strip
                              if block.settings.enable_size_guide and name_option == size_guide_option_name and use_option_popup_on_page == false and block.settings.button_label != blank
                                assign has_popup_option = true
                              endif
                            %}
                            <fieldset
                              class="product-form__controls product-form__controls--dropdown"
                              id="SingleOptionSelector-{{ forloop.index0 }}"
                            >
                              <div class="product-form__group-wrapper">
                                <legend class="product-form__group-name">
                                  {{- option.name | append: ':' | escape -}}
                                </legend>
                                {% if block.settings.display_inventory and option_position == product.options_with_values.size %}
                                  <div
                                  id="Inventory-{{ section.id }}"
                                  class="product__inventory{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} visibility-hidden{% endif %}"
                                  role="status">
                                    {% liquid
                                      assign limited_stock = block.settings.limited_stock
                                    %}
                                    {%- if product.selected_or_first_available_variant.inventory_management == 'shopify'   -%}
                                      {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                                        <span class="product__inventory-inner product__inventory-inner--{% if product.selected_or_first_available_variant.inventory_quantity <= limited_stock %}error{% endif %}">
                                          {%- if product.selected_or_first_available_variant.inventory_quantity <= limited_stock-%}
                                            {{- 'products.product.quantity.in_stock' | t: quantity: product.selected_or_first_available_variant.inventory_quantity | strip -}}
                                          {%- elsif product.selected_or_first_available_variant.inventory_quantity == 1 -%}
                                            {{ 'products.product.quantity.one_in_stock' | t }}
                                          {%- endif -%}
                                        </span>
                                      {%- else -%}
                                        {%- if product.selected_or_first_available_variant.inventory_policy != 'continue' -%}
                                          <span class="product__inventory-inner product__inventory-inner--empty">
                                            {{- 'products.product.quantity.out_of_stock' | t -}}
                                          </span>
                                        {%- endif -%}
                                      {%- endif -%}
                                    {%- endif -%}
                                    </div>
                                {% endif %}
                              </div>
                              <div class="select dropdown-select focus-inset" form="{{ product_form_id }}" tabindex="0">
                                <div
                                  class="select-label secondary_text{% if has_color_swatch %} select-label--with-color{% endif %}"
                                  {% if has_color_swatch %}
                                    style="--swatch-color: {{ color_value }}; --border-radius: {{ settings.swatch_border_radius }}px;"
                                  {% endif %}
                                >
                                  <span>{{- option.selected_value -}}</span>
                                  <input id="HiddenInput-{{ section.id }}-{{ option.name }}-{{ forloop.index0 }}" type="hidden" name="{{ option.name }}" value="{{ option.selected_value }}" {% if is_color_option %}
                                    data-color-swatch="{{ color_value }}"
                                  {% endif %}/>
                                </div>
                                <div class="select-wrapper" tabindex="0" aria-expanded="false">
                                  <ul class="product-form__controls-group">
                                    {% render 'product-variant-options',
                                      product: product,
                                      option: option,
                                      block: block,
                                      has_color_swatch: has_color_swatch,
                                      is_dropdown: true,
                                      swatch_type: 'color',
                                    %}
                                  </ul>
                                </div>
  
                                {% render 'icon-caret' %}
                              </div>
                              {%- if has_popup_option -%}
                                {% render 'popup-for-option', block: block %}
                                {% assign use_option_popup_on_page = true %}
                              {%- endif -%}
                            </fieldset>
                          {% endfor %}
                          <script type="application/json">
                            {{ product.variants | json }}
                          </script>
                        </variant-selects>
                      {% endif %}
                    {% endunless %}

                    <noscript class="product-form__noscript-wrapper-{{ section.id }}">
                      <fieldset class="product-form__controls {% if product.has_only_default_variant %} hidden{% endif %}">
                        <label for="Variants-{{ section.id }}" class="product-form__group-name">
                          {{- 'products.product.product_variants' | t -}}
                          :</label
                        >
                        <div class="product-form__controls-group">
                          <div class="select">
                            <select
                              name="id"
                              id="Variants-{{ section.id }}"
                              class="select__select"
                              form="{{ product_form_id }}"
                            >
                              {%- for variant in product.variants -%}
                                <option
                                  {% if variant == product.selected_or_first_available_variant %}
                                    selected="selected"
                                  {% endif %}
                                  {% if variant.available == false %}
                                    disabled
                                  {% endif %}
                                  value="{{ variant.id }}"
                                >
                                  {%- liquid
                                    echo variant.title
                                    if settings.currency_code_enabled
                                      echo variant.price | money_with_currency | strip_html | prepend: ' - '
                                    else
                                      echo variant.price | money | strip_html | prepend: ' - '
                                    endif
                                    if variant.available == false
                                      echo 'products.product.sold_out' | t | prepend: ' - '
                                    endif
                                    if variant.quantity_rule.increment > 1
                                      echo 'products.product.quantity.multiples_of' | t: quantity: variant.quantity_rule.increment | prepend: ' - '
                                    endif
                                    if variant.quantity_rule.min > 1
                                      echo 'products.product.quantity.minimum_of' | t: quantity: variant.quantity_rule.min | prepend: ' - '
                                    endif
                                    if variant.quantity_rule.max != null
                                      echo 'products.product.quantity.maximum_of' | t: quantity: variant.quantity_rule.max | prepend: ' - '
                                    endif
                                    assign cart_quantity = cart | item_count_for_variant: variant.id
                                    if cart_quantity > 0
                                      echo 'products.product.quantity.in_cart_html' | t: quantity: cart_quantity | prepend: ' - '
                                    endif
                                  -%}
                                </option>
                              {%- endfor -%}
                            </select>
                            {% render 'icon-caret' %}
                          </div>
                        </div>
                      </fieldset>
                    </noscript>
                  </div>

                {% elsif product.has_only_default_variant == true and product.selected_or_first_available_variant.available == false %}
                  {%- if block.settings.enable_notification_modal -%}
                     <modal-opener
                      class="no-js-hidden sold-out-modal-opener only-default-variant"
                      data-modal="#AvaliabilityNotificationModal-{{ section.id }}"
                      data-value="{{ product.title | escape }}"
                    >
                      <button
                        id="AvaliabilityNotificationModal-{{ section.id }}"
                        class="product-popup__button button-sold-out focus-inset"
                        type="button"
                        aria-haspopup="dialog"
                        data-unavailable-variant-img="{{ product.featured_image }}"
                      >{{ 'products.product.quantity.out_of_stock' | t }}
                        <span class="notification-bell">
                          {% render 'icon-bell' %}
                        </span>
                      </button>
                    </modal-opener> 
                    {%- render 'avaliability-notification',
                      section: section,
                      block: block,
                      product: product
                    -%}

                    {% assign subscription_form_id = 'ContactFormSubscribe-' %}
                      {%- form 'contact', id: subscription_form_id, class: 'contact-form__form subscription-form' -%}
                      <div class="product-popup-modal__result" data-subscribed-product="{{ product.handle }}">
                        {%- if form.posted_successfully? -%}
                          <div
                            class="form-status form-status-list form__message product-popup-modal__form-message body-normal"
                            tabindex="-1"
                          >
                            {% render 'icon-success' %}
                            {{ 'products.product.availiability_notification.post_success' | t }}
                          </div>
                        {%- elsif form.errors -%}
                          <div
                            class="form-status form-status-list form__message product-popup-modal__form-message body-normal"
                            tabindex="-1"
                          >
                            {% render 'icon-error' %}
                            {{ form.errors.messages.form }}
                          </div>
                        {%- endif -%}
                      </div>
                    {%- endform -%}
                  {%- endif -%}
                {% endif %}
              {%- when 'buy_buttons' -%}
                <div class="product__buy-buttons" {{ block.shopify_attributes }}>
                  {%- liquid
                    assign gift_card_recipient_feature_active = false
                    if block.settings.show_gift_card_recipient and product.gift_card?
                      assign gift_card_recipient_feature_active = true
                    endif

                    assign show_dynamic_checkout = false
                    if block.settings.show_dynamic_checkout and gift_card_recipient_feature_active == false
                      assign show_dynamic_checkout = true
                    endif
                  -%}

                  <product-form class="product-form" data-hide-errors="{{ gift_card_recipient_feature_active }}">
                    <div class="product-form__error-message-wrapper" role="alert" hidden>
                      {% render 'icon-error' %}
                      <span class="product-form__error-message"></span>
                    </div>
                    {%- form 'product',
                      product,
                      id: product_form_id,
                      class: 'form',
                      novalidate: 'novalidate',
                      data-type: 'add-to-cart-form'
                    -%}
                      <input
                        type="hidden"
                        name="id"
                        value="{{ product.selected_or_first_available_variant.id }}"
                        {% if product.selected_or_first_available_variant.available == false %}
                          disabled
                        {% endif %}
                      >

                      {%- if gift_card_recipient_feature_active -%}
                        {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
                      {%- endif -%}

                      <div class="product-form__buttons">
                        <div class="product-form__buttons-row">
                          {% if block.settings.show_quantity %}
                            <div
                              class="product-form__input product-form__quantity no-js-hidden"
                              {{ block.shopify_attributes }}
                            >
                              {%- assign cart_qty = cart
                                | item_count_for_variant: product.selected_or_first_available_variant.id
                              -%}
                              <quantity-input class="quantity">
                                <button class="quantity__button no-js-hidden focus-inset" name="minus" type="button">
                                  <span class="visually-hidden">
                                    {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
                                  </span>
                                  {% render 'icon-minus' %}
                                </button>
                                <input
                                  class="quantity__input focus-inset"
                                  type="number"
                                  name="quantity"
                                  id="Quantity-{{ section.id }}"
                                  data-cart-quantity="{{ cart_qty }}"
                                  data-min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                                  min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                                  {% if product.selected_or_first_available_variant.quantity_rule.max != null %}
                                    data-max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                                    max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                                  {% endif %}
                                  step="{{ product.selected_or_first_available_variant.quantity_rule.increment }}"
                                  value="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                                  form="{{ product_form_id }}"
                                >
                                <label class="visually-hidden" for="Quantity-{{ section.id }}">
                                  {{ 'products.product.quantity.label' | t }}
                                </label>
                                <button class="quantity__button no-js-hidden focus-inset" name="plus" type="button">
                                  <span class="visually-hidden">
                                    {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
                                  </span>
                                  {% render 'icon-plus' %}
                                </button>
                              </quantity-input>
                              <div class="quantity__rules caption">
                                {%- if product.selected_or_first_available_variant.quantity_rule.increment > 1 -%}
                                  <span class="divider">
                                    {{-
                                      'products.product.quantity.multiples_of'
                                      | t: quantity: product.selected_or_first_available_variant.quantity_rule.increment
                                    -}}
                                  </span>
                                {%- endif -%}
                                {%- if product.selected_or_first_available_variant.quantity_rule.min > 1 -%}
                                  <span class="divider">
                                    {{-
                                      'products.product.quantity.minimum_of'
                                      | t: quantity: product.selected_or_first_available_variant.quantity_rule.min
                                    -}}
                                  </span>
                                {%- endif -%}
                                {%- if product.selected_or_first_available_variant.quantity_rule.max != null -%}
                                  <span class="divider">
                                    {{-
                                      'products.product.quantity.maximum_of'
                                      | t: quantity: product.selected_or_first_available_variant.quantity_rule.max
                                    -}}
                                  </span>
                                {%- endif -%}
                              </div>
                            </div>
                          {% endif %}

                          <button
                            type="submit"
                            name="add"
                            class="product-form__submit button button--{%- if show_dynamic_checkout -%}transparent{% else %}primary{%- endif -%}"
                            {% if product.selected_or_first_available_variant.available == false %}
                              disabled
                            {% endif %}
                          >
                            {%- if product.selected_or_first_available_variant.available -%}
                              <span class="button__label" data-label="{{ 'products.product.add_to_cart' | t }}">
                                {{ 'products.product.add_to_cart' | t }}
                              </span>
                            {%- else -%}
                              <span class="button__label">
                                {{ 'products.product.sold_out' | t }}
                              </span>
                            {%- endif -%}
                              <div class="loading-overlay__spinner hidden">
                                {%- render 'icon-loading' -%}
                              </div>
                          </button>
                        </div>
                        {%- if show_dynamic_checkout -%}
                          <div class="product-form__checkout no-js-hidden">
                            {{ form | payment_button }}
                          </div>
                        {%- endif -%}
                      </div>
                    {%- endform -%}
                  </product-form>
                </div>
              {%- when 'promo_code' -%}
         
                {% render 'promo-code', block_settings: block, stripped_bg: true %}
              {%- when 'pickup_availability' -%}
                {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities
                  | where: 'pick_up_enabled', true
                -%}

                {%- if block.settings.show_pickup_availability == true
                  or block.settings.show_delivery_details == true 
                -%}
                  {%- if block.settings.enable_divider == true -%}
                    <span class="product__pickup-divider no-js-hidden"></span>
                  {%- endif -%}
                {%- endif -%}
                <div class="product__pickup-wrapper no-js-hidden"  {{ block.shopify_attributes }}>
                  {%- if product.selected_or_first_available_variant.available and block.settings.show_pickup_availability == true and pick_up_availabilities.size > 0 -%}
                    <div class="pickup-availability">
                      {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

                      <pickup-availability
                        class="product__pickup-availabilities no-js-hidden"
                        {% if product.selected_or_first_available_variant.available
                          and pick_up_availabilities.size > 0
                        %}
                          available
                        {% endif %}
                        data-base-url="{{ shop.url }}{{ routes.root_url }}"
                        data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                        data-has-only-default-variant="{{ product.has_only_default_variant }}"
                      >
                        <template>
                          <pickup-availability-preview class="pickup-availability-preview">
                            {% render 'icon-unavailable' %}
                            <div class="pickup-availability-info">
                              <p class="caption-large h6">
                                {{ 'products.product.pickup_availability.unavailable' | t }}
                              </p>
                              <button class="pickup-availability-button button button--link--tertiary link--underline_arrow">
                                <span class="button__label">{{ 'products.product.pickup_availability.refresh' | t }}</span>
                              </button>
                            </div>
                          </pickup-availability-preview>
                        </template>
                      </pickup-availability>
                      <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>
                    </div>
                  {% endif %}

                  {%- if block.settings.show_delivery_details == true -%}
                    <div class="delivery-details ">
                      <span class="icon-wrap">{% render 'icon-box' %}</span>
                      <div class="delivery-details__content">
                        {%- if block.settings.delivery_details_text != blank -%}
                          <p class="delivery-details__title title h6">{{ block.settings.delivery_details_text }}</p>
                        {%- endif -%}

                        {% liquid
                          if block.settings.button_label != blank
                            assign btn_label = block.settings.button_label
                          endif
                        %}
                      <div class="product-popup delivery-details-popup">
                        <modal-opener
                          class="no-js-hidden"
                          data-modal="#PopupModal-{{ block.id }}"
                          {{ block.shopify_attributes }}
                        >
                          <button
                            id="ProductPopup-{{ block.id }}"
                            class="product-popup__button button button--link--tertiary link--underline_arrow focus-inset"
                            type="button"
                            aria-haspopup="dialog"
                          >
                            <span class="button__label">
                              {{- btn_label -}}
                            </span>
                          </button>
                        </modal-opener>
                        <modal-dialog
                          id="PopupModal-{{ block.id }}"
                          class="product-popup-modal"
                          {{ block.shopify_attributes }}
                        >
                          <div
                            role="dialog"
                            aria-label="{{ block.settings.label }}"
                            aria-modal="true"
                            class="product-popup-modal__content"
                            tabindex="-1"
                          >
                            <button
                              id="ModalClose-{{ block.id }}"
                              type="button"
                              class="product-popup-modal__close modal-close-button focus-inset"
                              aria-label="{{ 'accessibility.close' | t }}"
                            >
                              {% render 'icon-close' %}
                            </button>
                            <div class="product-popup-modal__content-info">
                              {%- if block.settings.button_page.content != blank -%}
                                <div class="product-popup-modal__page-wrapper rte">{{ block.settings.button_page.content }}</div>
                              {%- else -%}
                                <p class="product-popup-modal__no-content body-normal">{{ 'accessibility.no_content' | t }}</p>
                              {%- endif -%}
                            </div>
                          </div>
                        </modal-dialog>
                      </div>
                      </div>
                    </div>
                  {%- endif -%}
                </div>
              {%- when 'custom_liquid' -%}
                <div class="custom-liquid" {{ block.shopify_attributes }}>
                  {{ block.settings.custom_liquid }}
                </div>
              {%- when 'share' -%}
                {%- if block.settings.show_share_facebook
                  or block.settings.show_share_twitter
                  or block.settings.show_share_pinterest
                  or block.settings.show_share_copy
                -%}
                  <div class="share-buttons" aria-label="list" {{ block.shopify_attributes }}>
                    <div class="share-buttons__opener dropdown-opener">
                      <button class="button link--underline_arrow button--link--primary">
                        <span>{{ block.settings.share_label }}</span>
                      </button>
                      {%- render 'icon-share' %}
                    </div>

                    <ul class="share-buttons__list list-unstyled">
                      {%- if block.settings.show_share_facebook -%}
                        <li class="share-buttons__item">
                          <a
                            href="https://www.facebook.com/sharer.php?u={{ shop.url | append: product.url }}"
                            class="share-buttons__button button facebook-btn focus-inset"
                            target="_blank"
                          >
                            <span class="icon-wrap">{% render 'icon-facebook' %}</span>
                            <span>{{ 'general.social.links.facebook' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}

                      {%- if block.settings.show_share_twitter -%}
                        <li class="share-buttons__item">
                          <a
                            href="https://twitter.com/share?url={{ shop.url | append: product.url }}&text={{ product.title | escape }}"
                            class="share-buttons__button button twitter-btn focus-inset"
                            target="_blank"
                          >
                            <span class="icon-wrap">{% render 'icon-twitter' %}</span>
                            <span>{{ 'general.social.links.twitter' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}

                      {%- if block.settings.show_share_pinterest -%}
                        <li class="share-buttons__item">
                          <a
                            href="https://pinterest.com/pin/create/bookmarklet/?media={{ product.featured_media | image_url: width: 1100, height: 1100 }}&url={{ shop.url | append: product.url }}&description={{ product.title | escape }}"
                            class="share-buttons__button button pinterest-btn"
                            target="_blank"
                          >
                          <span class="icon-wrap">{% render 'icon-pinterest' %}</span>
                            <span>{{ 'general.social.links.pinterest' | t }}</span>
                          </a>
                        </li>
                      {%- endif -%}

                      {%- if block.settings.show_share_copy -%}
                        <li class="share-buttons__item copy">
                          <button
                            data-copy-href="{{ shop.url | append: product.url }}"
                            class="share-buttons__button button copy-btn focus-inset"
                          >
                            <span class="icon-copy icon-wrap">
                              {% render 'icon-copy' %}
                            </span>

                            <span class="copy-success">
                              {% render 'icon-check' %}
                            </span>
                            <span class="copy-error">
                              {% render 'icon-error' %}
                            </span>

                            <span class="copy-text">{{ 'general.social.alt_text.copy_link' | t }}</span>
                          </button>
                        </li>
                      {%- endif -%}
                    </ul>
                  </div>
                {%- endif -%}
              {%- when 'popup' -%}
                {% liquid
                  if block.settings.button_label != blank
                    assign btn_label = block.settings.button_label

                    if block.settings.button_style != blank
                      assign btn_style = block.settings.button_style
                    else
                      assign btn_style = 'primary'
                    endif
                  endif

                  assign underline_arrow_class = false

                  if btn_style == 'link--primary' or btn_style == 'link--secondary' or btn_style == 'link--tertiary'
                    assign underline_arrow_class = true
                  endif
                %}
                <div class="product-popup">
                  <modal-opener
                    class="no-js-hidden"
                    data-modal="#PopupModal-{{ block.id }}"
                    {{ block.shopify_attributes }}
                  >
                    <button
                      id="ProductPopup-{{ block.id }}"
                      class="product-popup__button button button--{{ btn_style }}{% if underline_arrow_class %} link--underline_arrow{% endif %} focus-inset"
                      type="button"
                      aria-haspopup="dialog"
                    >
                      <span class="button__label">
                        {{- btn_label -}}
                      </span>
                    </button>
                  </modal-opener>
                  <div class="product-popup-modal__content-info no-js">
                    {% if block.settings.heading != blank %}
                      <h3 class="product-popup-modal__title">
                        {{ block.settings.heading }}
                      </h3>
                    {% endif %}
                    {% if block.settings.text != blank %}
                      <div class="product-popup-modal__text">
                        {{ block.settings.text }}
                      </div>
                    {% endif %}
                  </div>
                  <modal-dialog
                    id="PopupModal-{{ block.id }}"
                    class="product-popup-modal"
                    {{ block.shopify_attributes }}
                  >
                    <div
                      role="dialog"
                      aria-label="{{ block.settings.label }}"
                      aria-modal="true"
                      class="product-popup-modal__content"
                      tabindex="-1"
                    >
                      <button
                        id="ModalClose-{{ block.id }}"
                        type="button"
                        class="product-popup-modal__close modal-close-button focus-inset"
                        aria-label="{{ 'accessibility.close' | t }}"
                      >
                        {% render 'icon-close' %}
                      </button>
                      <div class="product-popup-modal__content-info">
                        {% if block.settings.heading != blank %}
                          <h3 class="product-popup-modal__title h3 align--{{ block.settings.alignment}}">
                            {{ block.settings.heading }}
                          </h3>
                        {% endif %}

                        {% if block.settings.text != blank %}
                          <div class="product-popup-modal__text align--{{ block.settings.alignment}}">
                            {{ block.settings.text }}
                          </div>
                        {% endif %}

                        {% if block.settings.image != blank %}
                          <div class="product-popup-modal__image-wrapper">
                            {%- liquid
                              assign sizes = '(min-width: 1360px) calc(61.8rem - 4rem * 2), (min-width: 750px) calc(80vw - 4rem * 2), (min-width: 576px) calc(90vw - 2.4rem * 2), calc(95vw - 2rem * 2)'
                              assign widths = '246, 493, 600, 713, 800, 900, 1000'
                            -%}
                            {{
                              block.settings.image
                              | image_url: width: 1000
                              | image_tag:
                                loading: 'lazy',
                                widths: widths,
                                sizes: sizes,
                                class: 'product-popup-modal__image'
                            }}
                          </div>
                        {% endif %}
                        {%- if block.settings.page.content != blank -%}
                          <div class="product-popup-modal__page-wrapper rte">{{ block.settings.page.content }}</div>
                        {%- endif -%}
                      </div>
                    </div>
                  </modal-dialog>
                </div>
              {%- when 'description' -%}
                {% liquid
                    assign has_excerpt = false
                    if block.settings.show_excerpt and product.metafields.custom.excerpt.value != blank
                      assign has_excerpt = true
                    endif
                %} 

                {% liquid 
                  if block.settings.display_rating_info and product.metafields.reviews.rating.value != blank
                    assign product_rating = product.metafields.reviews.rating.value 
                    assign product_rating_sides = product_rating | split: '.'
                    assign integer_part = product_rating_sides[0] 
                    assign decimal_part = product_rating_sides[1] | slice: 0, 2 
                  endif
                %}

                <div class="product__description product__description-wrapper" {{ block.shopify_attributes }} 
                     data-layout="{{ block.settings.layout }}"
                >
                  {%- if block.settings.layout == 'tabs' -%}
                    {% comment %} TODO: upgrade condition {% endcomment %}
                    {%- if block.settings.main_title != blank or block.settings.additional_title != blank or block.settings.reviews_title != blank -%}
                      <div class="description-tags-wrapper">
                        <div class="scroll-shadow scroll-shadow--left"></div>
                        <div class="description-tags list-unstyled">
                          {%- if block.settings.main_title != blank and product.description != blank or block.settings.description != blank or has_excerpt -%}
                            <div class="description-tags__tag focus-inset{% if block.settings.default_opened_tab == 'main' %} active{% endif %}" data-tag="{{ block.settings.main_title }}" tabindex="0">
                              <div class="description-tags__tag-wrap h4">{{ block.settings.main_title }}</div>
                            </div>
                          {%- endif -%}
                          {%- if block.settings.additional_title != blank -%}
                            <div class="description-tags__tag focus-inset{% if block.settings.default_opened_tab == 'additional' %} active{% endif %}" data-tag="{{ block.settings.additional_title }}" tabindex="0">
                              <div class="description-tags__tag-wrap h4">{{ block.settings.additional_title }}</div>
                            </div>
                          {%- endif -%}
                          {%- if block.settings.reviews_title != blank -%}
                            <div class="description-tags__tag focus-inset description-tags__tag--reviews{% if block.settings.default_opened_tab == 'reviews' %} active{% endif %}" data-tag="review" tabindex="0">
                              <div class="description-tags__tag-wrap h4">{{ block.settings.reviews_title }}
                                {%- if block.settings.display_rating_info and product.metafields.reviews.rating != blank -%} 
                                  <div class="rating-wrapper">
                                    <p class="rating-text caption body-normal">
                                      <span aria-hidden="true">
                                        {{ integer_part }}.{{ decimal_part }}
                                          {% comment %} / {{- product.metafields.reviews.rating.value.scale_max -}}  {% endcomment %}
                                      </span>
                                    </p>
                                      <p class="rating-count caption body-normal">
                                        <span aria-hidden="true ">{{ "accessibility.total_reviews" | t: rating_count: product.metafields.reviews.rating_count | strip }}</span>
                                        <span class="visually-hidden">
                                          {{ "accessibility.total_reviews" | t: rating_count: product.metafields.reviews.rating_count | strip }}
                                        </span>
                                      </p>
                                  </div>
                                {%- endif -%}
                              </div>
                            </div>
                            
                          {%- endif -%}
                        </div>
                        <div class="scroll-shadow scroll-shadow--right"></div>
                      </div>
                    {%- endif -%}
                  {%- endif -%}

                  {%- if product.description != blank or block.settings.description != blank or has_excerpt -%}
                    <div class="product__description-block {% if block.settings.layout == 'tabs' and block.settings.default_opened_tab == 'main' %} active{% endif %}" data-info="{{ block.settings.main_title }}">
                      {% if block.settings.layout == 'dropdown' %}
                        <div class="product__description-heading{% if block.settings.layout == 'dropdown' %}  dropdown-heading {% if block.settings.default_opened_tab == 'main' %} active{% endif %}{% endif %}" data-tag="{{ block.settings.main_title }}">
                          {%- if block.settings.main_title != blank -%}
                            <h4 class="description-title h4">{{ block.settings.main_title }}</h4>
                          {%- endif -%}
                          <div class="dropdown-button focus-inset" aria-label="toggle" tabindex="0">
                            {% render 'icon-plus-dropdown' %}
                            {% render 'icon-minus-dropdown' %}
                          </div>
                        </div>
                      {% endif %} 
                      <div class="product__description-block-info {% if block.settings.layout == 'dropdown' %}  dropdown-under{% endif %}">
                        <div class="product__description-block-container">
                        {% comment %} EXCERPT FROM METAFIELD {% endcomment %}
                          {%- if has_excerpt -%}
                            <div class="product__description-excerpt body-large">
                              {{- product.metafields.custom.excerpt.value -}}
                            </div>
                          {%- endif -%}

                          {%- if product.description != blank or block.settings.description != blank -%}
                            <div class="product__description body-large rte">
                              {%- if block.settings.description != blank -%}
                                {{- block.settings.description | escape -}}
                              {%- else -%}
                                {{- product.description -}}
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                          {%- if block.settings.display_sku and product.selected_or_first_available_variant.sku != blank -%}
                            <p
                              class="product__sku no-js-hidden {% if product.selected_or_first_available_variant.sku.size == 0 %} visibility-hidden{% endif %}"
                              id="Sku-{{ section.id }}"
                              role="status"
                            >
                              <span class="product__sku-title">{{ 'products.product.sku' | t }}: </span>
                              {{ product.selected_or_first_available_variant.sku -}}
                            </p>
                          {%- endif -%}
                          {%- if block.settings.display_tags and product.tags != blank -%}
                            <ul class="product-tags product__tags list-unstyled">
                              {% for tag in product.tags %}
                                <li class="product-tags__tag ">
                                  <a class="button button--{{ block.settings.tags_style }}" href="{{ routes.all_products_collection_url }}/{{ tag | handleize }}"> 
                                  <span class="tag__label button__label">{{ tag }}</span>
                                  </a>
                                </li>
                              {% endfor %}
                            </ul>
                          {%- endif -%}
                          {% if block.settings.display_custom_badges and product.metafields.custom.badges != blank %}
                            <div class="product__custom-badges" {{ block.shopify_attributes }}>
                              {% if product.metafields.custom.badges.list? %}
                                {% for badge in product.metafields.custom.badges.value %}
                                  <span
                                    class="badge badge--custom color-{{ section.settings.color_scheme }}"
                                    aria-hidden="true"
                                  >
                                    {{ badge }}
                                  </span>
                                {% endfor %}
                              {% else %}
                                <span class="badge badge--custom color-{{ settings.color_scheme }}" aria-hidden="true">
                                  {{ product.metafields.custom.badges }}
                                </span>
                              {% endif %}
                            </div>
                          {% endif %}
                        </div>
                      </div> 
                    </div>
                  {%- endif -%}
                  {% if block.settings.additional_info != blank and block.settings.additional_title != blank %}
                    <div class="product__description-block {% if block.settings.layout == 'tabs' and block.settings.default_opened_tab == 'additional' %} active{% endif %}" data-info="{{ block.settings.additional_title }}">
                      {% if block.settings.layout == 'dropdown' %}
                        <div class="product__description-heading{% if block.settings.layout == 'dropdown' %}  dropdown-heading{% if block.settings.default_opened_tab == 'additional' %} active{% endif %}{% if block.settings.additional_opened_by_default %} active{% endif %}{% endif %}" data-tag="{{ block.settings.additional_title }}">
                          {%- if block.settings.additional_title != blank -%}
                            <h4 class="description-title h4">{{ block.settings.additional_title }}</h4>
                          {%- endif -%}
                          
                          <div class="dropdown-button focus-inset" aria-label="toggle" tabindex="0">
                            {% render 'icon-plus-dropdown' %}
                            {% render 'icon-minus-dropdown' %}
                          </div>

                        </div>
                      {% endif %} 
                      <div class="product__description-block-info additional-info body-large rte{% if block.settings.layout == 'dropdown' %}  dropdown-under{% endif %}"> 
                        {{ block.settings.additional_info }}
                      </div>
                    </div>
                  {% endif %}
                
                  <div class="product__description-block" data-info="review">
                    {% if block.settings.layout == 'dropdown' %}
                      <div class="product__description-heading{% if block.settings.layout == 'dropdown' %}  dropdown-heading{% if block.settings.default_opened_tab == 'reviews' %} active{% endif %}{% endif %}" data-tag="review">
                        {%- if block.settings.reviews_title != blank -%}
                          <h4 class="description-title h4">{{ block.settings.reviews_title }}</h4>
                        {%- endif -%}
                        <div class="product__description-heading-right dropdown-heading-right">
                          {%- if block.settings.display_rating_info and product.metafields.reviews.rating != blank -%} 
                              <div class="rating-wrapper">
                                <p class="rating-text caption body-normal">
                                  <span aria-hidden="true">
                                    {{ integer_part }}.{{ decimal_part }}
                                      {% comment %} / {{- product.metafields.reviews.rating.value.scale_max -}}  {% endcomment %}
                                  </span>
                                </p>
                                  <p class="rating-count caption body-normal">
                                    <span aria-hidden="true ">{{ "accessibility.total_reviews" | t: rating_count: product.metafields.reviews.rating_count | strip }}</span>
                                    <span class="visually-hidden">
                                      {{ "accessibility.total_reviews" | t: rating_count: product.metafields.reviews.rating_count | strip }}
                                    </span>
                                  </p>
                              </div>
                            {%- endif -%}

                            <div class="dropdown-button focus-inset" aria-label="toggle" tabindex="0">
                              {% render 'icon-plus-dropdown' %}
                              {% render 'icon-minus-dropdown' %}
                            </div>
                        </div>

                      </div>
                    {% endif %}
                  </div>
                </div>
              {%- when 'divider' -%}
                {%- assign divider_index = forloop.index -%}
              {%- when 'inventory' %}
                <div
                  id="Inventory-{{ section.id }}"
                  class="product__inventory{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} visibility-hidden{% endif %}"
                  role="status" {{ block.shopify_attributes }}>
                    {% liquid
                      assign limited_stock = block.settings.limited_stock
                    %}
                    {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' and is_color_option == false  -%}
                      {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                        <span class="product__inventory-inner product__inventory-inner--{% if product.selected_or_first_available_variant.inventory_quantity <= limited_stock %}error{% endif %}">
                          {%- if product.selected_or_first_available_variant.inventory_quantity <= limited_stock-%}
                            {{- 'products.product.quantity.in_stock' | t: quantity: product.selected_or_first_available_variant.inventory_quantity | strip -}}
                          {%- endif -%}
                        </span>
                      {%- else -%}
                        {%- if product.selected_or_first_available_variant.inventory_policy != 'continue' -%}
                          <span class="product__inventory-inner product__inventory-inner--empty">
                            {{- 'products.product.quantity.out_of_stock' | t -}}
                          </span>
                        {%- endif -%}
                      {%- endif -%}
                    {%- endif -%}
                </div>
              {%- when 'product_markers' %}
                {%- render 'product-markers-block', block: block -%}
              {%- when 'product_recommendations' -%}
                <div class="product-recommendations__outer recommedations-block" {{ block.shopify_attributes }}>
                  <product-recommendations
                    class="product-recommendations product-recommendations-recommend"
                    data-intent="product-recommendations-recommend"
                    data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ block.settings.products_to_show }}"
                  >
                    {% if recommendations.performed %}
                      {% if recommendations.products_count > 0 %}
                        <div class="product-recommendations__top">
                          <h4 class="product-recommendations__heading h3">{{ block.settings.product_recommendations_text }}</h4>
                          <div class="product__recommendation-slider-nav js-recommendation-nav no-js-hidden" data-nav-id="{{ section.id }}">
                            <button class="swiper-button-prev focus-inset">
                              {% render 'icon-btn-arrow' %}
                            </button>
                            <button class="swiper-button-next focus-inset">
                              {% render 'icon-btn-arrow' %}
                            </button>
                          </div>
                        </div>

                        <div class="product-recommendations__wrapper">
                          <div
                            class="product-recommendations__layout recommendations--layout js-recommendation-swiper"
                            data-template="{{ section.id }}"
                            data-layout="block"
                            data-mobile-column="{{- block.settings.columns_mobile -}}"
                          >
                            <div
                              class="product-recommendations__list content list-unstyled"
                              role="list"
                            >
                              {% for recommendation in recommendations.products %}
                                <div class="product-recommendations__item swiper-slide">
                                  {% render 'product-card',
                                    product_card_product: recommendation,
                                    show_vendor: block.settings.show_vendor,
                                    show_desc: block.settings.show_desc,
                                    show_iventory: block.settings.show_iventory,
                                    mobile_column: block.settings.columns_mobile,
                                    columns: 3,
                                    section_id: section.id,
                                    color_scheme: section.settings.main_color_scheme
                                  %}
                                </div>
                              {% endfor %}
                            </div>
                          </div>
                        </div>
                      {% endif %}
                    {% else %} 
                      <div
                        class="product-recommendations__loading"
                        style="display: none;"
                      >
                        {% render 'icon-loading' %}
                      </div>
                    {% endif %}
                  </product-recommendations>
                </div>
              {%- when 'recently_viewed' -%}
                <div class="recently-viewed-outer recently-viewed-block" {{ block.shopify_attributes }}>
                  <div
                    class="recently-viewed recently-viewed--loading  no-js-hidden{% if search.performed %} recently-viewed--search-perfomed{% endif %}"
                    data-base-url="{{ routes.search_url }}?section_id={{section.id}}&type=product"
                    data-current-product="{{ product.id }}"
                    data-products-limit="{{ block.settings.products_to_show }}">
                      <div class="recently-viewed__top">
                          {%- if block.settings.heading_text != blank -%} 
                            <h4 class="recently-viewed__heading h3">{{ block.settings.heading_text }}</h4> 
                          {%- endif -%}
                          <div
                            class="recently-viewed__navigation slider-navigation-container js-recently-viewed-nav"
                            data-nav-id="{{ section.id }}"
                          >
                            <div class="swiper-button-prev focus-inset">
                              {% render 'icon-btn-arrow' %}
                            </div>
                            <button class="swiper-button-next focus-inset">
                              {% render 'icon-btn-arrow' %}
                            </button>
                          </div>
                      </div>
                      <div class="recently-viewed__wrapper">
                        <div class="loading-overlay">
                          <div class="loading-overlay__spinner">
                            {% render 'icon-loading' %}
                          </div>
                        </div>
                    
                        <div class="recently-viewed__empty body-large">
                          <span class="body-large">{{- 'sections.recently_viewed.empty_message' | t -}}</span>
                        </div>
                    
                        <div
                          class="recently-viewed__layout js-recently-viewed"
                          data-layout="block"
                          data-template="{{ section.id }}"
                          data-mobile-column="{{- block.settings.columns_mobile -}}"
                        >
                          <div
                            class="recently-viewed__list"
                          >
                            {% assign product_list = search.results | where: 'object_type', 'product' %}
                            {% assign product_count = 0 %}
                    
                            {% for product in product_list %}
                              {% assign product_count = product_count | plus: 1 %}
                            {% endfor %}
                    
                            {% liquid
                              assign anim_delay_coeff = 0.1
                    
                              if product_count > 12
                                assign anim_delay_coeff = 0.05
                              endif
                    
                              if product_count > 24
                                assign anim_delay_coeff = 0.025
                              endif
                            %}
                            {%- for product in product_list -%}
                              <div
                                class="recently-viewed__item"
                                style="--pop-prod-item-delay: {{ forloop.index | minus: 1 | times: anim_delay_coeff }}s;"
                              >
                                {% assign columns = 6 %}
                                {% render 'product-card',
                                  product_card_product: product,
                                  show_vendor: block.settings.show_vendor,
                                  show_desc: block.settings.show_desc,
                                  show_iventory: block.settings.show_iventory,
                                  mobile_column: block.settings.columns_mobile,
                                  section_id: section.id,
                                  add_id: forloop.index,
                                  columns: columns
                                %}
                              </div>
                            {%- endfor -%}
                          </div>
                        </div>
                      </div>
                    </div>
                </div>
              {%- when 'similar_products' -%}
                  <div class="similar-products" {{ block.shopify_attributes }}>
                    <div class="similar-products__header">
                      <h4 class="similar-products__heading h3">{{ block.settings.similar_products_text }}</h4>
                      <div class="product__similar-slider-nav slider-navigation-container js-similar-nav no-js-hidden">
                        <div class="swiper-button-prev product__similar-slider-nav-prev focus-inset">
                          {% render 'icon-btn-arrow' %}
                        </div>
                        <div class="swiper-button-next product__similar-slider-nav-next focus-inset">
                          {% render 'icon-btn-arrow' %}
                        </div>
                      </div>
                    </div>

                    <div
                      class="similar-products__content swiper js-similar-swiper"
                      data-mobile-column="{{- block.settings.columns_mobile -}}"
                    >
                      <div class="similar-products__wrapper swiper-wrapper">
                          {% for product in block.settings.product_list %}
                            <div class="swiper-slide similar-products__product">
                              {% render 'product-card',
                                product_card_product: product,
                                show_vendor: block.settings.show_vendor,
                                show_desc: block.settings.show_desc,
                                show_iventory: block.settings.show_iventory,
                                mobile_column: block.settings.columns_mobile,
                                columns: 3,
                                section_id: section.id,
                                color_scheme: section.settings.main_color_scheme
                              %}
                            </div>
                          {% else %}
                            {% for  i in (1..4) %} 
                              {% liquid
                                assign product_number = forloop.index
                              %}
                              <div class="swiper-slide similar-products__product">
                                {% render 'product-card-placeholder',
                                  show_vendor: block.settings.show_vendor,
                                  product_number: product_number,
                                  color_scheme: section.settings.main_color_scheme
                                %}
                              </div>
                            {% endfor %}
                          {% endfor %}
                      </div>
                    </div>
                  </div>
              {%- when 'product_banner' -%}
                {%- render 'product-banner', block: block -%}
              {% when "help_banner" %}
                {%- render 'help-banner', block: block -%}
              {%- when '@app' -%}
                <div {{ block.shopify_attributes }}>
                  {% render block %}
                </div>
              {%- endcase -%}
        {% endcapture %}

        {%- if divider_index == blank or forloop.index < divider_index -%}
          {%- assign content_before_divider = content_before_divider | append: block_content -%}
        {%- else -%}
          {%- assign content_after_divider = content_after_divider | append: block_content -%}
        {%- endif -%}
      {%- endfor -%}

      <div class="product__info-column main-information">
        {%- if content_before_divider != blank -%}
          <div class="product__info-block">
            {{ content_before_divider }}
          </div>
        {%- endif -%}
        {%- if section.settings.mini_widgets_sticky == true -%}
          {%- if section.settings.display_mini_card or section.settings.display_complementary -%}
            <div
              class="mini-widgets sticky"
              data-position="sticky"
            >
              <div class="product__info-block">
                {% if section.settings.display_mini_card %}
                  {% render 'product-mini-card',
                    product_card_product: product,
                    media_ratio: section.settings.aspect_ratio,
                    show_vendor: section.settings.mini_card_show_vendor,
                    section_id: section.id,
                    scheme: section.settings.color_scheme,
                    product_form_id: product_form_id
                  %}
                {% endif %}

                {%- if section.settings.display_complementary -%}
                  <product-recommendations
                    class="complementary-products product-recommendations"
                    data-intent="complementary-products"
                    data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&intent=complementary"
                  >
                    {%- if recommendations.performed and recommendations.products_count > 0 -%}
                      {% liquid
                        assign display_as_slider = false

                        if section.settings.complementary_layout == 'slider'
                          assign display_as_slider = true
                        elsif section.settings.complementary_layout == 'column' and section.settings.products_limit > 3 and recommendations.products_count > 3
                          assign display_as_slider = true
                        else
                          assign display_as_slider = false
                        endif
                      %}
                      <div class="complementary-products__container">
                        <div class="complementary-products__header">
                          <h5 class="complementary-products__heading h4">
                            {{ section.settings.complementary_heading }}
                          </h5>

                          {%- if display_as_slider -%}
                            <div class="product__complimentary-slider-nav no-js-hidden">
                              <div class="swiper-button-prev product__complimentary-slider-nav-prev focus-inset">
                                {% render 'icon-btn-arrow' %}
                              </div>
                              <div class="swiper-button-next product__complimentary-slider-nav-next focus-inset">
                                {% render 'icon-btn-arrow' %}
                              </div>
                            </div>
                          {%- endif -%}
                        </div>

                        <div class="product-recommendations__wrapper {% if recommendations.performed and recommendations.products_count > 1 and display_as_slider %} swiper js-complementary-swiper{% endif %}">
                          {% if recommendations.performed and recommendations.products_count > 0 %}
                            <div
                              class="product-recommendations__list{% if recommendations.performed and recommendations.products_count > 1 and display_as_slider %} swiper-wrapper complementary-swiper-wrapper{% endif %}"
                              role="list"
                            >
                              {% liquid
                                if display_as_slider
                                  assign additional_class = 'swiper-slide'
                                else
                                  assign additional_class = blank
                                endif
                              %}
                              {% for recommendation in recommendations.products
                                limit: section.settings.products_limit
                              %}
                                {% render 'product-card-horizontal',
                                  product_card_product: recommendation,
                                  media_ratio: settings.card_image_ratio,
                                  show_vendor: section.settings.complementary_show_vendor,
                                  show_image: true,
                                  color_scheme: section.settings.color_scheme,
                                  hide_swatches: false,
                                  show_arrow: false,
                                  additional_class: additional_class
                                %}
                              {% endfor %}
                            </div>
                          {% endif %}
                        </div>
                      </div>
                    {%- endif -%}
                  </product-recommendations>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
      <div class="product__info-column additional-information">
        {%- if content_after_divider != blank -%}
          {{ content_after_divider }}
        {%- endif -%}
      </div>

      {%- if section.settings.mini_widgets_sticky == false -%}
