{{ 'section-collapsible-content.css' | asset_url | stylesheet_tag }}

<script src="{{ 'collapsible-content.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-padding' %}
{%- endstyle -%}

<div
  class="
    collapsible-content color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding
    {% if section.settings.enable_border %} section-border {% if section.settings.border_full %} section-border-full {% endif %} {% endif %}
  "
>
  <div class="container">
    {% if section.settings.layout == 'left' %}
      {%- if section.settings.heading != blank -%}
        <{{ section.settings.heading_level }} class="collapsible-content__title {{ section.settings.heading_size }}">
          {{- section.settings.heading | newline_to_br -}}
        </{{ section.settings.heading_level }}>
      {% endif %}
    {% endif %}

    <div class="collapsible-content__wrapper collapsible-content__wrapper--{{ section.settings.layout }}">
      {%- if section.settings.heading != blank
        or section.settings.secondary_heading != blank
        or section.settings.description != blank
        or section.settings.show_button
        and section.settings.button_label != blank
      -%}
        <div class="collapsible-content__top">
          {% if section.settings.layout == 'center' %}
            {%- if section.settings.heading != blank -%}
              <{{ section.settings.heading_level }} class="collapsible-content__title {{ section.settings.heading_size }}">
                {{- section.settings.heading | newline_to_br -}}
              </{{ section.settings.heading_level }}>
            {% endif %}
          {% endif %}

          {%- if section.settings.secondary_heading != blank -%}
            <h3 class="collapsible-content__secondary-title {{ section.settings.secondary_heading_size }}">
              {{- section.settings.secondary_heading | newline_to_br -}}
            </h3>
          {% endif %}
          {%- if section.settings.description != blank -%}
            <div class="collapsible-content__description section-description body-large section-rte">
              {{- section.settings.description -}}
            </div>
          {% endif %}
          {%- if section.settings.show_button -%}
            <div class="collapsible-content__button-wrapper">
              {% render 'button',
                btn_label: section.settings.button_label,
                btn_style: section.settings.button_style,
                btn_link: section.settings.button_link,
                class: 'collapsible-content__button'
              %}
            </div>
          {%- endif -%}
        </div>
      {% endif %}

      <div class="collapsible-content__content content">
        <div class="collapsible-content__items">
          {%- for block in section.blocks -%}
            <div
              class="
                collapsible-content__item {% if block.settings.opened %} active {% endif %}
                color-{{ section.settings.row_color_scheme }}
                {% if forloop.index > 4 and section.settings.buttons_show %} collapsible-content__item--hidden{% endif %}
              "
              {{ block.shopify_attributes }}
            >
              <button class="collapsible-content__toggle button--unstyled focus-inset">
                <div class="collapsible-content__toggle-group">
                  {%- if block.settings.question != blank -%}
                    <p class="collapsible-content__question h5">{{ block.settings.question | escape }}</p>
                  {%- endif -%}
                </div>
                <div class="collapsible-content__icon">
                  {% render 'icon-minus' %}
                  {% render 'icon-plus' %}
                </div>
              </button>

              {%- if block.settings.answer != blank -%}
                <div
                  class="collapsible-content__answer section-rte body-large"
                  {% if block.settings.opened == false %}
                    style="display: none;"
                  {% endif %}
                >
                  {{ block.settings.answer }}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
        {% if section.blocks.size > 4 and section.settings.buttons_show %}
          <div class="collapsible-content__buttons">
            <button class="collapsible-content__show--more button button--{{ section.settings.show_more_button_style }} focus-inset">
              <span class="button__label">{{ 'sections.collapsible_content.show_more' | t }}</span>
            </button>
            <button class="collapsible-content__show--less collapsible-content__show--hidden button button--{{ section.settings.show_less_button_style }} focus-inset">
              <span class="button__label">{{ 'sections.collapsible_content.show_less' | t }}</span>
            </button>
          </div>
        {% endif %}

        {% if section.settings.link_label != blank %}
          <a
            {% if section.settings.link_url %}
              href="{{ section.settings.link_url }}"
            {% else %}
              disabled
            {% endif %}
            class="link--underline_arrow collapsible-content__link"
          >
            <span>
              {{ section.settings.link_label }}
            </span>
            {% render 'icon-btn-arrow' %}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.collapsible-content.name",
  "tag": "section",
  "class": "collapsible-content-section spaced-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "blocks": [
    {
      "type": "accordion",
      "name": "t:sections.collapsible-content.blocks.accordion.name",
      "limit": 20,
      "settings": [
        {
          "type": "text",
          "id": "question",
          "default": "t:sections.collapsible-content.blocks.accordion.settings.question.default",
          "label": "t:sections.all.heading.label"
        },
        {
          "type": "richtext",
          "id": "answer",
          "default": "t:sections.collapsible-content.blocks.accordion.settings.answer.default",
          "label": "t:sections.all.text.label"
        },
        {
          "type": "checkbox",
          "id": "opened",
          "label": "t:sections.collapsible-content.blocks.accordion.settings.opened.label",
          "default": false
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.collapsible-content.settings.layout.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.collapsible-content.settings.layout.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.collapsible-content.settings.layout.options__2.label"
        }
      ],
      "default": "left"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.all.heading.label",
      "default": "t:sections.collapsible-content.settings.heading.default"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_level",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_level.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_level.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_level.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_level.label"
    },
    {
      "type": "inline_richtext",
      "id": "secondary_heading",
      "default": "t:sections.collapsible-content.settings.secondary_heading.default",
      "label": "t:sections.collapsible-content.settings.secondary_heading.label"
    },
    {
      "type": "select",
      "id": "secondary_heading_size",
      "options": [
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.collapsible-content.settings.secondary_heading_size.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "header",
      "content": "t:sections.collapsible-content.settings.header.content"
    },
    {
      "type": "checkbox",
      "id": "buttons_show",
      "default": false,
      "label": "t:sections.collapsible-content.settings.buttons_show.label",
      "info": "t:sections.collapsible-content.settings.buttons_show.info"
    },
    {
      "type": "select",
      "id": "show_more_button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "tertiary",
      "label": "t:sections.collapsible-content.settings.show_more.label"
    },
    {
      "type": "select",
      "id": "show_less_button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "tertiary",
      "label": "t:sections.collapsible-content.settings.show_less.label"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "default": true,
      "label": "t:sections.all.button.button_show.label"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "t:sections.all.button.button_label.default_view_faq",
      "label": "t:sections.all.button.button_label.label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.all.button.button_link.label"
    },
    {
      "type": "select",
      "id": "button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "tertiary",
      "label": "t:sections.all.button.button_style.label"
    },
    {
      "type": "color_scheme",
      "id": "row_color_scheme",
      "default": "background-1",
      "label": "t:sections.collapsible-content.settings.row_color_scheme.label"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "t:sections.collapsible-content.settings.link_label.label",
      "default": "t:sections.all.button.button_label.default_read_all"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "t:sections.collapsible-content.settings.link_url.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "xl",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.collapsible-content.name",
      "category": "t:sections.categories.storytelling",
      "blocks": [
        {
          "type": "accordion",
          "settings": {
            "opened": true
          }
        },
        {
          "type": "accordion"
        },
        {
          "type": "accordion"
        }
      ]
    }
  ]
}
{% endschema %}
