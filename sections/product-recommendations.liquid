{{ 'section-product-recommendations.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'section-padding' %}
{%- endstyle -%}

<div class="product-recommendations__outer section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} background">
  <product-recommendations
    class="product-recommendations product-recommendations-recommend"
    data-intent="product-recommendations-recommend"
    data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_limit }}"
  >
    {% if recommendations.performed %}
      {% if recommendations.products_count > 0 %}
        {% liquid
          assign has_navigation_mobile = false

          if section.settings.columns_mobile == '1' and recommendations.products_count > 1
            assign has_navigation_mobile = true
          endif

          if section.settings.columns_mobile == '2' and recommendations.products_count > 2
            assign has_navigation_mobile = true
          endif
        %}
        <div class="product-recommendations__top container">
          <div class="product-recommendations__top-main{% if has_navigation_mobile %} product-recommendations__top-main--column-on-mobile{% endif %}">
            {%- if section.settings.heading != blank or section.settings.description != blank -%}
              <div class="product-recommendations__top-text">
                {% render 'heading-group', section: section, class: 'product-recommendations' %}
              </div>
            {%- endif -%}

            {%- if section.settings.show_button -%}
              {% render 'button',
                btn_label: section.settings.button_label,
                btn_style: 'link--primary',
                btn_link: section.settings.button_link,
                class: 'product-recommendations__button'
              %}
            {%- endif -%}
          </div>

          <div
            class="product-recommendations__navigation slider-navigation-container js-recommendation-nav"
            data-nav-id="{{ section.id }}"
          >
            <div class="swiper-button-prev focus-inset">
              {% render 'icon-btn-arrow' %}
            </div>
            <button class="swiper-button-next focus-inset">
              {% render 'icon-btn-arrow' %}
            </button>
          </div>
        </div>

        <div class="product-recommendations__wrapper container content">
          <div
            class="product-recommendations__layout js-recommendation-swiper"
            data-layout="section"
            data-template="{{ section.id }}"
            data-mobile-column="{{- section.settings.columns_mobile -}}"
          >
            <div
              class="product-recommendations__list content list-unstyled"
              role="list"
            >
              {% for recommendation in recommendations.products %}
                <div class="product-recommendations__item swiper-slide">
                  {% assign columns = 6 %}
                  {% render 'product-card',
                    product_card_product: recommendation,
                    show_vendor: section.settings.show_vendor,
                    show_desc: section.settings.show_desc,
                    show_iventory: section.settings.show_iventory,
                    mobile_column: section.settings.columns_mobile,
                    section_id: section.id,
                    add_id: forloop.index,
                    columns: columns
                  %}
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      {% endif %}
    {% else %}
      <div
        class="product-recommendations__loading"
        style="display: none;"
      >
        {% render 'icon-loading' %}
      </div>
    {% endif %}
  </product-recommendations>
</div>

{% schema %}
{
  "name": "t:sections.product-recommendations.name",
  "tag": "section",
  "limit": 1,
  "class": "product-recommendations-section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.product-recommendations.settings.paragraph__1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "textarea",
      "id": "heading",
      "default": "t:sections.product-recommendations.settings.heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "t:sections.product-recommendations.settings.products_limit.label"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.all.card.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_desc",
      "default": false,
      "label": "t:sections.all.card.show_desc.label",
      "info": "t:sections.all.card.show_desc.info"
    },
    {
      "type": "checkbox",
      "id": "show_iventory",
      "default": true,
      "label": "t:sections.all.card.show_iventory.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.mobile_options.header.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.all.mobile_options.columns.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.all.mobile_options.columns.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.all.mobile_options.columns.options__2.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.button.header_button.content"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "default": false,
      "label": "t:sections.all.button.button_show.label"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.all.button.button_label.label",
      "default": "t:sections.all.button.button_label.default_shop_all"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.all.button.button_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "xl",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.product-recommendations.name",
      "category": "t:sections.categories.products"
    }
  ]
}
{% endschema %}
