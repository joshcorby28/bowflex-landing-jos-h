{%- liquid
  assign product_1 = all_products[section.settings.product_1]
  assign product_2 = all_products[section.settings.product_2]
-%}

<div class="bfx-products bfx-products--{{ section.id }}">
  <div class="container">

    {%- if section.settings.heading != blank -%}
      <h2 class="bfx-products__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="bfx-products__grid">

      {%- for i in (1..2) -%}
        {%- liquid
          if i == 1
            assign product    = product_1
            assign fb_title   = section.settings.product_1_title
            assign fb_desc    = section.settings.product_1_desc
            assign fb_image   = section.settings.product_1_image
            assign fb_price   = section.settings.product_1_price
            assign fb_was     = section.settings.product_1_was_price
            assign fb_url     = section.settings.product_1_url
          else
            assign product    = product_2
            assign fb_title   = section.settings.product_2_title
            assign fb_desc    = section.settings.product_2_desc
            assign fb_image   = section.settings.product_2_image
            assign fb_price   = section.settings.product_2_price
            assign fb_was     = section.settings.product_2_was_price
            assign fb_url     = section.settings.product_2_url
          endif
        -%}

        <div class="bfx-products__card{% if forloop.first %} is-open{% endif %}">

          {%- if product != blank -%}

            <div class="bfx-products__card-header">
              {%- if product.featured_image -%}
                <img class="bfx-products__header-thumb" src="{{ product.featured_image | image_url: width: 80 }}" alt="{{ product.title | escape }}" width="52" height="52" loading="lazy">
              {%- endif -%}
              <div class="bfx-products__header-text">
                <p class="bfx-products__vendor">{{ product.vendor }}</p>
                <h3 class="bfx-products__title">{{ product.title }}</h3>
                <span class="bfx-products__header-price">{{ product.price | money }}</span>
              </div>
              <div class="bfx-products__header-meta">
                <span class="bfx-products__counter">{{ forloop.index }} of 2</span>
                <svg class="bfx-products__arrow" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </div>
            </div>

            <div class="bfx-products__body">
              <div class="bfx-products__media">
                {%- if product.images.size > 1 -%}
                  <div class="bfx-products__thumbs">
                    {%- for img in product.images limit: 4 -%}
                      <img src="{{ img | image_url: width: 90 }}" alt="{{ img.alt | escape }}" loading="lazy" width="64" height="64" class="bfx-products__thumb" style="width:64px;height:64px;object-fit:contain;border:1px solid #e5e5e5;border-radius:4px;">
                    {%- endfor -%}
                  </div>
                {%- endif -%}
                <a href="{{ product.url }}" class="bfx-products__main-img">
                  {{- product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title, style: 'width:100%;aspect-ratio:1/1;object-fit:contain;' -}}
                </a>
              </div>

              <div class="bfx-products__actions">
                <div class="bfx-products__price">
                  <span class="bfx-products__price-current">{{ product.price | money }}</span>
                  {%- if product.compare_at_price > product.price -%}
                    <s class="bfx-products__price-was">{{ product.compare_at_price | money }}</s>
                  {%- endif -%}
                </div>
                <p class="bfx-products__tax-note">Taxes included. Shipping calculated at checkout.</p>
                <form action="{{ routes.cart_add_url }}" method="post" class="bfx-products__form">
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <div class="bfx-products__atc-row">
                    <div class="bfx-products__qty">
                      <button type="button" class="bfx-products__qty-btn" data-action="minus" aria-label="Decrease quantity">−</button>
                      <input type="number" name="quantity" value="1" min="1" class="bfx-products__qty-input" aria-label="Quantity">
                      <button type="button" class="bfx-products__qty-btn" data-action="plus" aria-label="Increase quantity">+</button>
                    </div>
                    <button type="submit" class="bfx-products__btn" aria-label="Add {{ product.title }} to cart">Add to Cart</button>
                  </div>
                </form>
              </div>

              {%- if product.description != blank -%}
                <div class="bfx-products__desc-wrap">
                  <div class="bfx-products__desc" id="bfx-desc-{{ section.id }}-{{ i }}">{{ product.description }}</div>
                  <button class="bfx-products__read-more" data-desc="bfx-desc-{{ section.id }}-{{ i }}">Read more</button>
                </div>
              {%- endif -%}

              {%- if product.url != blank -%}
                <a href="{{ product.url }}" class="bfx-products__readmore">View full details</a>
              {%- endif -%}
            </div>

          {%- else -%}

            <div class="bfx-products__card-header">
              {%- if fb_image != blank -%}
                <img class="bfx-products__header-thumb" src="{{ fb_image | image_url: width: 80 }}" alt="{{ fb_title | escape }}" width="52" height="52" loading="lazy">
              {%- endif -%}
              <div class="bfx-products__header-text">
                <p class="bfx-products__vendor">BowFlex</p>
                <h3 class="bfx-products__title">{{ fb_title }}</h3>
                {%- if fb_price != blank -%}<span class="bfx-products__header-price">{{ fb_price }}</span>{%- endif -%}
              </div>
              <div class="bfx-products__header-meta">
                <span class="bfx-products__counter">{{ forloop.index }} of 2</span>
                <svg class="bfx-products__arrow" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </div>
            </div>

            <div class="bfx-products__body">
              <div class="bfx-products__media">
                {%- if fb_image != blank -%}
                  <div class="bfx-products__main-img">
                    {{- fb_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: fb_title, style: 'width:100%;aspect-ratio:1/1;object-fit:contain;' -}}
                  </div>
                {%- else -%}
                  <div class="bfx-products__main-img">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
                {%- endif -%}
              </div>

              {%- if fb_url != blank -%}
                <div class="bfx-products__actions">
                  <div class="bfx-products__price">
                    {%- if fb_price != blank -%}<span class="bfx-products__price-current">{{ fb_price }}</span>{%- endif -%}
                    {%- if fb_was != blank -%}<s class="bfx-products__price-was">{{ fb_was }}</s>{%- endif -%}
                  </div>
                  <p class="bfx-products__tax-note">Taxes included. Shipping calculated at checkout.</p>
                  <div class="bfx-products__atc-row">
                    <div class="bfx-products__qty">
                      <button type="button" class="bfx-products__qty-btn" data-action="minus" aria-label="Decrease quantity">−</button>
                      <input type="number" value="1" min="1" class="bfx-products__qty-input" aria-label="Quantity">
                      <button type="button" class="bfx-products__qty-btn" data-action="plus" aria-label="Increase quantity">+</button>
                    </div>
                    <a href="{{ fb_url }}" class="bfx-products__btn">Add to Cart</a>
                  </div>
                </div>
              {%- endif -%}

              {%- if fb_desc != blank -%}
                <div class="bfx-products__desc-wrap">
                  <div class="bfx-products__desc" id="bfx-desc-{{ section.id }}-{{ i }}">{{ fb_desc }}</div>
                  <button class="bfx-products__read-more" data-desc="bfx-desc-{{ section.id }}-{{ i }}">Read more</button>
                </div>
              {%- endif -%}

              {%- if fb_url != blank -%}
                <a href="{{ fb_url }}" class="bfx-products__readmore">View full details</a>
              {%- endif -%}
            </div>

          {%- endif -%}

        </div>
      {%- endfor -%}

    </div>
  </div>
</div>

<style>
  .bfx-products--{{ section.id }} {
    padding-top: var(--spacing-{{ section.settings.padding_top }}, 40px);
    padding-bottom: var(--spacing-{{ section.settings.padding_bottom }}, 40px);
  }
  .bfx-products__heading {
    font-family: var(--font-body-family);
    text-align: left;
    font-size: calc(var(--font-heading-h1-scale) * 4rem);
    font-weight: 700;
    font-style: normal;
    margin: 0 0 40px;
    line-height: 1.3;
  }
  .bfx-products__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .bfx-products__card {
    border-radius: 8px;
    padding: 24px;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .bfx-products__body {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .bfx-products__actions {
    margin-top: auto;
  }
  .bfx-products__badge {
    position: absolute;
    top: 14px;
    left: 14px;
    background: #BE2530;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .bfx-products__card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .bfx-products__arrow { display: none; }
  .bfx-products__vendor {
    font-size: 13px;
    color: #888;
    margin: 0 0 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .bfx-products__title {
    font-family: var(--font-body-family);
    font-size: 19px;
    font-weight: 700;
    font-style: normal;
    margin: 0 0 16px;
    line-height: 1.3;
  }
  .bfx-products__media {
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
    align-items: flex-start;
    flex-shrink: 0;
  }
  .bfx-products__header-thumb,
  .bfx-products__header-price,
  .bfx-products__header-meta { display: none !important; }
  @media (max-width: 749px) {
    .bfx-products__header-thumb { display: block !important; }
    .bfx-products__header-meta { display: flex !important; }
    .bfx-products__header-price { display: inline-block !important; }
  }

  .bfx-products__main-img { flex: 1; }
  .bfx-products__thumbs {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .bfx-products__thumb { cursor: pointer; transition: border-color 0.15s; }
  .bfx-products__price {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 4px;
    flex-wrap: wrap;
  }
  .bfx-products__price-current {
    font-family: var(--font-body-family);
    font-size: 25px;
    font-weight: 700;
    color: #BE2530;
  }
  .bfx-products__price-was {
    font-family: var(--font-body-family);
    font-size: 20px;
    color: #999;
  }
  .bfx-products__tax-note {
    font-size: 14px;
    color: #666;
    margin: 0 0 14px;
  }
  .bfx-products__desc {
    font-size: 15px;
    color: #444;
    line-height: 1.55;
    margin: 0 0 6px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .bfx-products__desc.is-expanded {
    display: block;
    overflow: visible;
  }
  .bfx-products__read-more {
    background: none;
    border: none;
    padding: 0;
    font-size: 14px;
    font-weight: 600;
    color: #111;
    text-decoration: underline;
    cursor: pointer;
    margin-bottom: 14px;
    display: block;
  }
  .bfx-products__actions { margin-bottom: 10px; }
  .bfx-products__form { margin: 0; }
  .bfx-products__atc-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .bfx-products__qty {
    display: flex;
    align-items: center;
    background: #efefef;
    border-radius: 50px;
    overflow: hidden;
    flex-shrink: 0;
    height: 48px;
    padding: 0 4px;
  }
  .bfx-products__qty-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 20px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #333;
    border-radius: 50%;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .bfx-products__qty-btn:hover { background: #e0e0e0; }
  .bfx-products__qty-input {
    width: 28px;
    background: transparent;
    border: none;
    text-align: center;
    font-size: 15px;
    font-weight: 600;
    color: #111;
    -moz-appearance: textfield;
    padding: 0;
  }
  .bfx-products__qty-input::-webkit-outer-spin-button,
  .bfx-products__qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .bfx-products__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    height: 48px;
    padding: 0 20px;
    background: #fff;
    color: #BE2530;
    border: 2px solid #BE2530;
    border-radius: 50px;
    font-weight: 700;
    font-size: 14px;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    letter-spacing: 0.01em;
  }
  .bfx-products__btn:hover {
    background: #9e1f29;
    border-color: #9e1f29;
    color: #fff;
  }
  .bfx-products__readmore {
    font-size: 13px;
    color: #555;
    text-decoration: underline;
  }
  @media (max-width: 749px) {
    .bfx-products__grid { grid-template-columns: 1fr; gap: 0; }
    .bfx-products__card {
      border-radius: 10px;
      border: 1.5px solid #e5e5e5;
      padding: 14px 16px;
      margin-bottom: 12px;
      background: #fafafa;
      transition: background 0.2s;
      overflow: hidden;
    }
    .bfx-products__card.is-open {
      background: #fff;
      border-color: #ccc;
    }
    .bfx-products__card-header {
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 12px;
      padding-bottom: 0;
    }
    .bfx-products__header-thumb {
      width: 52px;
      height: 52px;
      object-fit: contain;
      border-radius: 6px;
      flex-shrink: 0;
      border: 1px solid #eee;
      background: #fff;
      transition: opacity 0.2s;
    }
    .bfx-products__card.is-open .bfx-products__header-thumb { display: none !important; }
    .bfx-products__header-text { flex: 1; min-width: 0; }
    .bfx-products__header-price {
      font-size: 13px;
      font-weight: 700;
      color: #BE2530;
      margin-top: 2px;
    }
    .bfx-products__card.is-open .bfx-products__header-price { display: none !important; }
    .bfx-products__header-meta {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      flex-shrink: 0;
    }
    .bfx-products__counter {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #999;
      white-space: nowrap;
    }
    .bfx-products__title {
      margin-bottom: 0;
      font-size: 15px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .bfx-products__arrow {
      display: block;
      flex-shrink: 0;
      transition: transform 0.25s ease;
    }
    .bfx-products__card.is-open .bfx-products__arrow {
      transform: rotate(180deg);
    }
    .bfx-products__body {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s ease;
    }
    .bfx-products__card.is-open .bfx-products__body {
      max-height: 2000px;
    }
    .bfx-products__body > *:first-child { margin-top: 16px; }
    .bfx-products__media { flex-direction: column; }
    .bfx-products__main-img {
      width: 100%;
      max-height: 200px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .bfx-products__main-img img,
    .bfx-products__main-img a img {
      max-height: 200px !important;
      width: auto !important;
      aspect-ratio: unset !important;
    }
    .bfx-products__thumbs {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .bfx-products__atc-row { flex-wrap: wrap; }
    .bfx-products__btn { min-width: 0; }
  }
</style>

<script>
  document.querySelectorAll('.bfx-products--{{ section.id }} .bfx-products__thumb').forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      var card = this.closest('.bfx-products__card');
      var mainImg = card.querySelector('.bfx-products__main-img img');
      if (!mainImg) return;
      var thumbs = card.querySelectorAll('.bfx-products__thumb');
      thumbs.forEach(function(t) { t.style.borderColor = '#e5e5e5'; });
      this.style.borderColor = '#111';
      mainImg.src = this.src.replace(/width=\d+/, 'width=600');
      mainImg.srcset = '';
    });
  });

  document.querySelectorAll('.bfx-products--{{ section.id }} .bfx-products__qty-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var input = this.closest('.bfx-products__qty').querySelector('.bfx-products__qty-input');
      var val = parseInt(input.value) || 1;
      if (this.dataset.action === 'plus') input.value = val + 1;
      else if (this.dataset.action === 'minus' && val > 1) input.value = val - 1;
    });
  });

  document.querySelectorAll('.bfx-products--{{ section.id }} .bfx-products__read-more').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var desc = document.getElementById(this.dataset.desc);
      var expanded = desc.classList.toggle('is-expanded');
      this.textContent = expanded ? 'Read less' : 'Read more';
    });
  });

  if (window.innerWidth <= 749) {
    document.querySelectorAll('.bfx-products--{{ section.id }} .bfx-products__card-header').forEach(function(header) {
      header.addEventListener('click', function() {
        header.closest('.bfx-products__card').classList.toggle('is-open');
      });
    });
  }
</script>

{% schema %}
{
  "name": "BFX LP — Product Compare",
  "tag": "section",
  "class": "bfx-lp-products-section spaced-section",
  "enabled_on": { "templates": ["*"] },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Section Heading",
      "default": "Seamless by Design — Performance, Comfort & Connection in Every Step"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Colour",
      "default": "#BE2530"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Colour",
      "default": "#FFFFFF"
    },
    { "type": "header", "content": "Product 1 (T9)" },
    { "type": "product", "id": "product_1", "label": "Product 1" },
    { "type": "text", "id": "product_1_title", "label": "Title (fallback)", "default": "BowFlex T9 JRNY Treadmill" },
    { "type": "textarea", "id": "product_1_desc", "label": "Short Description", "default": "The BFX T9 Treadmill delivers a high-performance workout experience, blending power, connectivity, and comfort." },
    { "type": "image_picker", "id": "product_1_image", "label": "Image (fallback)" },
    { "type": "text", "id": "product_1_price", "label": "Price (fallback)", "default": "£1,699.99" },
    { "type": "text", "id": "product_1_was_price", "label": "Was Price (fallback)", "default": "£2,199.99" },
    { "type": "url", "id": "product_1_url", "label": "URL (fallback)" },
    { "type": "header", "content": "Product 2 (T6)" },
    { "type": "product", "id": "product_2", "label": "Product 2" },
    { "type": "text", "id": "product_2_title", "label": "Title (fallback)", "default": "BowFlex T6 Folding Treadmill" },
    { "type": "textarea", "id": "product_2_desc", "label": "Short Description", "default": "Elevate your home fitness with the BowFlex T6 Folding Treadmill, designed for runners, walkers, and serious home gym users." },
    { "type": "image_picker", "id": "product_2_image", "label": "Image (fallback)" },
    { "type": "text", "id": "product_2_price", "label": "Price (fallback)", "default": "£1,499.99" },
    { "type": "text", "id": "product_2_was_price", "label": "Was Price (fallback)", "default": "£1,899.99" },
    { "type": "url", "id": "product_2_url", "label": "URL (fallback)" },
    { "type": "header", "content": "Spacing" },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        {"value":"no-indent","label":"None"},{"value":"xs","label":"XS"},
        {"value":"s","label":"S"},{"value":"m","label":"M"},
        {"value":"l","label":"L"},{"value":"xl","label":"XL"}
      ],
      "default": "l",
      "label": "Padding Top"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        {"value":"no-indent","label":"None"},{"value":"xs","label":"XS"},
        {"value":"s","label":"S"},{"value":"m","label":"M"},
        {"value":"l","label":"L"},{"value":"xl","label":"XL"}
      ],
      "default": "l",
      "label": "Padding Bottom"
    }
  ],
  "presets": [{ "name": "BFX LP — Product Compare" }]
}
{% endschema %}
