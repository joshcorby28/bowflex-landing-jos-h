<div class="bfx-text-cols bfx-text-cols--{{ section.id }}">
  <div class="container">
    <div class="bfx-text-cols__grid">

      {%- for block in section.blocks -%}
        {%- if block.type == 'column' -%}
          <div class="bfx-text-cols__col" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div class="bfx-text-cols__col-img">
                {{- block.settings.image | image_url: width: 80 | image_tag: loading: 'lazy', style: 'height:56px;width:auto;margin-bottom:16px;' -}}
              </div>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h3 class="bfx-text-cols__col-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="bfx-text-cols__col-text rte">{{ block.settings.text }}</div>
            {%- endif -%}
            {%- if block.settings.link_label != blank and block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="bfx-text-cols__col-link">{{ block.settings.link_label }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</div>

<style>
  .bfx-text-cols--{{ section.id }} {
    padding-top: var(--spacing-{{ section.settings.padding_top }}, 48px);
    padding-bottom: var(--spacing-{{ section.settings.padding_bottom }}, 48px);
    background: {{ section.settings.background_color }};
  }
  .bfx-text-cols__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: 40px;
  }
  .bfx-text-cols__col-heading {
    font-family: var(--font-body-family);
    font-size: clamp(20px, 2.2vw, 26px);
    font-weight: 700;
    font-style: normal;
    margin: 0 0 14px;
    line-height: 1.3;
  }
  .bfx-text-cols__col-text {
    font-size: 15px;
    color: #444;
    line-height: 1.6;
    margin: 0 0 16px;
  }
  .bfx-text-cols__col-link {
    font-size: 15px;
    color: #111;
    text-decoration: underline;
    font-weight: 600;
  }
  .bfx-text-cols__col-link:hover { opacity: 0.7; }
  @media (max-width: 749px) {
    .bfx-text-cols__grid { grid-template-columns: 1fr !important; gap: 28px; }
  }
</style>

{% schema %}
{
  "name": "BFX LP — Text Columns",
  "tag": "section",
  "class": "bfx-lp-text-cols-section spaced-section",
  "enabled_on": { "templates": ["*"] },
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Colour",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "label": "Columns"
    },
    { "type": "header", "content": "Spacing" },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        {"value":"no-indent","label":"None"},{"value":"xs","label":"XS"},
        {"value":"s","label":"S"},{"value":"m","label":"M"},
        {"value":"l","label":"L"},{"value":"xl","label":"XL"}
      ],
      "default": "l",
      "label": "Padding Top"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        {"value":"no-indent","label":"None"},{"value":"xs","label":"XS"},
        {"value":"s","label":"S"},{"value":"m","label":"M"},
        {"value":"l","label":"L"},{"value":"xl","label":"XL"}
      ],
      "default": "l",
      "label": "Padding Bottom"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Icon / Image" },
        { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "A Premium Running Experience with Ultimate App Freedom" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>The BFX T9 Treadmill delivers a high-performance workout experience, blending power, connectivity, and comfort.</p>" },
        { "type": "text", "id": "link_label", "label": "Link Label", "default": "Read more" },
        { "type": "url", "id": "link", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BFX LP — Text Columns",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "heading": "A Premium Running Experience with Ultimate App Freedom",
            "text": "<p>The BFX T9 Treadmill delivers a high-performance workout experience, blending power, connectivity, and comfort.</p>",
            "link_label": "Read more"
          }
        },
        {
          "type": "column",
          "settings": {
            "heading": "Built for Performance, Designed for Results",
            "text": "<p>Elevate your home fitness with the BowFlex T6 Folding Treadmill, designed for runners, walkers, and serious home gym users.</p>",
            "link_label": "Read more"
          }
        }
      ]
    }
  ]
}
{% endschema %}
