{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'section-products-grid.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
<script src="{{ 'products-grid.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-padding' %}
{%- endstyle -%}

{% liquid
  assign grid_products = collections.all.products
  assign collection_handle = 'all'
  assign base_url = routes.all_products_collection_url
  assign total_shop_products = shop.products_count | default: 0

  if section.settings.collection != blank
    assign grid_products = section.settings.collection.products
    assign collection_handle = section.settings.collection.handle
    assign base_url = routes.collections_url | append: '/' | append: collection_handle
    assign total_shop_products = section.settings.collection.all_products_count
  endif

  if section.settings.product_list != blank
    assign grid_products = section.settings.product_list
    assign collection_handle = 'all'
    assign base_url = 'none'
    assign total_shop_products = section.settings.product_list.size
  endif

  case section.settings.sort
    when 'alphabetical', 'alphabetical_reversed'
      assign grid_products = grid_products | sort: 'title'
    when 'products_high', 'products_low'
      assign grid_products = grid_products | sort: 'price_min'
    when 'date', 'date_reversed'
      assign grid_products = grid_products | sort: 'published_at'
    when 'featured'
      assign grid_products = grid_products | sort: 'manual'
    when 'best_selling'
      assign grid_products = grid_products | sort: 'manual'
  endcase

  if section.settings.sort == 'products_high' or section.settings.sort == 'date_reversed' or section.settings.sort == 'alphabetical_reversed'
    assign grid_products = grid_products | reverse
  endif

  assign btn_link = ''
  case section.settings.sort
    when 'alphabetical'
      assign btn_link = routes.collections_url | append: '/' | append: collection_handle | append: '?sort_by=title-ascending'
    when 'alphabetical_reversed'
      assign btn_link = routes.collections_url | append: '/' | append: collection_handle | append: '?sort_by=title-descending'
    when 'date'
      assign btn_link = routes.collections_url | append: '/' | append: collection_handle | append: '?sort_by=created-ascending'
    when 'date_reversed'
      assign btn_link = routes.collections_url | append: '/' | append: collection_handle | append: '?sort_by=created-descending'
    when 'products_low'
      assign btn_link = routes.collections_url | append: '/' | append: collection_handle | append: '?sort_by=price-ascending'
    when 'products_high'
      assign btn_link = routes.collections_url | append: '/' | append: collection_handle | append: '?sort_by=price-descending'
    when 'featured'
      assign btn_link = routes.collections_url | append: '/' | append: collection_handle | append: '?sort_by=manual'
    when 'best_selling'
      assign btn_link = routes.collections_url | append: '/' | append: collection_handle | append: '?sort_by=best-selling'
  endcase

  if section.settings.button_link != blank
    assign btn_link = section.settings.button_link
  endif

  assign is_dynamic_loading = false
  if total_shop_products > 50
    assign is_dynamic_loading = true
  elsif section.settings.sort == 'featured' or section.settings.sort == 'best_selling'
    if base_url != 'none' and total_shop_products > 0
      assign is_dynamic_loading = true
    endif
  endif
%}

<div
  class="products-grid section-{{ section.id }}-padding{% if is_dynamic_loading %} products-grid--loading{% endif %}"
  data-is-dynamic-load="{{ is_dynamic_loading }}"
  data-base-url="{{ base_url }}"
  data-sort-type="{{ section.settings.sort }}"
  data-limit-products="{{ section.settings.products_per_page }}"
>
  <div class="container">
    {% assign show_button = false %}
    {%- if section.settings.button_show and section.settings.button_label != blank -%}
      {% assign show_button = true %}
    {% endif %}
    {%- if section.settings.heading != blank or section.settings.description != blank or show_button -%}
      <div class="products-grid__top {% if section.settings.heading != blank and section.settings.description == blank %} products-grid__top_only-heading{% endif %}">
        <div class="products-grid__top-main">
          {% render 'heading-group', section: section, class: 'products-grid' %}
        </div>

        {%- if show_button -%}
          <a
            {% if btn_link %}
              href="{{ btn_link }}"
            {% else %}
              disabled
            {% endif %}
            class="link--underline_arrow"
          >
            <span>
              {{- section.settings.button_label -}}
            </span>
            {% render 'icon-btn-arrow' %}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="products-grid full-width content">
      <div class="loading-overlay no-js-hidden">
        <div class="loading-overlay__spinner">
          {% render 'icon-loading' %}
        </div>
      </div>

      <ul
        id="products-grid"
        data-id="{{ section.id }}"
        class="collection-product-list collection-product-list--{{ section.settings.columns }}-items collection-product-list--{{ section.settings.columns_mobile }}-mobile"
      >
        {% if grid_products.size > 0 %}
          {%- for product in grid_products limit: section.settings.products_per_page -%}
            <li class="collection-product-list-item">
              {% render 'product-card',
                product_card_product: product,
                show_vendor: section.settings.show_vendor,
                show_desc: section.settings.show_desc,
                show_iventory: section.settings.show_iventory,
                columns: section.settings.columns,
                mobile_column: section.settings.columns_mobile,
                section_id: section.id
              %}
            </li>
          {%- endfor -%}
        {% else %}
          {%- for i in (1..4) -%}
            <li class="collection-product-list-item">
              {% render 'product-card-placeholder',
                show_vendor: section.settings.show_vendor,
                product_number: forloop.index
              %}
            </li>
          {%- endfor -%}
        {% endif %}
      </ul>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.products-grid.name",
  "tag": "section",
  "class": "products-grid-section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["*"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.all.heading.label",
      "default": "t:sections.products-grid.settings.heading.default"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_level",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_level.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_level.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_level.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_level.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.products-grid.settings.collection.label"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "t:sections.products-grid.settings.product_list.label",
      "info": "t:sections.products-grid.settings.product_list.info",
      "limit": 50
    },
    {
      "type": "paragraph",
      "content": "t:sections.products-grid.settings.text_about_products.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.products-grid.settings.text_about_dynamic.content"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 50,
      "step": 1,
      "default": 4,
      "label": "t:sections.products-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 6,
      "label": "t:sections.products-grid.settings.columns.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "1",
      "label": "t:sections.products-grid.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.products-grid.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.products-grid.settings.columns_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "sort",
      "options": [
        {
          "value": "alphabetical",
          "label": "t:sections.products-grid.settings.sort.options__1.label"
        },
        {
          "value": "alphabetical_reversed",
          "label": "t:sections.products-grid.settings.sort.options__2.label"
        },
        {
          "value": "date_reversed",
          "label": "t:sections.products-grid.settings.sort.options__3.label"
        },
        {
          "value": "date",
          "label": "t:sections.products-grid.settings.sort.options__4.label"
        },
        {
          "value": "products_high",
          "label": "t:sections.products-grid.settings.sort.options__5.label"
        },
        {
          "value": "products_low",
          "label": "t:sections.products-grid.settings.sort.options__6.label"
        },
        {
          "value": "featured",
          "label": "t:sections.products-grid.settings.sort.options__7.label"
        },
        {
          "value": "best_selling",
          "label": "t:sections.products-grid.settings.sort.options__8.label"
        }
      ],
      "default": "alphabetical",
      "label": "t:sections.products-grid.settings.sort.label",
      "info": "t:sections.products-grid.settings.sort.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.card.header_card.content"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "t:sections.products-grid.settings.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_desc",
      "default": false,
      "label": "t:sections.products-grid.settings.show_desc.label",
      "info": "t:sections.products-grid.settings.show_desc.info"
    },
    {
      "type": "checkbox",
      "id": "show_iventory",
      "default": true,
      "label": "t:sections.all.card.show_iventory.label",
      "info": "t:sections.popular-products.settings.show_iventory.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.button.header_button.content"
    },
    {
      "type": "checkbox",
      "id": "button_show",
      "default": true,
      "label": "t:sections.all.button.button_show.label"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.all.button.button_label.label",
      "default": "t:sections.products-grid.settings.button_label.default"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.all.button.button_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "s",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "l",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.products-grid.name",
      "category": "t:sections.categories.products"
    }
  ]
}
{% endschema %}
