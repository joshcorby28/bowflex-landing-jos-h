{{ 'section-recently-viewed.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
<script src="{{ 'recently-viewed.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}

  .recently-viewed__wrapper {
    position: relative;
  }
  .recently-viewed__empty {
    display: none;
    width: 100%;
    align-items: center;
    justify-content: center;
  }
  .recently-viewed__empty span {
    max-width: 550px;
    text-align: center;
  }
  .recently-viewed--empty .recently-viewed__empty {
    display: flex;
  }
  .recently-viewed .loading-overlay {
    inset: 0;
    z-index: 6;
    display: none;
    width: 100%;
    padding: 0 5rem;
  }
  .recently-viewed.recently-viewed--loading .loading-overlay {
    display: block;
  }
  .recently-viewed.recently-viewed--loading .loading-overlay .loading-overlay__spinner {
    top: 50%;
    transform: translateY(-50%);
  }

  .recently-viewed.recently-viewed--loading .recently-viewed__navigation,
  .recently-viewed.recently-viewed--empty .recently-viewed__navigation {
    display: none;
  }
{%- endstyle -%}

<div
  class="recently-viewed recently-viewed--loading color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding no-js-hidden{% if search.performed %} recently-viewed--search-perfomed{% endif %}"
  data-base-url="{{ routes.search_url }}?section_id={{section.id}}&type=product"
  data-current-product="{{ product.id }}"
  data-products-limit="{{ section.settings.products_limit }}"
>
  <div class="recently-viewed__top container">
    <div class="recently-viewed__top-main">
      {% render 'heading-group', section: section, class: 'recently-viewed', text_align: 'left' %}
    </div>
    <div
      class="recently-viewed__navigation slider-navigation-container js-recently-viewed-nav"
      data-nav-id="{{ section.id }}"
    >
      <button class="swiper-button-prev focus-inset">
        {% render 'icon-btn-arrow' %}
      </button>
      <button class="swiper-button-next focus-inset">
        {% render 'icon-btn-arrow' %}
      </button>
    </div>
  </div>
  <div class="recently-viewed__wrapper container content">
    <div class="loading-overlay">
      <div class="loading-overlay__spinner">
        {% render 'icon-loading' %}
      </div>
    </div>

    <div class="recently-viewed__empty body-large">
      <span class="body-large">{{- 'sections.recently_viewed.empty_message' | t -}}</span>
    </div>

    <div
      class="recently-viewed__layout js-recently-viewed {% if section.settings.animate_on_scroll %} animate-on-scroll{% endif %}"
      data-layout="section"
      data-template="{{ section.id }}"
      data-mobile-column="{{- section.settings.columns_mobile -}}"
    >
      <div class="recently-viewed__list">
        {% assign product_list = search.results | where: 'object_type', 'product' %}
        {% assign product_count = 0 %}

        {% for product in product_list %}
          {% assign product_count = product_count | plus: 1 %}
        {% endfor %}

        {% liquid
          assign anim_delay_coeff = 0.1

          if product_count > 12
            assign anim_delay_coeff = 0.05
          endif

          if product_count > 24
            assign anim_delay_coeff = 0.025
          endif
        %}
        {%- for product in product_list -%}
          <div
            class="recently-viewed__item"
            style="--pop-prod-item-delay: {{ forloop.index | minus: 1 | times: anim_delay_coeff }}s;"
          >
            {% assign columns = 6 %}
            {% render 'product-card',
              product_card_product: product,
              show_vendor: section.settings.show_vendor,
              show_desc: section.settings.show_desc,
              show_iventory: section.settings.show_iventory,
              mobile_column: section.settings.columns_mobile,
              section_id: section.id,
              add_id: forloop.index,
              columns: columns
            %}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.recently-viewed.name",
  "tag": "section",
  "class": "recently-viewed-section recently-viewed-outer",
  "limit": 1,
  "disabled_on": {
    "templates": ["password"],
    "groups": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.recently-viewed.settings.heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_level",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_level.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_level.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_level.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_level.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 4,
      "max": 50,
      "step": 1,
      "default": 12,
      "label": "t:sections.recently-viewed.settings.products_limit.label"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.all.card.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_desc",
      "default": false,
      "label": "t:sections.all.card.show_desc.label",
      "info": "t:sections.all.card.show_desc.info"
    },
    {
      "type": "checkbox",
      "id": "show_iventory",
      "default": true,
      "label": "t:sections.all.card.show_iventory.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.mobile_options.header.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.all.mobile_options.columns.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.all.mobile_options.columns.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.all.mobile_options.columns.options__2.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "l",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.recently-viewed.presets.name",
      "category": "t:sections.categories.products"
    }
  ]
}
{% endschema %}
