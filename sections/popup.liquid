{% liquid
  assign width = section.settings.width | append: 'px'

  assign has_image = false
  if section.settings.show_image and section.settings.image != blank
    assign has_image = true
  endif
%}

<div
  class="popup-main popup popup--{{ section.settings.position }}{% if has_image %} popup-main-image--{{ section.settings.image_position }}{% else %} popup-main--no-image{% endif %}"
  {% if section.settings.popup_id != blank %}
    id="{{ section.settings.popup_id }}"
  {% endif %}
  data-limit-display="{{ section.settings.limit-display }}"
  data-limit-lifetime="{{ section.settings.limit-cache }}"
  data-open-trigger="{{ section.settings.trigger-open }}"
  data-open-delay-number="{{ section.settings.trigger-open-delay }}"
  data-open-scroll-position="{{ section.settings.open-scroll-position }}"
  data-open-scroll-type="{{ section.settings.open-scroll-type }}"
  {% if section.settings['manual-selector'] != blank %}
    data-open-manual-selector="{{ section.settings.manual-selector }}"
  {% endif %}
  data-close-trigger="{{ section.settings.trigger-close }}"
  data-close-delay-number="{{ section.settings.trigger-close-delay }}"
  data-close-scroll-position="{{ section.settings.close-scroll-position }}"
  data-close-scroll-type="{{ section.settings.close-scroll-type }}"
  data-open-animation="popupOpen{{ section.settings.open-animation }}"
  data-exit-animation="popupExit{{ section.settings.exit-animation }}"
  data-overlay="{{ section.settings.show-overlay }}"
  data-mobile-disable="{{ section.settings.mobile }}"
  data-body-scroll-disable="{{ section.settings.scrolling }}"
  data-overlay-close="{{ section.settings.overlay-close }}"
  data-esc-close="{{ section.settings.esc-close }}"
  data-f4-close="{{ section.settings.f4-close }}"
  data-id="{{ section.id }}"
  style="width: {{ width }};"
>
  <div class="popup-wrap color-{{ section.settings.color_scheme }} background">
    <div class="popup-container">
      {%- liquid
        if has_image and section.settings.image_position == 'background'
          if section.settings.aspect_ratio == 'portrait'
            # 3 / 4
            assign outer_padding_bottom = 133
          elsif section.settings.aspect_ratio == 'landscape'
            # 3 / 2
            assign outer_padding_bottom = 66
          elsif section.settings.aspect_ratio == 'square'
            # 1 / 1
            assign outer_padding_bottom = 100
          else
            # adapt
            assign outer_padding_bottom = 100 | divided_by: section.settings.image.aspect_ratio | round: 2
          endif
        endif
      -%}
      <div
        class="popup-outer{% if has_image != blank %} popup-outer_image {% if section.settings.image_position == 'background' %} popup-outer_image--background{% endif %}{% endif %}"
        {% if has_image and section.settings.image_position == 'background' %}
          style="--padding_bottom_outer: {{ outer_padding_bottom }}%;"
        {% endif %}
      >
        {%- if has_image -%}
          {%- liquid
            if section.settings.aspect_ratio == 'portrait'
              # 3 / 4
              assign image_padding_bottom = 133
              assign settings_aspect_ratio = 0.75
            elsif section.settings.aspect_ratio == 'landscape'
              # 3 / 2
              assign image_padding_bottom = 66

              if section.settings.image_position == 'top' or section.settings.image_position == 'bottom'
                assign image_padding_bottom = 56
              endif
              assign settings_aspect_ratio = 1.33
            elsif section.settings.aspect_ratio == 'square'
              # 1 / 1
              assign image_padding_bottom = 100
              assign settings_aspect_ratio = 1
            else
              # adapt
              assign image_padding_bottom = 100 | divided_by: section.settings.image.aspect_ratio | round: 2
              assign settings_aspect_ratio = section.settings.image.aspect_ratio
            endif

            assign calc_ratio = 1
            if section.settings.image.aspect_ratio > settings_aspect_ratio
              assign calc_ratio = section.settings.image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
            endif
          -%}
          <div
            class="popup-thumbnail"
            {% if section.settings.image_position != 'background' %}
              style="--padding_bottom: {{ image_padding_bottom }}%;"
            {% endif %}
          >
            {%- capture sizes -%}
              {%- if section.settings.image_position == 'top' or section.settings.image_position == 'bottom' or section.settings.image_position == 'background' -%}
                (min-width: 750px) calc({{width}} * {{ calc_ratio }}), calc(100vw * {{ calc_ratio }})
              {%- else -%}
                (min-width: 750px) calc({{width}} * 0.5 * {{ calc_ratio }}), calc(100vw * {{ calc_ratio }})
              {%- endif -%}
            {%- endcapture -%}
            {%- capture style -%}
              object-fit: {{ section.settings.image_fit }}; object-position: {{ section.settings.image.presentation.focal_point }};
            {%- endcapture -%}
            {{
              section.settings.image
              | image_url: width: section.settings.image.width
              | image_tag:
                loading: 'lazy',
                sizes: sizes,
                widths: '275, 550, 750, 990, 1200, 1360, 1600, 1800, 2000, 2400, 2800, 3200',
                style: style
            }}

            {%- if section.settings.overlay_opacity != 0 -%}
              <span
                class="popup-thumbnail-overlay"
                style="background-color: rgba(var(--color-overlay), {{ section.settings.overlay_opacity }})"
              ></span>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="popup-content popup-content--{{ section.settings.content_align }}{% if section.settings.width <= 800 %} popup-content--narrow-content{% endif %}">
          <div class="popup-wrapper-text">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'popup_subheading' -%}
                  {%- if block.settings.subheading != blank -%}
                    <div
                      class="popup-subheading {{ block.settings.subheading_style }}{% if block.settings.subheading_style == 'simple' %} h4{% endif %}{% if block.settings.subheading_style == 'badge' %} {{ block.settings.badge_subheading_color }}{% endif %}"
                      {{ block.shopify_attributes }}
                    >
                      {{- block.settings.subheading -}}
                    </div>
                  {%- endif -%}
                {%- when 'popup_heading' -%}
                  {%- if block.settings.heading != blank -%}


            
                <!--   <{{ block.settings.heading_level | default: 'h3' }}
                      class="popup-heading richtext-link-inside {{ block.settings.heading_size }}"
                      {{ block.shopify_attributes }}
                    >
                      {{- block.settings.heading -}}
                    </{{ block.settings.heading_level | default: 'h3' }}> -->

            <span
                      class="popup-heading richtext-link-inside {{ block.settings.heading_size }}"
                      {{ block.shopify_attributes }}
                    >
                      {{- block.settings.heading -}}
                    </span>

                   
                  {%- endif -%}
                {%- when 'popup_description' -%}
                  {%- if block.settings.description != blank -%}
                    <div
                      class="popup-description rte"
                      {{ block.shopify_attributes }}
                    >
                      {{- block.settings.description -}}
                    </div>
                  {%- endif -%}
                {%- when 'button' -%}
                  {% render 'button', layout: block, class: 'popup-button' %}
                {%- when 'subscribe_form' -%}
                  {% assign form_id = 'popup_newsletter_' | append: section.id %}
                  {% form 'customer', class: 'newsletter-form', id: form_id %}
                    <div
                      class="newsletter-form__inner{% if section.settings.width <= 500 %} newsletter-form__inner_column{% endif %}"
                      {{ block.shopify_attributes }}
                    >
                      <input type="hidden" name="contact[tags]" value="newsletter">
                      <div class="newsletter-form__field-wrapper">
                        <div class="field">
                          <input
                            id="NewsletterForm--{{ section.id }}"
                            type="email"
                            name="contact[email]"
                            dir="ltr"
                            class="field__input field"
                            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                            aria-required="true"
                            autocorrect="off"
                            autocapitalize="off"
                            autocomplete="email"
                            pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
                            {% if form.errors %}
                              autofocus
                              aria-invalid="true"
                              aria-describedby="Newsletter-error--{{ section.id }}"
                            {% elsif form.posted_successfully? %}
                              aria-describedby="Newsletter-success--{{ section.id }}"
                            {% endif %}
                            placeholder="{{ block.settings.placeholder_input }}"
                            required
                          >
                          <label class="h6" for="NewsletterForm--{{ section.id }}">
                            {{- 'newsletter.label' | t -}}
                          </label>
                        </div>
                      </div>
                      <button
                        type="submit"
                        class="button button--{{ block.settings.button_style }} focus-inset"
                        name="commit"
                      >
                        <div class="button__content">
                          <span class="button__label" data-label="{{- block.settings.button_label -}}">
                            {{- block.settings.button_label -}}
                          </span>
                        </div>
                      </button>
                    </div>
                    {%- if form.errors -%}
                      <small
                        class="newsletter-form__message form__message"
                        id="Newsletter-error--{{ section.id }}"
                      >
                        {%- render 'icon-error' -%}
                        {{- form.errors.translated_fields.email | capitalize }}
                        {{ form.errors.messages.email -}}
                      </small>
                    {%- endif -%}
                    {%- if form.posted_successfully? -%}
                      <h3
                        class="newsletter-form__message newsletter-form__message--success form__message"
                        id="Newsletter-success--{{ section.id }}"
                        tabindex="-1"
                        autofocus
                      >
                        {% render 'icon-success' -%}
                        {{- 'newsletter.success' | t -}}
                      </h3>
                    {%- endif -%}
                  {% endform %}
                  {% if block.settings.description != blank %}
                    <div class="popup-text body-small richtext-link-inside" {{ block.shopify_attributes }}>
                      {{- block.settings.description -}}
                    </div>
                  {% endif %}
                {%- when 'social_links' -%}
                  {% if block.settings.show_twitter
                    and settings.social_twitter_link != blank
                    or block.settings.show_facebook
                    and settings.social_facebook_link != blank
                    or block.settings.show_pinterest
                    and settings.social_pinterest_link != blank
                    or block.settings.show_instagram
                    and settings.social_instagram_link != blank
                    or block.settings.show_tiktok
                    and settings.social_tiktok_link != blank
                    or block.settings.show_tumblr
                    and settings.social_tumblr_link != blank
                    or block.settings.show_snapchat
                    and settings.social_snapchat_link != blank
                    or block.settings.show_youtube
                    and settings.social_youtube_link != blank
                    or block.settings.show_vimeo
                    and settings.social_vimeo_link != blank
                  %}
                    <ul
                      class="list-unstyled list-social"
                      role="list"
                      {{ block.shopify_attributes }}
                    >
                      {%- if block.settings.show_twitter and settings.social_twitter_link != blank -%}
                        <li class="list-social__item">
                          <a
                            href="{{ settings.social_twitter_link }}"
                            class="link link--text list-social__link"
                            {%- if settings.links_blank -%}
                              target="_blank"
                            {%- endif -%}
                          >
                            {%- render 'icon-twitter' -%}
                            <span class="visually-hidden">
                              {{- 'general.social.links.twitter' | t -}}
                            </span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if block.settings.show_facebook and settings.social_facebook_link != blank -%}
                        <li class="list-social__item">
                          <a
                            href="{{ settings.social_facebook_link }}"
                            class="link link--text list-social__link"
                            {%- if settings.links_blank -%}
                              target="_blank"
                            {%- endif -%}
                          >
                            {%- render 'icon-facebook' -%}
                            <span class="visually-hidden">
                              {{- 'general.social.links.facebook' | t -}}
                            </span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if block.settings.show_pinterest and settings.social_pinterest_link != blank -%}
                        <li class="list-social__item">
                          <a
                            href="{{ settings.social_pinterest_link }}"
                            class="link link--text list-social__link"
                            {%- if settings.links_blank -%}
                              target="_blank"
                            {%- endif -%}
                          >
                            {%- render 'icon-pinterest' -%}
                            <span class="visually-hidden">
                              {{- 'general.social.links.pinterest' | t -}}
                            </span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if block.settings.show_instagram and settings.social_instagram_link != blank -%}
                        <li class="list-social__item">
                          <a
                            href="{{ settings.social_instagram_link }}"
                            class="link link--text list-social__link"
                            {%- if settings.links_blank -%}
                              target="_blank"
                            {%- endif -%}
                          >
                            {%- render 'icon-instagram' -%}
                            <span class="visually-hidden">
                              {{- 'general.social.links.instagram' | t -}}
                            </span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if block.settings.show_tiktok and settings.social_tiktok_link != blank -%}
                        <li class="list-social__item">
                          <a
                            href="{{ settings.social_tiktok_link }}"
                            class="link link--text list-social__link"
                            {%- if settings.links_blank -%}
                              target="_blank"
                            {%- endif -%}
                          >
                            {%- render 'icon-tiktok' -%}
                            <span class="visually-hidden">
                              {{- 'general.social.links.tiktok' | t -}}
                            </span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if block.settings.show_tumblr and settings.social_tumblr_link != blank -%}
                        <li class="list-social__item">
                          <a
                            href="{{ settings.social_tumblr_link }}"
                            class="link link--text list-social__link"
                            {%- if settings.links_blank -%}
                              target="_blank"
                            {%- endif -%}
                          >
                            {%- render 'icon-tumblr' -%}
                            <span class="visually-hidden">
                              {{- 'general.social.links.tumblr' | t -}}
                            </span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if block.settings.show_snapchat and settings.social_snapchat_link != blank -%}
                        <li class="list-social__item">
                          <a
                            href="{{ settings.social_snapchat_link }}"
                            class="link link--text list-social__link"
                            {%- if settings.links_blank -%}
                              target="_blank"
                            {%- endif -%}
                          >
                            {%- render 'icon-snapchat' -%}
                            <span class="visually-hidden">
                              {{- 'general.social.links.snapchat' | t -}}
                            </span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if block.settings.show_youtube and settings.social_youtube_link != blank -%}
                        <li class="list-social__item">
                          <a
                            href="{{ settings.social_youtube_link }}"
                            class="link link--text list-social__link"
                            {%- if settings.links_blank -%}
                              target="_blank"
                            {%- endif -%}
                          >
                            {%- render 'icon-youtube' -%}
                            <span class="visually-hidden">
                              {{- 'general.social.links.youtube' | t -}}
                            </span>
                          </a>
                        </li>
                      {%- endif -%}
                      {%- if block.settings.show_vimeo and settings.social_vimeo_link != blank -%}
                        <li class="list-social__item">
                          <a
                            href="{{ settings.social_vimeo_link }}"
                            class="link link--text list-social__link"
                            {%- if settings.links_blank -%}
                              target="_blank"
                            {%- endif -%}
                          >
                            {%- render 'icon-vimeo' -%}
                            <span class="visually-hidden">
                              {{- 'general.social.links.vimeo' | t -}}
                            </span>
                          </a>
                        </li>
                      {%- endif -%}
                    </ul>
                  {% endif %}
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>

        <button
          type="button"
          class="button button--unstyled modal-close-button popup-close focus-inset"
          aria-label="{{- 'accessibility.close' | t -}}"
        >
          {% render 'icon-close' %}
        </button>
      </div>
    </div>
  </div>
</div>

{% if section.settings['show-overlay'] %}
  <div
    class="popup-overlay"
    {%- if section.settings['overlay-close'] -%}
      style="cursor: pointer;"
    {%- endif -%}
  ></div>
{% endif %}

{% schema %}
{
  "name": "t:sections.overlay-group.popup.name",
  "enabled_on": {
    "groups": ["custom.overlay"]
  },
  "settings": [
    {
      "type": "text",
      "id": "popup_id",
      "label": "t:sections.overlay-group.all.settings.popup_id.label"
    },
    {
      "type": "header",
      "content": "t:sections.overlay-group.all.settings.style.header.content"
    },
    {
      "type": "range",
      "id": "width",
      "min": 460,
      "max": 1920,
      "unit": "px",
      "step": 20,
      "default": 520,
      "label": "t:sections.overlay-group.all.settings.width.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "select",
      "id": "position",
      "options": [
        {
          "value": "top-left",
          "label": "t:sections.overlay-group.all.settings.position.options__1.label"
        },
        {
          "value": "top",
          "label": "t:sections.overlay-group.all.settings.position.options__2.label"
        },
        {
          "value": "top-right",
          "label": "t:sections.overlay-group.all.settings.position.options__3.label"
        },
        {
          "value": "left",
          "label": "t:sections.overlay-group.all.settings.position.options__4.label"
        },
        {
          "value": "center",
          "label": "t:sections.overlay-group.all.settings.position.options__5.label"
        },
        {
          "value": "right",
          "label": "t:sections.overlay-group.all.settings.position.options__6.label"
        },
        {
          "value": "bottom-left",
          "label": "t:sections.overlay-group.all.settings.position.options__7.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.overlay-group.all.settings.position.options__8.label"
        },
        {
          "value": "bottom-right",
          "label": "t:sections.overlay-group.all.settings.position.options__9.label"
        }
      ],
      "default": "bottom-left",
      "label": "t:sections.overlay-group.all.settings.position.label"
    },
    {
      "type": "text_alignment",
      "id": "content_align",
      "label": "t:sections.overlay-group.popup.settings.content_align.label",
      "default": "left"
    },
    {
      "type": "select",
      "id": "open-animation",
      "label": "t:sections.overlay-group.all.settings.open-animation.label",
      "options": [
        {
          "value": "Fade",
          "label": "t:sections.overlay-group.all.settings.animation.options__1.label"
        },
        {
          "value": "Slide",
          "label": "t:sections.overlay-group.all.settings.animation.options__2.label"
        },
        {
          "value": "Zoom",
          "label": "t:sections.overlay-group.all.settings.animation.options__3.label"
        },
        {
          "value": "SlideFade",
          "label": "t:sections.overlay-group.all.settings.animation.options__4.label"
        }
      ],
      "default": "Fade"
    },
    {
      "type": "select",
      "id": "exit-animation",
      "label": "t:sections.overlay-group.all.settings.exit-animation.label",
      "options": [
        {
          "value": "Fade",
          "label": "t:sections.overlay-group.all.settings.animation.options__1.label"
        },
        {
          "value": "Slide",
          "label": "t:sections.overlay-group.all.settings.animation.options__2.label"
        },
        {
          "value": "Zoom",
          "label": "t:sections.overlay-group.all.settings.animation.options__3.label"
        },
        {
          "value": "SlideFade",
          "label": "t:sections.overlay-group.all.settings.animation.options__4.label"
        }
      ],
      "default": "Fade"
    },
    {
      "type": "checkbox",
      "id": "show-overlay",
      "label": "t:sections.overlay-group.all.settings.show-overlay.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.overlay-group.all.settings.image.header.content"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:sections.overlay-group.all.settings.image.show_image.label",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.overlay-group.popup.settings.image.label"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.card.image_ratio_2.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.card.image_ratio_2.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.card.image_ratio_2.options__3.label"
        },
        {
          "value": "adapt",
          "label": "t:sections.all.card.image_ratio_2.options__4.label"
        }
      ],
      "default": "landscape",
      "label": "t:sections.all.card.image_ratio_2.label"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.overlay-group.popup.settings.image_position.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.overlay-group.popup.settings.image_position.options__1.label"
        },
        {
          "value": "right",
          "label": "t:sections.overlay-group.popup.settings.image_position.options__2.label"
        },
        {
          "value": "top",
          "label": "t:sections.overlay-group.popup.settings.image_position.options__3.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.overlay-group.popup.settings.image_position.options__4.label"
        },
        {
          "value": "background",
          "label": "t:sections.overlay-group.popup.settings.image_position.options__5.label"
        }
      ],
      "default": "top"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "t:sections.all.card.image_fit.label",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.all.card.image_fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.all.card.image_fit.options__2.label"
        }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "t:sections.all.overlay_opacity.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.overlay-group.all.settings.trigger.header.content"
    },
    {
      "type": "select",
      "id": "trigger-open",
      "label": "t:sections.overlay-group.all.settings.trigger-open.label",
      "options": [
        {
          "value": "delay",
          "label": "t:sections.overlay-group.all.settings.trigger.options__1.label"
        },
        {
          "value": "scroll",
          "label": "t:sections.overlay-group.all.settings.trigger.options__2.label"
        },
        {
          "value": "exit",
          "label": "t:sections.overlay-group.all.settings.trigger.options__3.label"
        },
        {
          "value": "manual",
          "label": "t:sections.overlay-group.all.settings.trigger.options__4.label"
        }
      ],
      "default": "delay"
    },
    {
      "type": "range",
      "id": "trigger-open-delay",
      "label": "t:sections.overlay-group.all.settings.trigger-open-delay.label",
      "min": 0,
