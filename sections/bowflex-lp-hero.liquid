<div class="bfx-hero bfx-hero--{{ section.id }}">
  <picture>
    {%- if section.settings.image_mobile != blank -%}
      <source
        media="(max-width: 749px)"
        srcset="{{ section.settings.image_mobile | image_url: width: 375 }} 375w, {{ section.settings.image_mobile | image_url: width: 750 }} 750w"
        sizes="100vw"
      >
    {%- endif -%}
    {%- if section.settings.image_desktop != blank -%}
      {{- section.settings.image_desktop | image_url: width: 1920 | image_tag: loading: 'eager', fetchpriority: 'high', widths: '750,1100,1500,1920', sizes: '100vw', style: 'width:100%;height:auto;display:block;' -}}
    {%- elsif section.settings.image_mobile != blank -%}
      {{- section.settings.image_mobile | image_url: width: 750 | image_tag: loading: 'eager', fetchpriority: 'high', widths: '375,750', sizes: '100vw', style: 'width:100%;height:auto;display:block;' -}}
    {%- endif -%}
  </picture>
</div>

<style>
  .bfx-hero--{{ section.id }} { line-height: 0; }
</style>

{% schema %}
{
  "name": "BFX LP — Hero",
  "tag": "section",
  "class": "bfx-lp-hero-section",
  "enabled_on": { "templates": ["*"] },
  "settings": [
    { "type": "image_picker", "id": "image_desktop", "label": "Desktop Image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile Image" }
  ],
  "presets": [{ "name": "BFX LP — Hero" }]
}
{% endschema %}
