<div class="bfx-hero bfx-hero--{{ section.id }}">
  {%- if section.settings.image_desktop != blank -%}
    <div class="bfx-hero__desktop">
      {{- section.settings.image_desktop | image_url: width: 1920 | image_tag: loading: 'eager', fetchpriority: 'high', widths: '750,1100,1500,1920', style: 'width:100%;display:block;' -}}
    </div>
  {%- endif -%}
  {%- if section.settings.image_mobile != blank -%}
    <div class="bfx-hero__mobile">
      {{- section.settings.image_mobile | image_url: width: 750 | image_tag: loading: 'eager', fetchpriority: 'high', widths: '375,750', style: 'width:100%;display:block;' -}}
    </div>
  {%- endif -%}
</div>

<style>
  .bfx-hero--{{ section.id }} { line-height: 0; }
  .bfx-hero__mobile { display: none; }
  @media (max-width: 749px) {
    .bfx-hero__desktop { display: none; }
    .bfx-hero__mobile { display: block; }
  }
</style>

{% schema %}
{
  "name": "BFX LP — Hero",
  "tag": "section",
  "class": "bfx-lp-hero-section",
  "enabled_on": { "templates": ["*"] },
  "settings": [
    { "type": "image_picker", "id": "image_desktop", "label": "Desktop Image" },
    { "type": "image_picker", "id": "image_mobile", "label": "Mobile Image" }
  ],
  "presets": [{ "name": "BFX LP — Hero" }]
}
{% endschema %}
