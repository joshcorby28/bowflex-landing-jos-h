{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'section-main-blog.css' | asset_url | stylesheet_tag }}

{%- if settings.pagination_type == 'load_more' or settings.pagination_type == 'infinite_scroll' -%}
  <script src="{{ 'load-more.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% liquid
  assign has_featured_posts = false
  for block in section.blocks
    if block.settings.featured_post != blank
      assign has_featured_posts = true
    endif
  endfor
%}

{% if has_featured_posts %}
  {{ 'component-article-card-overlay.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- style -%}
  {% render 'section-padding' %}
{%- endstyle -%}

{% liquid
  assign blog_title = blog.title
%}

<div class="main-blog main-blog-{{ section.id }} section-{{ section.id }}-padding">
  <div class="container">
    {% render 'page-header', title: blog_title, class: 'main-blog-title' %}
    {% if section.settings.desc != blank %}
      <div class="main-blog__desc body-large">
        {{ section.settings.desc }}
      </div>
    {% endif %}

    {%- if has_featured_posts -%}
      <div class="main-blog__featured-posts main-blog-posts-grid main-blog-posts-grid--{{ section.settings.posts_per_row }}">
        {%- for block in section.blocks -%}
          {%- if block.settings.featured_post != blank -%}
            <div
              class="main-blog__featured-post-wrapper main-blog__featured-post-wrapper--{{ section.settings.featured_aspect_ratio }}"
              {{ block.shopify_attributes }}
            >
              {% liquid
                assign is_inside_section_with_heading = false
                if section.settings.section_header_text != blank
                  assign is_inside_section_with_heading = true
                endif
              %}
              {% render 'article-card-overlay',
                blog: blog,
                article: block.settings.featured_post,
                article_heading_font_size: section.settings.featured_article_heading_font_size,
                aspect_ratio: section.settings.featured_aspect_ratio,
                object_fit: section.settings.featured_object_fit,
                show_image: section.settings.featured_show_image,
                show_date: section.settings.featured_show_date,
                show_author: section.settings.featured_show_author,
                show_tags: section.settings.featured_show_tags,
                show_excerpt: section.settings.featured_show_excerpt,
                show_video_icon: section.settings.featured_show_video_icon,
                show_comments_count: section.settings.featured_show_comments_count,
                is_inside_section_with_heading: is_inside_section_with_heading,
                columns_count: section.settings.posts_per_row,
                color_scheme: block.settings.color_scheme,
                overlay_opacity: block.settings.overlay_opacity,
                featured_show_button: section.settings.featured_show_button
              %}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > 1 -%}
        <div class="no-js-hidden main-blog__slider-controls container">
          <div
            class="main-blog__slider-pagination swiper-pagination color-{{ section.blocks[0].settings.color_scheme }}"
          ></div>
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- paginate blog.articles by section.settings.posts_per_page -%}
      {% if blog.articles_count > 0 %}
        <div class="main-blog-posts-container">
          {% if section.settings.secondary_heading != blank %}
            <h3 class="main-blog__secondary-heading">
              {{ section.settings.secondary_heading }}
            </h3>
          {% endif %}
          <ul class="main-blog-posts-grid main-blog-posts-grid--{{ section.settings.posts_per_row }} load-more-grid list-unstyled">
            {%- for article in blog.articles -%}
              <li class="main-blog-post-card">
                {% liquid
                  assign is_inside_section_with_heading = false
                  if section.settings.section_header_text != blank
                    assign is_inside_section_with_heading = true
                  endif
                %}
                {% render 'article-card',
                  blog: blog,
                  article: article,
                  article_heading_font_size: section.settings.article_heading_font_size,
                  object_fit: section.settings.object_fit,
                  aspect_ratio: section.settings.aspect_ratio,
                  show_image: section.settings.show_image,
                  show_date: section.settings.show_date,
                  show_author: section.settings.show_author,
                  show_tags: section.settings.show_tags,
                  show_excerpt: section.settings.show_excerpt,
                  show_video_icon: section.settings.show_video_icon,
                  show_comments_count: section.settings.show_comments_count,
                  is_inside_section_with_heading: is_inside_section_with_heading,
                  columns_count: section.settings.posts_per_row
                %}
              </li>
            {%- endfor -%}
          </ul>
          {%- if paginate.pages > 1 -%}
            {%- if settings.pagination_type == 'load_more' -%}
              {% render 'load-more',
                next_url: paginate.next.url,
                count_pages: paginate.pages,
                current_page: paginate.current_page
              %}
              <div class="js-hidden">
                {% render 'pagination', paginate: paginate %}
              </div>
            {%- elsif settings.pagination_type == 'infinite_scroll' -%}
              {% render 'infinite-scroll',
                next_url: paginate.next.url,
                count_pages: paginate.pages,
                current_page: paginate.current_page
              %}
              <div class="js-hidden">
                {% render 'pagination', paginate: paginate %}
              </div>
            {% else %}
              {% render 'pagination', paginate: paginate %}
            {%- endif -%}
          {%- endif -%}
        </div>
      {% endif %}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-blog.name",
  "tag": "section",
  "class": "section-main-blog",
  "settings": [
    {
      "type": "text",
      "id": "desc",
      "label": "t:sections.main-blog.settings.desc.label"
    },
    {
      "type": "range",
      "id": "posts_per_page",
      "min": 2,
      "max": 50,
      "step": 1,
      "default": 8,
      "label": "t:sections.main-blog.settings.posts_per_page.label"
    },
    {
      "type": "range",
      "id": "posts_per_row",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-blog.settings.posts_per_row.label"
    },
    {
      "type": "text",
      "id": "secondary_heading",
      "label": "t:sections.main-blog.settings.secondary_heading.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-blog.settings.header__featured.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.main-blog.settings.featured_text.content"
    },
    {
      "type": "checkbox",
      "id": "featured_show_image",
      "default": true,
      "label": "t:sections.blog-posts.settings.show_image.label"
    },
    {
      "type": "select",
      "id": "featured_aspect_ratio",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.card.image_ratio_2.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.card.image_ratio_2.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.card.image_ratio_2.options__3.label"
