    },
    {
      "type": "checkbox",
      "id": "featured_show_comments_count",
      "default": false,
      "label": "t:sections.blog-posts.settings.show_comments_count.label"
    },
    {
      "type": "checkbox",
      "id": "featured_show_button",
      "default": true,
      "label": "t:sections.main-blog.settings.featured_show_button.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-blog.settings.header__content.content"
