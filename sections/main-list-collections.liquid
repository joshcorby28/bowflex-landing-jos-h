      "default": "alphabetical",
      "label": "t:sections.main-list-collections.settings.sort.label"
    },
    {
      "type": "collection_list",
      "id": "collections_sale",
      "label": "t:sections.main-list-collections.settings.collections_sale.label",
      "info": "t:sections.main-list-collections.settings.collections_sale.info"
