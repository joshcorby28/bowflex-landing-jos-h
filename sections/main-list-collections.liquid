      "default": "t:sections.main-list-collections.settings.title.default"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "label": "t:sections.main-list-collections.settings.description.label",
      "default": "t:sections.main-list-collections.settings.description.default"
    },
    {
      "type": "range",
      "id": "collections_per_row",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 4,
