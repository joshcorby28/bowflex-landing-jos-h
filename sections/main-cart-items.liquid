{{ 'component-cart.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag: preload: true }}

{%- for block in section.blocks -%}
  {%- if block.type == 'cart_shipping_slider' and settings.show_shipping -%}
    {{ 'component-cart-shipping.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- if block.type == 'cart_promo_code' -%}
    <script src="{{ 'promocode-copy.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
{%- endfor -%}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-margin' %}

  .cart__empty {
    display: none;
  }
  .is-empty .cart__empty {
    display: flex;
  }
  .cart__empty-button {
    display: none;
  }
  .is-empty .cart__empty-button {
    display: inline-flex;
  }
  .cart-item__error-text:empty {
    margin-top: 0;
  }
  .cart-item__error-text:empty + svg {
    display: none;
  }
{%- endstyle -%}

<div class="main-cart">
  <div class="container">
    <div class="main-cart__header">
      <h1 class="main-cart__title h2">
        {{- 'sections.cart.title' | t -}}
      </h1>

      {% liquid
        assign button_label_continue = 'general.continue_shopping' | t

        assign button_link_continue = routes.collections_url | sort_by: 'best-selling'
        if section.settings.button_link_continue != blank
          assign button_link_continue = section.settings.button_link_continue
        endif
      %}
      {% render 'button',
        btn_label: button_label_continue,
        btn_style: 'link--primary',
        btn_link: button_link_continue,
        class: 'main-cart__header-btn'
      %}
    </div>

    <div class="main-cart__wrapper">
      <cart-items class="{% if cart == empty %} is-empty{% endif %}">
        <div class="cart__empty">
          {% render 'icon-pack', icon: 'bag' %}

          <h2 class="cart__empty-title h3">
            {%- if section.settings.title_empty != blank -%}
              {{- section.settings.title_empty -}}
            {%- else -%}
              {{- 'general.cart.empty_cart_title' | t -}}
            {%- endif -%}
          </h2>

          {%- if section.settings.text_empty != blank -%}
            <p class="cart__empty-desc">
              {{- section.settings.text_empty -}}
            </p>
          {%- endif -%}
        </div>

        <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">
          <div id="main-cart-items" data-id="{{ section.id }}">
            <div class="js-contents">
              {%- if cart != empty -%}
                <table class="cart-items">
                  <thead>
                    <tr>
                      <th class="body-small" colspan="2" scope="col">
                        {{- 'sections.cart.headings.product' | t -}}
                      </th>
                      <th class="body-small cart-items-price" colspan="1" scope="col">
                        {{- 'sections.cart.headings.price' | t -}}
                      </th>
                      <th class="body-small cart-items-quantity" colspan="1" scope="col">
                        {{- 'sections.cart.headings.quantity' | t -}}
                      </th>
                      <th class="body-small cart-items-price" colspan="2" scope="col">
                        {{- 'sections.cart.headings.total' | t -}}
                      </th>
                    </tr>
                  </thead>

                  <tbody>
                    {%- for item in cart.items -%} 
{% liquid
  assign collections = ''
  for collection in item.product.collections
      assign collections = collections | append: collection.id | append: ','
  endfor
%}
                      <tr class="cart-item" id="CartItem-{{ item.index | plus: 1 }}" data-foxkit-product-id={{ item.product.id }} data-foxkit-collections="{{ collections }}">
                        <td class="cart-item__media">
                          {% liquid
                            case settings.card_image_ratio
                              when 'landscape'
                                assign ratio = '4/3'
                                assign settings_aspect_ratio = 1.33
                              when 'portrait'
                                assign ratio = '3/4'
                                assign settings_aspect_ratio = 0.75
                              when 'square'
                                assign ratio = '1/1'
                                assign settings_aspect_ratio = 1
                            endcase

                            assign aspect_ratio = ratio | split: '/'
                            assign temp = aspect_ratio[0] | append: '.0'
                            assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
                          %}
                          <div
                            class="cart-item__media-wrapper"
                            style="padding-bottom: {{ padding_bottom }}%;"
                          >
                            <a
                              href="{{ item.url }}"
                              class="cart-item__link focus-inset"
                              aria-label="{{ 'accessibility.product_link' | t }}"
                            ></a>
                            {%- if item.image -%}
                              {% liquid
                                assign calc_ratio = 1
                                if settings.card_image_fit == 'cover' and item.image.aspect_ratio > settings_aspect_ratio
                                  assign calc_ratio = item.image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
                                endif
                              %}
                              {%- capture img_sizes -%}
                                calc({{ calc_ratio }} * 60px)
                              {%- endcapture -%}
                              {%- capture image_styles -%}
                                object-fit: {{ settings.card_image_fit }};
                              {%- endcapture -%}
                              {{
                                item.image
                                | image_url: width: item.image.width
                                | image_tag:
                                  loading: 'lazy',
                                  widths: '60, 120, 180, 240, 300, 600, 900, 1200, 1500, 1800, 2000',
                                  sizes: img_sizes,
                                  class: 'cart-item__image',
                                  style: image_styles
                              }}
                            {%- else -%}
                              {{ 'image' | placeholder_svg_tag: 'placeholder-svg cart-item__image' }}
                            {%- endif -%}
                          </div>
                        </td>

                        <td class="cart-item__details">
                          {%- if section.settings.show_vendor -%}
                            <div class="cart-item__vendor body-xs">
                              {%- if settings.enable_vendor_link -%}
                                {{- item.product.vendor | link_to_vendor: class: 'focus-inset' -}}
                              {%- else -%}
                                {{- item.product.vendor -}}
                              {%- endif -%}
                            </div>
                          {%- endif -%}

                          <a href="{{ item.product.url }}" class="cart-item__name focus-inset">
                            <span class="link--hover-underline">{{- item.product.title | escape -}}</span>
                          </a>

                          {% comment %} render info lines (options, properties, discounts) {% endcomment %}
                          {%- if item.product.has_only_default_variant == false
                            or item.properties != blank
                            or item.selling_plan_allocation != blank
                            or item.line_level_discount_allocations != blank
                          -%}
                            <div class="cart-item__lines">
                              {% comment %} render options {% endcomment %}
                              {%- if item.product.has_only_default_variant == false -%}
                                <dl class="product-option__group">
                                  {%- for option in item.options_with_values -%}
                                    <div class="product-option body-xs">
                                      <dt>{{ option.name }}:</dt>
                                      <dd>{{ option.value }}</dd>
                                    </div>
                                  {%- endfor -%}
                                </dl>
                              {%- endif -%}

                              {% comment %} render properties {% endcomment %}
                              {%- if item.properties != blank -%}
                                <dl class="product-option__group">
                                  {%- for property in item.properties -%}
                                    {%- assign property_first_char = property.first | slice: 0 -%}
                                    {%- if property.last != blank and property_first_char != '_' -%}
                                      <div class="product-option body-xs">
                                        <dt>{{ property.first }}:</dt>
                                        <dd>
                                          {%- if property.last contains '/uploads/' -%}
                                            <a
                                              href="{{ property.last }}"
                                              class="link"
                                              target="_blank"
                                            >
                                              {{ property.last | split: '/' | last }}
                                            </a>
                                          {%- else -%}
                                            {{ property.last }}
                                          {%- endif -%}
                                        </dd>
                                      </div>
                                    {%- endif -%}
                                  {%- endfor -%}
                                </dl>
                              {%- endif -%}

                              {% comment %} render selling_plan_allocation {% endcomment %}
                              {%- if item.selling_plan_allocation != blank -%}
                                <p class="product-option body-xs">
                                  {{- item.selling_plan_allocation.selling_plan.name -}}
                                </p>
                              {%- endif -%}

                              {% comment %} render discounts {% endcomment %}
                              {%- if item.line_level_discount_allocations != blank -%}
                                <ul
                                  class="discounts list-unstyled"
                                  role="list"
                                  aria-label="{{ 'customer.order.discount' | t }}"
                                >
                                  {%- for discount in item.line_level_discount_allocations -%}
                                    {% liquid
                                      if settings.currency_code_enabled
                                        assign discount_total = discount.discount_application.total_allocated_amount | money_with_currency
                                      else
                                        assign discount_total = discount.discount_application.total_allocated_amount | money
                                      endif
                                    %}
                                    <li class="discounts__discount body-xs">
                                      {%- render 'icon-discount' -%}
                                      <span>{{ discount.discount_application.title }} -{{ discount_total }}</span>
                                    </li>
                                  {%- endfor -%}
                                </ul>
                              {%- endif -%}
                            </div>
                          {%- endif -%}

                          <p class="cart-item__error" id="Line-item-error-{{ item.index | plus: 1 }}">
                            <span class="cart-item__error-text body-xs"></span>
                            {% render 'icon-error' %}
                          </p>
                        </td>

                        <td class="cart-item__prices">
                          <span class="desktop-hidden body-xs">{{ 'sections.cart.headings.price' | t }}</span>
                          <div class="cart-item__price-wrapper">
                            {%- if item.original_price != item.final_price -%}
                              <dl class="cart-item__discounted-prices">
                                <dt class="visually-hidden">
                                  {{- 'products.product.price.sale_price' | t -}}
                                </dt>
                                <dd class="price price_sale">
                                  {%- if settings.currency_code_enabled -%}
                                    {{- item.final_price | money_with_currency -}}
                                  {%- else -%}
                                    {{- item.final_price | money -}}
                                  {%- endif -%}
                                </dd>
                                <dt class="visually-hidden">
                                  {{- 'products.product.price.regular_price' | t -}}
                                </dt>
                                <dd>
                                  <s class="cart-item__old-price price">
                                    {%- if settings.currency_code_enabled -%}
                                      {{- item.original_price | money_with_currency -}}
                                    {%- else -%}
                                      {{- item.original_price | money -}}
                                    {%- endif -%}
                                  </s>
                                </dd>
                              </dl>
                            {%- else -%}
                              <span class="price">
                                {%- if settings.currency_code_enabled -%}
                                  {{- item.original_price | money_with_currency -}}
                                {%- else -%}
                                  {{- item.original_price | money -}}
                                {%- endif -%}
                              </span>
                            {%- endif -%}
                          </div>
                        </td>

                        <td class="cart-item__quantity">
                          <label class="desktop-hidden tablet-hidden body-xs" for="Quantity-{{ item.index | plus: 1 }}">
                            {{- 'products.product.quantity.label' | t -}}
                          </label>
                          <quantity-input class="quantity">
                            <button class="quantity__button no-js-hidden focus-inset" name="minus" type="button">
                              <span class="visually-hidden">
                                {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
                              </span>
                              {% render 'icon-minus' %}
                            </button>
                            <input
                              class="quantity__input focus-inset"
                              type="number"
                              name="updates[]"
                              value="{{ item.quantity }}"
                              min="0"
                              aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                              id="Quantity-{{ item.index | plus: 1 }}"
                              data-index="{{ item.index | plus: 1 }}"
                            >
                            <button class="quantity__button no-js-hidden focus-inset" name="plus" type="button">
                              <span class="visually-hidden">
                                {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
                              </span>
                              {% render 'icon-plus' %}
                            </button>
                          </quantity-input>
                        </td>

                        <td class="cart-item__totals">
                          <span class="desktop-hidden body-xs">{{- 'sections.cart.headings.total' | t -}}</span>

                          <div class="cart-item__price-wrapper">
                            {%- if item.original_line_price != item.final_line_price -%}
                              <dl class="cart-item__discounted-prices">
                                <dt class="visually-hidden">
                                  {{- 'products.product.price.sale_price' | t -}}
                                </dt>
                                <dd class="price price_sale">
                                  {%- if settings.currency_code_enabled -%}
                                    {{- item.final_line_price | money_with_currency -}}
                                  {%- else -%}
                                    {{- item.final_line_price | money -}}
                                  {%- endif -%}
                                </dd>
                                <dt class="visually-hidden">
                                  {{- 'products.product.price.regular_price' | t -}}
                                </dt>
                                <dd>
                                  <s class="cart-item__old-price price">
                                    {%- if settings.currency_code_enabled -%}
                                      {{- item.original_line_price | money_with_currency -}}
                                    {%- else -%}
                                      {{- item.original_line_price | money -}}
                                    {%- endif -%}
                                  </s>
                                </dd>
                              </dl>
                            {%- else -%}
                              <span class="price">
                                {%- if settings.currency_code_enabled -%}
                                  {{- item.original_line_price | money_with_currency -}}
                                {%- else -%}
                                  {{- item.original_line_price | money -}}
                                {%- endif -%}
                              </span>
                            {%- endif -%}

                            {%- if item.variant.available and item.unit_price_measurement -%}
                              <div class="unit-price">
                                <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                                {%- if settings.currency_code_enabled -%}
                                  {{- item.variant.unit_price | money_with_currency -}}
                                {%- else -%}
                                  {{- item.variant.unit_price | money -}}
                                {%- endif -%}
                                <span aria-hidden="true">/</span>
                                <span class="visually-hidden"
                                  >&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span
                                >
                                {%- if item.variant.unit_price_measurement.reference_value != 1 -%}
                                  {{- item.variant.unit_price_measurement.reference_value -}}
                                {%- endif -%}
                                {{- item.variant.unit_price_measurement.reference_unit -}}
                              </div>
                            {%- endif -%}
                          </div>

                          <div class="loading-overlay hidden">
                            <div class="loading-overlay__spinner">
                              {% render 'icon-loading-circle' %}
                            </div>
                          </div>
                        </td>

                        <td class="cart-item__remove">
                          <cart-remove-button
                            id="Remove-{{ item.index | plus: 1 }}"
                            data-index="{{ item.index | plus: 1 }}"
                          >
                            <a
                              class="button button--unstyled focus-inset"
                              href="{{ item.url_to_remove }}"
                              aria-label="{{ 'general.cart.remove_product' | t: title: item.title }}"
                            >
                              {% render 'icon-remove' %}
                              <span class="underlined-link">{{- 'sections.cart.remove_button_label' | t -}}</span>
                            </a>
                          </cart-remove-button>
                        </td>
                      </tr>
                    {%- endfor -%}
                  </tbody>
                </table>
              {%- endif -%}
            </div>
          </div>

          <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
          <p
            class="visually-hidden"
            id="shopping-cart-line-item-status"
            aria-live="polite"
            aria-hidden="true"
            role="status"
          >
            {{- 'accessibility.loading' | t -}}
          </p>
        </form>
      </cart-items>

      <div class="{% if cart == empty %} is-empty{% endif %}" id="main-cart-footer" data-id="{{ section.id }}">
        <div class="cart__footer">
          <div class="cart__blocks">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when '@app' -%}
                  <div class="cart__apps" {{ block.shopify_attributes }}>
                    {% render block %}
                  </div>
                {%- when 'subtotal' -%}
                  <div class="cart__subtotal js-contents-totals" {{ block.shopify_attributes }}>
                    <div class="totals__wrapper">
                      <div class="totals">
                        <h4 class="totals__subtotal h4">
                          {{- 'sections.cart.subtotal' | t -}}
                        </h4>
                        <div class="totals__subtotal-value">
                          <span class="h5">
                            {%- if block.settings.currency_code_enabled -%}
                              {{- cart.total_price | money_with_currency -}}
                            {%- else -%}
                              {{- cart.total_price | money -}}
                            {%- endif -%}
                          </span>

                          <div class="loading-overlay hidden">
                            <div class="loading-overlay__spinner">
                              {% render 'icon-loading-circle' %}
                            </div>
                          </div>
                        </div>
                      </div>

                      {%- if cart.cart_level_discount_applications.size > 0 -%}
                        <div class="discounts__wrapper">
                          <ul
                            class="discounts list-unstyled"
                            role="list"
                            aria-label="{{ 'customer.order.discount' | t }}"
                          >
                            {%- for discount in cart.cart_level_discount_applications -%}
                              <li class="discounts__discount">
                                <span class="discounts__discount-label body-small">
                                  {%- render 'icon-discount' -%}
                                  {{ discount.title }}
                                </span>
                                <span class="discounts__discount-value body-small">
                                  -
                                  {%- if settings.currency_code_enabled -%}
                                    {{ discount.total_allocated_amount | money_with_currency }}
                                  {%- else -%}
                                    {{ discount.total_allocated_amount | money }}
                                  {%- endif -%}
                                </span>
                              </li>
                            {%- endfor -%}
                          </ul>
                        </div>
                      {%- endif -%}
                    </div>

                    {%- if block.settings.enable_tax_info -%}
                      <small class="tax-note body-small richtext-link-inside">
                        {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
                          {{-
                            'sections.cart.taxes_included_and_shipping_policy_html'
                            | t: link: shop.shipping_policy.url
                          -}}
                        {%- elsif cart.taxes_included -%}
                          {{- 'sections.cart.taxes_included_but_shipping_at_checkout' | t -}}
                        {%- elsif shop.shipping_policy.body != blank -%}
                          {{-
                            'sections.cart.taxes_and_shipping_policy_at_checkout_html'
                            | t: link: shop.shipping_policy.url
                          -}}
                        {%- else -%}
                          {{- 'sections.cart.taxes_and_shipping_at_checkout' | t -}}
                        {%- endif -%}
                      </small>
                    {%- endif -%}
                  </div>
                {%- when 'cart_note' -%}
                  <div class="cart__note" {{ block.shopify_attributes }}>
                    <span class="cart__note-heading body-small">{{- 'sections.cart.note_title' | t -}}</span>
                    <cart-note class="field">
                      <label for="Cart-note" class="visually-hidden">
                        {{- 'sections.cart.note_title' | t -}}
                      </label>
                      <textarea
                        class="cart__note-input field__input"
                        name="note"
                        dir="ltr"
                        id="Cart-note"
                        placeholder="{{- 'sections.cart.note_placeholder' | t -}}"
                      >{{ cart.note }}</textarea>

                      <span class="cart__note-loading">
                        {% render 'icon-loading-circle' %}
                      </span>
                      <span class="cart__note-success">
                        {% render 'icon-success' %}
                      </span>
                    </cart-note>
                  </div>
                {%- when 'cart_promo_code' -%}
                  <div
                    class="cart__promo-code cart__promo-code--display-{{ block.settings.display_type }}"
                    {{ block.shopify_attributes }}
                  >
                    <div class="cart-promo-code">
                      {%- if block.settings.promo_text != blank -%}
                        <div class="cart-promo-code__text body-large">
                          {{- block.settings.promo_text | newline_to_br -}}
                        </div>
                      {%- endif -%}
                      <div class="cart-promo-code__form">
                        <div class="cart-promo-code__input">
                          {{- block.settings.promocode -}}
                        </div>
                        <div class="cart-promo-code__copy">
                          {% render 'button',
                            btn_style: block.settings.promo_button_style,
                            copy: true,
                            promocode: block.settings.promocode,
                            class: 'promocode-button-copy'
                          %}
                          <span class="code-copy-success body-small">
                            {{ 'sections.button.copy_success' | t }}
                          </span>
                          <span class="code-copy-error">
                            {{ 'sections.button.copy_failure' | t }}
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>

                {%- when 'cart_shipping_slider' -%}
                  <div
                    id="main-cart-shipping"
                    data-id="{{ section.id }}"
                    class="main-cart-shipping no-js-hidden"
                    {{ block.shopify_attributes }}
                  >
                    <div class="js-contents-shipping">
                      {% render 'cart-shipping-slider', cart: cart %}
                    </div>
                  </div>
                {%- when 'cart_buttons' -%}
                  <div class="cart__ctas" {{ block.shopify_attributes }}>
                    <noscript>
                      <button type="submit" class="cart__update-button button button--primary focus-inset" form="cart">
                        <div class="button__content">
                          <span class="button__label" data-label="{{- 'general.cart.update' | t -}}">
                            {{- 'general.cart.update' | t -}}
                          </span>
                        </div>
                      </button>
                    </noscript>

                    <button
                      type="submit"
                      class="cart__checkout-button button button--primary focus-inset"
                      name="checkout"
                      {% if cart == empty %}
                        disabled
                      {% endif %}
                      form="cart"
                    >
                      <div class="button__content">
                        <span class="button__label" data-label="{{- 'general.cart.checkout' | t -}}">
                          {{- 'general.cart.checkout' | t -}}
                        </span>
                      </div>
                    </button>

                    {%- if additional_checkout_buttons -%}
                      <div class="cart__footer-dynamic-checkout">
                        <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
                          {{ content_for_additional_checkout_buttons }}
                        </div>
                      </div>
                    {%- endif -%}
                  </div>
              {%- endcase -%}
            {%- endfor -%}

            {%- if section.settings.show_button_empty and section.settings.button_label_empty != blank -%}
              {% liquid
                assign button_link = routes.collections_url | sort_by: 'best-selling'
                if section.settings.button_link_empty != blank
                  assign button_link = section.settings.button_link_empty
                endif
              %}

              {% render 'button',
                btn_label: section.settings.button_label_empty,
                btn_style: 'primary',
                btn_link: button_link,
                class: 'cart__empty-button'
              %}
            {%- endif -%}
          </div>
        </div>
        <div class="cart-errors" id="cart-errors"></div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "class": "section-cart-items",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "t:sections.main-cart-items.settings.show_vendor.label"
    },
    {
      "type": "url",
      "id": "button_link_continue",
      "label": "t:sections.main-cart-items.settings.button_link_continue.label",
      "info": "t:sections.main-cart-items.settings.button_link_continue.info"
    },
    {
      "type": "header",
      "content": "t:sections.main-cart-items.settings.header__empty.content"
    },
    {
      "type": "text",
      "id": "title_empty",
      "label": "t:sections.all.heading.label",
      "info": "t:sections.main-cart-items.settings.title_empty.info",
      "default": "t:sections.main-cart-items.settings.title_empty.default"
    },
    {
