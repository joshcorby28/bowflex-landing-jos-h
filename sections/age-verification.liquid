<div
  class="age-verification popup color-{{ section.settings.color_scheme }} background"
  data-exit-animation="popupExitFade"
  data-body-scroll-disable="true"
  data-mobile-disable="false"
  data-open-trigger="none"
  data-id="{{ section.id }}"
  data-limit-display="1"
  data-limit-lifetime="30"
>
  <div class="age-verification__wrapper popup-wrap">
    <div class="age-verification__content">
      <div class="age-verification__question show">
        {%- if section.settings.heading -%}
          <{{ section.settings.heading_level | default: 'h2' }} class="popup-heading age-verification__heading {{ section.settings.heading_size }}">
            {{- section.settings.heading -}}
          </{{ section.settings.heading_level | default: 'h2' }}>
        {%- endif -%}
        {%- if section.settings.text -%}
          <div class="popup-text rte">
            {{- section.settings.text -}}
          </div>
        {%- endif -%}
        <div class="age-verification__buttons">
          <button class="button button--tertiary age-verification__button-no focus-inset">
            <div class="button__content">
              <span class="button__label" data-label="{{- section.settings.button_label_no -}}">
                {{- section.settings.button_label_no -}}
              </span>
            </div>
          </button>
          <button class="button button--primary age-verification__popup-close focus-inset">
            <div class="button__content">
              <span class="button__label" data-label="{{- section.settings.button_label_yes -}}">
                {{- section.settings.button_label_yes -}}
              </span>
            </div>
          </button>
        </div>
      </div>

      <div class="age-verification__declined">
        {%- if section.settings.heading_declined -%}
          <{{ section.settings.heading_level | default: 'h2' }} class="popup-heading age-verification__heading {{ section.settings.heading_size }}">
            {{- section.settings.heading_declined -}}
          </{{ section.settings.heading_level | default: 'h2' }}>
        {%- endif -%}
        {%- if section.settings.text_declined -%}
          <div class="popup-text rte">
            {{- section.settings.text_declined -}}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.overlay-group.age-verification.name",
  "class": "age-verification-section",
  "limit": 1,
  "enabled_on": {
    "groups": ["custom.overlay"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "header",
      "content": "t:sections.overlay-group.age-verification.settings.header_1.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.overlay-group.age-verification.settings.heading.label",
      "default": "t:sections.overlay-group.age-verification.settings.heading.default"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_level",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_level.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_level.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_level.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_level.label"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.overlay-group.age-verification.settings.text.label",
      "default": "t:sections.overlay-group.age-verification.settings.text.default"
    },
    {
      "type": "text",
      "id": "button_label_no",
      "label": "t:sections.overlay-group.age-verification.settings.button_label_no.label",
      "default": "t:sections.overlay-group.age-verification.settings.button_label_no.default"
    },
    {
      "type": "text",
      "id": "button_label_yes",
      "label": "t:sections.overlay-group.age-verification.settings.button_label_yes.label",
      "default": "t:sections.overlay-group.age-verification.settings.button_label_yes.default"
    },
    {
      "type": "header",
      "content": "t:sections.overlay-group.age-verification.settings.header_2.content"
    },
    {
      "type": "text",
      "id": "heading_declined",
      "label": "t:sections.overlay-group.age-verification.settings.heading.label",
      "default": "t:sections.overlay-group.age-verification.settings.heading_declined.default"
    },
    {
      "type": "richtext",
      "id": "text_declined",
      "label": "t:sections.overlay-group.age-verification.settings.text.label",
      "default": "t:sections.overlay-group.age-verification.settings.text_declined.default"
    }
  ],
  "presets": [
    {
      "name": "t:sections.overlay-group.age-verification.name",
      "category": "t:sections.categories.popups"
    }
  ]
}
{% endschema %}
