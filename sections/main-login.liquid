{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'section-margin' %}
  {% render 'section-padding' %}
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div
    class="customer login container"
  >
    <div class="login__wrapper">
      <div class="login__col">
        <div class="login__reset" id="recover">
          <div class="page-header">
            <h2 class="title--page login__title h3">
              {{ 'customer.recover_password.title' | t }}
            </h2>
          </div>
          <div class="login__desc body-large">
            <span>{{ 'customer.recover_password.subtext' | t }}</span>
          </div>
          
          {%- form 'recover_customer_password' -%}
            {% assign recover_success = form.posted_successfully? %}
            <div class="field field--email">
              <input
                type="email"
                value=""
                name="email"
                id="RecoverEmail"
                dir="ltr"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                required
                {% if form.errors %}
                  aria-invalid="true"
                  aria-describedby="RecoverEmail-email-error"
                  autofocus
                {% endif %}
                placeholder="{{ 'customer.login_page.email_placeholder' | t }}"
              >
              <label for="RecoverEmail" class="h6">
                {{- 'customer.login_page.email' | t -}}
              </label>
              {%- if form.errors -%}
                <small id="RecoverEmail-email-error" class="form__message">
                  {{ form.errors.messages.form }}
                </small>
              {%- endif -%}
            </div>

            <div class="login__buttons">
              <button class="button button--primary focus-inset">
                <span class="button__label">
                  {{- 'customer.login_page.submit' | t -}}
                </span>
              </button>

              <a
                class="button button--tertiary anchor focus-inset"
                href="#login"
              >
                <span class="button__label">
                  {{- 'customer.login_page.cancel' | t -}}
                </span>
              </a>
            </div>
          {%- endform -%}
        </div>

        <div class="login__form" id="login">
          <div class="page-header">
            <div class="page-header__inner">
              <h1 class="title--page login__title h3 active">
                {{ 'customer.login_page.title' | t }}
              </h1>
              <a
                href="{{ routes.account_register_url }}"
                class="title--page register__title h3 focus-inset"
              >
                <span>{{- 'customer.login_page.create_account' | t -}}</span>
              </a>
            </div>
          </div>
          <div class="login__desc body-large">
            {{- 'customer.login_page.description' | t -}}
          </div>
          {%- if recover_success == true -%}
            <p class="form__message form__message--success" tabindex="-1" autofocus>
              {{- 'customer.recover_password.success' | t -}}
            </p>
          {%- endif -%}
          {%- form 'customer_login', novalidate: 'novalidate' -%}
            <div class="field field--email login__field">
              <input
                type="email"
                name="customer[email]"
                class="field__input"
                id="CustomerEmail"
                dir="ltr"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                required
                {% if form.errors contains 'form' %}
                  aria-invalid="true"
                  aria-describedby="LoginForm-email-error"
                {% endif %}
                placeholder="{{ 'customer.login_page.email_placeholder' | t }}"
              >
              <label for="CustomerEmail" class="h6">
                {{- 'customer.login_page.email' | t -}}
              </label>
              {% unless template.name == 'register' %}
                {{ form.errors | default_errors }}
              {% endunless %}
            </div>

            {%- if form.password_needed -%}
              <div class="field field--pass login__field">
                <div class="button-pass-visibility">
                  {% render 'icon-eye' %}
                  {% render 'icon-eye-close' %}
                </div>
                <input
                  type="password"
                  value=""
                  name="customer[password]"
                  class="field__input"
                  id="CustomerPassword"
                  dir="ltr"
                  autocomplete="current-password"
                  placeholder="{{ 'customer.login_page.password_placeholder' | t }}"
                  {% if form.errors contains 'form' %}
                    aria-invalid="true"
                  {% endif %}
                  required
                >
                <label for="CustomerPassword" class="h6">
                  {{- 'customer.login_page.password' | t -}}
                </label>
                {% unless template.name == 'register' %}
                  {{ form.errors | default_errors }}
                {% endunless %}
              </div>
            {%- endif -%}

            <a
              href="#recover"
              class="anchor login__recover link button--underline focus-inset"
            >
              <span>{{- 'customer.login_page.forgot_password' | t -}}</span>
            </a>
            
            <button class="button button--primary login__sign-in focus-inset">
              <div class="button__content">
                <span class="button__label" data-label="{{- 'customer.log_in' | t -}}">
                  {{- 'customer.sign_in' | t -}}
                </span>
              </div>
            </button>
          {%- endform -%}
        </div>

        {%- if shop.checkout.guest_login -%}
          <div class="login__guest">
            <div class="login__title h2">
              {{ 'customer.login_page.guest_title' | t }}
            </div>

            {%- form 'guest_login' -%}
              <button class="button button--primary focus-inset">
                <div class="button__content">
                  <span class="button__label" data-label="{{- 'customer.login_page.guest_continue' | t -}}">
                    {{- 'customer.login_page.guest_continue' | t -}}
                  </span>
                </div>
              </button>
            {%- endform -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  window.onload = () => {
    typeof PasswordViewer !== 'undefined' && new PasswordViewer();
  };
</script>

