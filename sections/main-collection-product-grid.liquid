{{ 'template-collection.css' | asset_url | stylesheet_tag: preload: true }}

{%- if settings.pagination_type == 'load_more' or settings.pagination_type == 'infinite_scroll' -%}
  <script src="{{ 'load-more.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{{ 'component-card.css' | asset_url | stylesheet_tag: preload: true }}

{%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
  {{ 'component-facets.css' | asset_url | stylesheet_tag: preload: true }}
  <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

{%- liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  if collection.url
    assign results_url = collection.url
  else
    assign terms = collection.terms | escape
    assign results_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
  endif

  assign filter_type = 'vertical'
-%}

<div class="section-{{ section.id }}-padding">
  <div class="container">
    <div
      id="CollectionWrapper"
      class="collection-wrapper collection-wrapper--{{ section.settings.columns }} collection-wrapper--{{ filter_type }}{% if section.settings.enable_default_open and filter_type == "vertical" %} active-filters{% endif %}"
    >
      {%- if collection.all_products_count > 0 -%}
        {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
          {% render 'facets',
            results: collection,
            enable_filtering: section.settings.enable_filtering,
            enable_sorting: section.settings.enable_sorting,
            filter_type: filter_type,
            enable_default_open: section.settings.enable_default_open,
            enable_default_collapsible: section.settings.enable_default_collapsible,
            image_filter_ratio: section.settings.image_filter_ratio,
            image_filter_fit: section.settings.image_filter_fit,
            image_filter_columns: section.settings.image_filter_columns,
            button_filters: section.settings.button_filters,
            enable_price_labels: section.settings.enable_price_labels
          %}
        {%- endif -%}
      {%- endif -%}

      <div
        id="ProductGridContainer"
        class="products-grid {% if section.settings.enable_default_open and filter_type == "vertical" %}{% else %}full-width{% endif %} {% if section.settings.enable_filtering == false or collection.all_products_count == 0 %} products-grid_no-filter{% endif %}"
        data-id="{{ section.id }}"
      >
        {%- if collection.all_products_count > 0 -%}
          {%- if section.settings.enable_filtering or section.settings.enable_sorting or section.settings.show_count -%}
            <div class="products-grid__top small-hide medium-hide">
              {%- if section.settings.enable_filtering -%}
                <button
                  type="button"
                  class="button button--unstyled facets-button-show no-js-hidden focus-inset"
                >
                  {% render 'icon-filter' %}
                  <span>{{- 'products.facets.show_filters' | t -}}</span>
                </button>

                <div class="active-facets active-facets-desktop">
                  <div class="active-facets__wrapper">
                    <facet-remove>
                      <a
                        href="{{ results_url }}"
                        class="active-facets__button-remove focus-inset"
                        aria-label="{{ 'products.facets.clear_all' | t }}"
                      >
                        <span>{{ 'products.facets.clear_all' | t }}</span>
                      </a>
                    </facet-remove>

                    {%- for filter in collection.filters -%}
                      {%- for value in filter.active_values -%}
                        <facet-remove>
                          <a
                            href="{{ value.url_to_remove }}"
                            class="active-facets__button focus-inset"
                            aria-label="{{ 'products.facets.clear_filter' | t | append: ":" | append: value.label | escape }}"
                          >
                            <span class="active-facets__button-inner">
                              <span>{{ value.label | escape }}</span>
                              {% render 'icon-close-small' %}
                            </span>
                            <span class="visually-hidden">{{ 'products.facets.clear_filter' | t }}</span>
                          </a>
                        </facet-remove>
                      {%- endfor -%}
                      {% if filter.type == 'price_range' %}
                        {%- if filter.min_value.value != null or filter.max_value.value != null -%}
                          <facet-remove>
                            <a
                              href="{{ filter.url_to_remove }}"
                              class="active-facets__button focus-inset"
                              aria-label="{{ 'products.facets.clear_filter' | t | append: ":" | append: filter.label | escape }}"
                            >
                              <span class="active-facets__button-inner">
                                <span>
                                  {%- if filter.min_value.value -%}
                                    {{ filter.min_value.value | money }}
                                  {%- else -%}
                                    {{ 0 | money }}
                                  {%- endif -%}
                                  —
                                  {% if filter.max_value.value %}
                                    {{ filter.max_value.value | money }}
                                  {% else -%}
                                    {{ filter.range_max | money }}
                                  {%- endif -%}
                                </span>
                                {% render 'icon-close-small' %}
                              </span>
                              <span class="visually-hidden">{{ 'products.facets.clear_filter' | t }}</span>
                            </a>
                          </facet-remove>
                        {%- endif -%}
                      {% endif %}
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
<h1>
  {{ collection.title }}
  {% if current_tags.size > 0 %}
    - {{ current_tags | join: ", " }}
  {% endif %}
</h1>

              {%- if section.settings.show_count and collection.all_products_count > 0 -%}
                <div class="products-grid__product-count" role="status">
                  <h2 class="products-grid__product-count-text body-small">
                    <span id="ProductCountDesktop">
                      {%- if collection.all_products_count and collection.products_count -%}
                        {%- if collection.products_count == collection.all_products_count -%}
                          {{- 'products.facets.product_count_simple' | t: count: collection.all_products_count -}}
                        {%- else -%}
                          {{-
                            'products.facets.product_count'
                            | t: product_count: collection.products_count, count: collection.all_products_count
                          -}}
                        {%- endif -%}
                      {%- else -%}
                        {{- 'templates.search.results' | t: terms: collection.terms, count: collection.results_count -}}
                      {%- endif -%}
                    </span>
                  </h2>
                </div>
              {%- endif -%}

              {%- if section.settings.enable_sorting -%}
                <facet-filters-form class="products-grid__top-sorting small-hide medium-hide no-js-hidden">
                  <form id="FacetSortForm" class="facets-sorting">
                    <label class="facets-sorting__label body-small" for="SortBy">
                      {{- 'products.facets.sort_by_label' | t -}}
                    </label>
                    <div class="facet-filters__field facets-sorting__field">
                      {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}

                      {% render 'custom-sort-select', sort_by: sort_by, sort_options: collection.sort_options %}
                    </div>
                  </form>
                </facet-filters-form>
                <noscript>
                  <facet-filters-form class="small-hide medium-hide">
                    <form id="FacetSortForm" class="facets-sorting">
                      <label class="facets-sorting__label body-small" for="SortBy">
                        {{- 'products.facets.sort_by_label' | t -}}
                      </label>
                      <div class="facet-filters__field facets-sorting__field">
                        {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                        <div class="select field">
                          <select
                            name="sort_by"
                            class="select__select focus-inset"
                            id="SortByNoScript"
                            aria-describedby="a11y-refresh-page-message"
                          >
                            {%- for option in collection.sort_options -%}
                              <option
                                value="{{ option.value | escape }}"
                                {% if option.value == sort_by %}
                                  selected="selected"
                                {% endif %}
                              >
                                {{ option.name | escape }}
                              </option>
                            {%- endfor -%}
                          </select>
                          {% render 'icon-caret' %}
                        </div>
                      </div>
                      <button type="submit" class="button focus-inset">
                        {{- 'products.facets.sort_button' | t -}}
                      </button>
                    </form>
                  </facet-filters-form>
                </noscript>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- paginate collection.products by section.settings.products_per_page -%}
          {%- if collection.products.size == 0 -%}
            <div class="collection collection-product collection--empty">
              <div class="loading-overlay no-js-hidden">
                <div class="loading-overlay__spinner">
                  {% render 'icon-loading' %}
                </div>
              </div>

              <div class="title-wrapper center title-wrapper-empty">
                <h2 class="title title--primary body-large">
                  {% if collection.all_products_count == 0 %}
                    {{ 'sections.collection_template.empty' | t -}}
                    <br>
                  {% else %}
                    {{ 'sections.collection_template.empty_results' | t -}}
                    <br>
                    {{
                      'sections.collection_template.results_use_fewer_filters_html'
                      | t: link: collection.url, class: 'underlined-link'
                    }}
                  {% endif %}
                </h2>
              </div>
            </div>
          {%- else -%}
            <div class="collection collection-product">
              <div class="loading-overlay no-js-hidden">
                <div class="loading-overlay__spinner">
                  {% render 'icon-loading' %}
                </div>
              </div>

              <ul
                id="product-grid"
                class="collection-product-list collection-product-list--{{ section.settings.columns }}-items collection-product-list--{{ section.settings.columns_mobile }}-mobile load-more-grid list-unstyled"
              >
                {%- for product in collection.products -%}
                  <li class="collection-product-list-item">
                    {% render 'product-card',
                      product_card_product: product,
                      show_vendor: section.settings.show_vendor,
                      show_desc: section.settings.show_desc,
                      show_iventory: section.settings.show_iventory,
                      columns: section.settings.columns,
                      mobile_column: section.settings.columns_mobile,
                      section_id: section.id,
                      add_id: forloop.index
                    %}
                  </li>
                {%- endfor -%}
              </ul>

              {%- if paginate.pages > 1 -%}
                {%- if settings.pagination_type == 'load_more' -%}
                  {% render 'load-more',
                    next_url: paginate.next.url,
                    count_pages: paginate.pages,
                    current_page: paginate.current_page
                  %}
                  <div class="js-hidden">
                    {% render 'pagination', paginate: paginate %}
                  </div>
                {%- elsif settings.pagination_type == 'infinite_scroll' -%}
                  {% render 'infinite-scroll',
                    next_url: paginate.next.url,
                    count_pages: paginate.pages,
                    current_page: paginate.current_page
                  %}
                  <div class="js-hidden">
                    {% render 'pagination', paginate: paginate %}
                  </div>
                {% else %}
                  {% render 'pagination', paginate: paginate %}
                {%- endif -%}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endpaginate -%}

        {% liquid
          assign has_product_tags = false
          if section.settings.show_product_tags and collection.all_tags != blank
            assign has_product_tags = true
          endif
        %}
        {%- if section.settings.addtitional_description != blank or has_product_tags -%}
          <div class="products-grid__bottom">
            {%- if section.settings.addtitional_description != blank -%}
              <div class="products-grid__description rte richtext-link-inside body-large">
                {{- section.settings.addtitional_description -}}
              </div>
            {%- endif -%}

            {%- if has_product_tags -%}
              <ul class="products-grid__tags list-unstyled">
                {% liquid
                  assign tags_limit = section.settings.tags_to_show
                  if section.settings.tags_to_show == 0
                    assign tags_limit = null
                  endif
                %}
                {%- for product_tag in collection.all_tags limit: tags_limit -%}
                  <li>
                    {% if current_tags contains product_tag %}
                      <span class="products-grid__tag products-grid__tag--active{% if section.settings.enable_tags_filter %} products-grid__tag--with-hover{% endif %}">
                        {% if section.settings.enable_tags_filter %}
                          {{- product_tag | link_to_remove_tag: product_tag -}}
                        {% else %}
                          <span>{{- product_tag -}}</span>
                        {% endif %}
                      </span>
                    {% else %}
                      <span class="products-grid__tag{% if section.settings.enable_tags_filter %} products-grid__tag--with-hover{% endif %}">
                        {% if section.settings.enable_tags_filter %}
                          {{- product_tag | link_to_add_tag: product_tag -}}
                        {% else %}
                          <span>{{- product_tag -}}</span>
                        {% endif %}
                      </span>
                    {% endif %}
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "tag": "section",
  "class": "collection-grid-section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 3,
      "max": 45,
      "step": 1,
      "default": 12,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 6,
      "label": "t:sections.main-collection-product-grid.settings.columns.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.main-collection-product-grid.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.show_count.label"
    },
    {
      "type": "checkbox",
      "id": "show_product_tags",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.show_product_tags.label",
      "info": "t:sections.main-collection-product-grid.settings.show_product_tags.info"
    },
    {
      "type": "range",
      "id": "tags_to_show",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 5,
      "label": "t:sections.main-collection-product-grid.settings.tags_to_show.label",
      "info": "t:sections.main-collection-product-grid.settings.tags_to_show.info",
      "visible_if": "{{ section.settings.show_product_tags }}"
    },
    {
      "type": "checkbox",
      "id": "enable_tags_filter",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.enable_tags_filter.label",
      "visible_if": "{{ section.settings.show_product_tags }}"
    },
    {
      "type": "richtext",
      "id": "addtitional_description",
      "label": "t:sections.main-collection-product-grid.settings.addtitional_description.label",
      "info": "t:sections.main-collection-product-grid.settings.addtitional_description.info"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__3.content"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_desc",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.show_desc.label",
      "info": "t:sections.main-collection-product-grid.settings.show_desc.info"
    },
    {
      "type": "checkbox",
      "id": "show_iventory",
      "default": true,
      "label": "t:sections.all.card.show_iventory.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__1.content"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_filtering.label",
      "info": "t:sections.main-collection-product-grid.settings.enable_filtering.info"
    },
    {
      "type": "checkbox",
      "id": "enable_default_open",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_default_open.label"
    },
    {
      "type": "checkbox",
      "id": "enable_default_collapsible",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.enable_default_collapsible.label"
    },
    {
      "type": "checkbox",
      "id": "enable_price_labels",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_price_labels.label"
    },
    {
      "type": "textarea",
      "id": "button_filters",
      "label": "t:sections.main-collection-product-grid.settings.button_filters.label",
      "info": "t:sections.main-collection-product-grid.settings.button_filters.info",
      "default": "t:sections.main-collection-product-grid.settings.button_filters.default"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_sorting.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.image_filter.content"
    },
    {
      "type": "select",
      "id": "image_filter_ratio",
      "options": [
        {
          "value": "3/2",
          "label": "t:sections.all.card.image_ratio_2.options__1.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.card.image_ratio_2.options__2.label"
        },
        {
          "value": "1/1",
          "label": "t:sections.all.card.image_ratio_2.options__3.label"
        }
      ],
      "default": "3/4",
      "label": "t:sections.all.card.image_ratio_2.label"
    },
    {
      "type": "select",
      "id": "image_filter_fit",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.all.card.image_fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.all.card.image_fit.options__2.label"
        }
      ],
      "default": "cover",
      "label": "t:sections.all.card.image_fit.label"
    },
    {
      "type": "range",
      "id": "image_filter_columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "t:sections.main-collection-product-grid.settings.image_filter_columns.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "l",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "l",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ]
}
{% endschema %}
