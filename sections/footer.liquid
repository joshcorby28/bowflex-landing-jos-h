{{- 'section-footer.css' | asset_url | stylesheet_tag -}}
{{- 'component-accordion.css' | asset_url | stylesheet_tag -}}
{{- 'component-list-menu.css' | asset_url | stylesheet_tag -}}
{{- 'component-list-payment.css' | asset_url | stylesheet_tag -}}
{{- 'component-list-social.css' | asset_url | stylesheet_tag -}}
{{- 'component-rte.css' | asset_url | stylesheet_tag -}}

<script src="{{ 'footer.js' | asset_url }}" defer="defer"></script>

{% style %}
  {% render 'section-margin' %}
{% endstyle %}

{%- if settings.social_twitter_link != blank
  or settings.social_facebook_link != blank
  or settings.social_pinterest_link != blank
  or settings.social_instagram_link != blank
  or settings.social_tiktok_link != blank
  or settings.social_tumblr_link != blank
  or settings.social_snapchat_link != blank
  or settings.social_youtube_link != blank
  or settings.social_vimeo_link != blank
-%}
  {% assign is_show_socials = true %}
{% else %}
  {% assign is_show_socials = false %}
{%- endif -%}

<footer class="footer color-{{ section.settings.color_scheme }} {% if section.settings.show_border %} footer_border {% endif %}">
  <div class="container">
    <div class="footer-main">
      {% comment %} ----- FOOTER BLOCKS ----- {% endcomment %}
      {%- if section.blocks.size > 0 -%}
        <div class="footer-blocks">
          {% assign blocks_of_type = section.blocks | where: 'type', 'link_list' %}
          {% assign block_count = blocks_of_type.size %}
          {% assign index = 1 %}
          <a href="#">Back to top</a>

          {%- for block in section.blocks -%}
            {%- case block.type -%}
                {% comment %} ----- FOOTER MENU BLOCK link_list ----- {% endcomment %}
              {%- when 'logo_info' -%}
                <div
                  class="footer-block footer-block--logo {% if block.settings.enable_border_left %}section_border_left{% endif %} {% if block.settings.enable_border_right %}section_border_right{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  <a
                    href="{{ routes.root_url }}"
                    class="footer__logo-link focus-inset"
                  >
                    {%- if block.settings.logo != blank -%}
                      {%- assign logo_height = block.settings.logo_width
                        | divided_by: block.settings.logo.aspect_ratio
                      -%}
                      {%- assign logo_alt = block.settings.logo.alt | default: shop.name | escape -%}
                      {%- assign image_size_2x = block.settings.logo_width | times: 2 -%}
                      {%- capture srcset -%}
                        {{ block.settings.logo | image_url: width: block.settings.logo_width }}, {{ block.settings.logo | image_url: width: image_size_2x }} 2x
                      {%- endcapture -%}
                      {{
                        block.settings.logo
                        | image_url: width: block.settings.logo_width
                        | image_tag:
                          class: 'footer-logo__image footer-logo__image--light-mode',
                          srcset: srcset,
                          height: logo_height,
                          width: block.settings.logo_width,
                          alt: logo_alt
                      }}
                      {%- if block.settings.logo_2 != blank -%}
                        {%- capture srcset -%}
                          {{ block.settings.logo_2 | image_url: width: block.settings.logo_width }}, {{ block.settings.logo_2 | image_url: width: image_size_2x }} 2x
                        {%- endcapture -%}
                        {{
                          block.settings.logo_2
                          | image_url: width: block.settings.logo_width
                          | image_tag:
                            class: 'footer-logo__image footer-logo__image--dark-mode',
                            srcset: srcset,
                            height: logo_height,
                            width: block.settings.logo_width,
                            alt: logo_alt
                        }}
                      {%- endif -%}
                    {%- elsif block.settings.logo_2 != blank -%}
                      {% if block.settings.logo == blank %}
                        <span class="h5 footer-logo__image link--hover-underline">{{ shop.name }}</span>
                      {% endif %}
                      {%- capture srcset -%}
                        {{ block.settings.logo_2 | image_url: width: block.settings.logo_width }}, {{ block.settings.logo_2 | image_url: width: image_size_2x }} 2x
                      {%- endcapture -%}
                      {{
                        block.settings.logo_2
                        | image_url: width: block.settings.logo_width
                        | image_tag:
                          class: 'footer-logo__image footer-logo__image--dark-mode',
                          srcset: srcset,
                          height: logo_height,
                          width: block.settings.logo_width,
                          alt: logo_alt
                      }}
                    {%- else -%}
                      <span class="h5 link--hover-underline">{{ shop.name }}</span>
                    {%- endif -%}
                  </a>
                  <div class="footer-logo__text richtext-link-inside">
                    {{- block.settings.description -}}
                  </div>
                </div>
              {%- when 'link_list' -%}
                {%- if block.type == 'link_list'
                  and block.settings.heading != blank
                  and block.settings.menu != blank
                -%}
                  <div class="accordion">
                    <details
                      {% if block.settings.default_open %}
                        open
                      {% endif %}
                    >
                      <summary>
                        <h2 class="accordion__heading h5">
                          {{- block.settings.heading | escape -}}
                        </h2>
                        {% render 'icon-caret' %}
                      </summary>
                      {%- if block.settings.menu != blank -%}
                        <ul class="footer-block__details-content list-unstyled">
                          {%- for link in block.settings.menu.links -%}
                            <li>
                              <a
                                href="{{ link.url }}"
                                {% if settings.links_blank and link.type == 'http_link' %}
                                  target="_blank"
                                {% endif %}
                                class="list-menu__item focus-inset list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                              >
                                <span>{{ link.title }}</span>
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </details>
                  </div>

                  <div
                    class="footer-block footer-menu-block {% if index == 1 %} footer-menu-block_first {% elsif index == block_count %} footer-menu-block_last {% endif %}"
                    {{ block.shopify_attributes }}
                  >
                    <h2 class="footer-menu-block__heading h5">
                      {{- block.settings.heading | escape -}}
                    </h2>

                    <ul class="footer-menu-block-list list-unstyled">
                      {%- for link in block.settings.menu.links -%}
                        <li class="footer-menu-block-list__item">
                          <a
                            href="{{ link.url }}"
                            {% if settings.links_blank and link.type == 'http_link' %}
                              target="_blank"
                            {% endif %}
                            class="footer-menu-block-list__link focus-inset {% if link.active %} footer-menu-block-list__link--active {% endif %} link--hover-underline-secondary"
                          >
                            <span>{{- link.title }}</span>
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>

                  {% assign index = index | plus: 1 %}
                {%- endif -%}
                {% comment %} ----- FOOTER SUBSCRIBE BLOCK subscribe ----- {% endcomment %}
              {% when 'subscribe' %}
                <div
                  class="footer-block footer-subscribe-block {% if block.settings.enable_border_left %}section_border_left{% endif %} {% if block.settings.enable_border_right %}section_border_right{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {% form 'customer', class: 'footer-subscribe-form' %}
                    {% if block.settings.heading != blank %}
                      <h2 class="footer-subscribe-form__heading h5">
                        {{- block.settings.heading -}}
                      </h2>
                    {% endif %}
                    <div class="footer-subscribe-form__inner">
                      <input
                        type="hidden"
                        name="contact[tags]"
                        value="newsletter"
                      >
                      <div class="footer-subscribe-form__input-wrapper">
                        <input
                          id="NewsletterForm--{{ section.id }}"
                          dir="ltr"
                          type="email"
                          name="contact[email]"
                          display:
                          block;
                          class="footer-subscribe-form__input"
                          value="{{ form.email }}"
                          aria-required="true"
                          autocorrect="off"
                          autocapitalize="off"
                          autocomplete="email"
                          pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
                          {% if form.errors %}
                            autofocus
                            aria-invalid="true"
                            aria-describedby="Newsletter-error--{{ section.id }}"
                          {% elsif form.posted_successfully? %}
                            aria-describedby="Newsletter-success--{{ section.id }}"
                          {% endif %}
                          placeholder="{{ 'newsletter.label' | t }}"
                          required
                        >
                        <label class="visually-hidden" for="NewsletterForm--{{ section.id }}">
                          {{- 'newsletter.label' | t -}}
                        </label>
                      </div>
                      <button
                        type="submit"
                        class="button button--{{ block.settings.button_style }}"
                      >
                        <span class="button__label">
                          {{ 'newsletter.button_label' | t }}
                        </span>
                      </button>
                    </div>
                    {% if block.settings.privacy_policy_consent and block.settings.privacy_policy_text != blank %}
                      <div class="footer-subscribe-form__checkbox field field--checkbox">
                        <input
                          type="checkbox"
                          name="subscribe_checkbox"
                          id="subscribe_checkbox"
                          required
                        >
                        <label
                          for="subscribe_checkbox"
                        >
                          <span class="field__checkbox">
                            {% render 'icon-checkmark' %}
                          </span>
                          <span class="field__label">
                            {{ block.settings.privacy_policy_text }}
                          </span>
                        </label>
                      </div>
                    {% endif %}
                    {% if block.settings.additional_text != blank %}
                      <div class="footer-subscribe-form__text body-small richtext-link-inside">
                        {{- block.settings.additional_text -}}
                      </div>
                    {% endif %}
                    {%- if form.errors -%}
                      <small
                        class="footer-subscribe-form__message footer-subscribe-form__message--error body-normal"
                        id="Newsletter-error--{{ section.id }}"
                      >
                        {%- render 'icon-error' -%}
                        {{- form.errors.translated_fields.email | capitalize }}
                        {{ form.errors.messages.email -}}
                      </small>
                    {%- endif -%}
                    {%- if form.posted_successfully? -%}
                      <small
                        class="footer-subscribe-form__message footer-subscribe-form__message--success"
                        id="Newsletter-success--{{ section.id }}"
                        tabindex="-1"
                        autofocus
                      >
                        {% render 'icon-success' -%}
                        {{- 'newsletter.success' | t }}
                      </small>
                    {%- endif -%}
                  {% endform %}

                  {% comment %} ----- FOOTER SOCIALS ----- {% endcomment %}
                  {%- if is_show_socials == true and block.settings.show_socials -%}
                    <div class="footer-socials">
                      {% if block.settings.social_media_label %}
                        <div class="footer-socials__label h5">
                          {{ block.settings.social_media_label }}
                        </div>
                      {% endif %}
                      <ul
                        class="footer-socials-list list-social list-unstyled"
                        role="list"
                      >
                        {%- if settings.social_twitter_link != blank -%}
                          <li class="footer-socials-list__item list-social__item">
                            <a
                              href="{{ settings.social_twitter_link }}"
                              class="link link--text list-social__link"
                              {%- if settings.links_blank -%}
                                target="_blank"
                              {%- endif -%}
                            >
                              {%- render 'icon-twitter' -%}
                              <span class="visually-hidden">
                                {{- 'general.social.links.twitter' | t -}}
                              </span>
                            </a>
                          </li>
                        {%- endif -%}
                        {%- if settings.social_facebook_link != blank -%}
                          <li class="footer-socials-list__item list-social__item">
                            <a
                              href="{{ settings.social_facebook_link }}"
                              class="link link--text list-social__link"
                              {%- if settings.links_blank -%}
                                target="_blank"
                              {%- endif -%}
                            >
                              {%- render 'icon-facebook' -%}
                              <span class="visually-hidden">
                                {{- 'general.social.links.facebook' | t -}}
                              </span>
                            </a>
                          </li>
                        {%- endif -%}
                        {%- if settings.social_pinterest_link != blank -%}
                          <li class="footer-socials-list__item list-social__item">
                            <a
                              href="{{ settings.social_pinterest_link }}"
                              class="link link--text list-social__link"
                              {%- if settings.links_blank -%}
                                target="_blank"
                              {%- endif -%}
                            >
                              {%- render 'icon-pinterest' -%}
                              <span class="visually-hidden">
                                {{- 'general.social.links.pinterest' | t -}}
                              </span>
                            </a>
                          </li>
                        {%- endif -%}
                        {%- if settings.social_instagram_link != blank -%}
                          <li class="footer-socials-list__item list-social__item">
                            <a
                              href="{{ settings.social_instagram_link }}"
                              class="link link--text list-social__link"
                              {%- if settings.links_blank -%}
                                target="_blank"
                              {%- endif -%}
                            >
                              {%- render 'icon-instagram' -%}
                              <span class="visually-hidden">
                                {{- 'general.social.links.instagram' | t -}}
                              </span>
                            </a>
                          </li>
                        {%- endif -%}
                        {%- if settings.social_tiktok_link != blank -%}
                          <li class="footer-socials-list__item list-social__item">
                            <a
                              href="{{ settings.social_tiktok_link }}"
                              class="link link--text list-social__link"
                              {%- if settings.links_blank -%}
                                target="_blank"
                              {%- endif -%}
                            >
                              {%- render 'icon-tiktok' -%}
                              <span class="visually-hidden">
                                {{- 'general.social.links.tiktok' | t -}}
                              </span>
                            </a>
                          </li>
                        {%- endif -%}
                        {%- if settings.social_tumblr_link != blank -%}
                          <li class="footer-socials-list__item list-social__item">
                            <a
                              href="{{ settings.social_tumblr_link }}"
                              class="link link--text list-social__link"
                              {%- if settings.links_blank -%}
                                target="_blank"
                              {%- endif -%}
                            >
                              {%- render 'icon-tumblr' -%}
                              <span class="visually-hidden">
                                {{- 'general.social.links.tumblr' | t -}}
                              </span>
                            </a>
                          </li>
                        {%- endif -%}
                        {%- if settings.social_snapchat_link != blank -%}
                          <li class="footer-socials-list__item list-social__item">
                            <a
                              href="{{ settings.social_snapchat_link }}"
                              class="link link--text list-social__link"
                              {%- if settings.links_blank -%}
                                target="_blank"
                              {%- endif -%}
                            >
                              {%- render 'icon-snapchat' -%}
                              <span class="visually-hidden">
                                {{- 'general.social.links.snapchat' | t -}}
                              </span>
                            </a>
                          </li>
                        {%- endif -%}
                        {%- if settings.social_youtube_link != blank -%}
                          <li class="footer-socials-list__item list-social__item">
                            <a
                              href="{{ settings.social_youtube_link }}"
                              class="link link--text list-social__link"
                              {%- if settings.links_blank -%}
                                target="_blank"
                              {%- endif -%}
                            >
                              {%- render 'icon-youtube' -%}
                              <span class="visually-hidden">
                                {{- 'general.social.links.youtube' | t -}}
                              </span>
                            </a>
                          </li>
                        {%- endif -%}
                        {%- if settings.social_vimeo_link != blank -%}
                          <li class="footer-socials-list__item list-social__item">
                            <a
                              href="{{ settings.social_vimeo_link }}"
                              class="link link--text list-social__link"
                              {%- if settings.links_blank -%}
                                target="_blank"
                              {%- endif -%}
                            >
                              {%- render 'icon-vimeo' -%}
                              <span class="visually-hidden">
                                {{- 'general.social.links.vimeo' | t -}}
                              </span>
                            </a>
                          </li>
                        {%- endif -%}
                      </ul>
                    </div>
                  {%- endif -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {% assign show_bottom = false %}
    {% if section.settings.enable_country_selector and localization.available_countries.size > 1 %}
      {% assign show_bottom = true %}
    {% elsif section.settings.enable_language_selector and localization.available_languages.size > 1 %}
      {% assign show_bottom = true %}
    {% elsif section.settings.payment_enable or section.settings.show_policy or section.settings.enable_copyright %}
      {% assign show_bottom = true %}
    {% elsif shop.features.follow_on_shop? and section.settings.enable_follow_on_shop %}
      {% assign show_bottom = true %}
    {% endif %}

    {% if show_bottom %}
      <div class="footer-bottom">
        <div class="footer-bottom-container">
          <div class="footer-bottom-container__main">
            {% comment %} ----- LOCALIZATION (LANGUAGE AND COUNTRY) ----- {% endcomment %}
            {%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
              <div class="footer-localization">
                {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
                  <noscript>
                    {%- form 'localization', id: 'FooterCountryFormNoScript', class: 'localization-form' -%}
                      <div class="localization-form__select">
                        <select
                          class="localization-selector link"
                          name="country_code"
                          aria-labelledby="FooterCountryLabelNoScript"
                        >
                          {%- for country in localization.available_countries -%}
                            <option
                              value="{{ country.iso_code }}"
                              {%- if country.iso_code == localization.country.iso_code %}
                                selected
                              {% endif %}
                            >
                              {{ country.name }} (
                              {{- country.currency.iso_code }}
                              {{ country.currency.symbol }})
                            </option>
                          {%- endfor -%}
                        </select>
                        {% render 'icon-caret' %}
                      </div>
                      <button
                        type="submit"
                        class="button button--primary focus-inset"
                      >
                        <span class="button__label">
                          {{ 'localization.update_country' | t }}
                        </span>
                      </button>
                    {%- endform -%}
                  </noscript>
                  <footer-localization-form>
                    {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
                      <div class="no-js-hidden">
                        <div class="disclosure">
                          <button
                            type="button"
                            class="footer-localization-button footer-localization-button_country disclosure__button localization-form__select localization-selector link link--text focus-inset"
                            aria-expanded="false"
                            aria-controls="FooterCountryList"
                          >
                            <div
                              style="display: inline"
                              class="currency-flag"
                              data-value="{{ localization.country.iso_code }}"
                              aria-hidden="true"
                            ></div>
                            <span class="currency-country">
                              {{ localization.country.name }} (
                              {{- localization.country.currency.iso_code }}
                              {{ localization.country.currency.symbol -}}
                              )
                            </span>
                            {% render 'icon-caret' -%}
                          </button>
                          <ul
                            id="FooterCountryList"
                            role="list"
                            class="disclosure__list color-background-1 list-unstyled"
                            hidden
                          >
                            {%- for country in localization.available_countries -%}
                              <li class="disclosure__item" tabindex="-1">
                                <a
                                  class="link link--text disclosure__link disclosure__link--flag {% if country.iso_code == localization.country.iso_code %} disclosure__link--active{% endif %} focus-inset"
                                  href="#"
                                  {% if country.iso_code == localization.country.iso_code %}
                                    aria-current="true"
                                  {% endif %}
                                  data-value="{{ country.iso_code }}"
                                >
                                  <span>
                                    {{ country.name }}
                                    (
                                    {{- country.currency.iso_code }}
                                    {{ country.currency.symbol -}}
                                    )
                                  </span>
                                  {% if country.iso_code == localization.country.iso_code %}
                                    {% render 'icon-checkmark' %}
                                  {% endif %}
                                </a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        </div>
                        <input
                          type="hidden"
                          name="country_code"
                          value="{{ localization.country.iso_code }}"
                        >
                      </div>
                    {%- endform -%}
                  </footer-localization-form>
                {%- endif -%}

                {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
                  <noscript>
                    {%- form 'localization', id: 'FooterLanguageFormNoScript', class: 'localization-form' -%}
                      <div class="localization-form__select">
                        <select
                          class="localization-selector link"
                          name="locale_code"
                          aria-labelledby="FooterLanguageLabelNoScript"
                        >
                          {%- for language in localization.available_languages -%}
                            <option
                              value="{{ language.iso_code }}"
                              lang="{{ language.iso_code }}"
                              {%- if language.iso_code == localization.language.iso_code %}
                                selected
                              {% endif %}
                            >
                              {{ language.endonym_name | capitalize }}
                            </option>
                          {%- endfor -%}
                        </select>
                        {% render 'icon-caret' %}
                      </div>
                      <button
                        type="submit"
                        class="button button--primary focus-inset"
                      >
                        <div class="button__content">
                          <span class="button__label" data-label="{{ 'localization.update_language' | t }}">
                            {{ 'localization.update_language' | t }}
                          </span>
                        </div>
                      </button>
                    {%- endform -%}
                  </noscript>
                  <footer-localization-form>
                    {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
                      <div class="no-js-hidden">
                        <div class="disclosure">
                          <button
                            type="button"
                            class="footer-localization-button disclosure__button localization-form__select localization-selector link link--text focus-inset"
                            aria-expanded="false"
                            aria-controls="FooterLanguageList"
                          >
                            <span class="value">
                              {{- localization.language.endonym_name | capitalize }}
                            </span>
                            {% render 'icon-caret' -%}
                          </button>
                          <ul
                            id="FooterLanguageList"
                            role="list"
                            class="disclosure__list color-background-1 list-unstyled"
                            hidden
                          >
                            {%- for language in localization.available_languages -%}
                              <li class="disclosure__item" tabindex="-1">
                                <a
                                  class="link link--text disclosure__link disclosure__link_language {% if language.iso_code == localization.language.iso_code %} disclosure__link--active{% endif %} focus-inset"
                                  href="#"
                                  hreflang="{{ language.iso_code }}"
                                  lang="{{ language.iso_code }}"
                                  {% if language.iso_code == localization.language.iso_code %}
                                    aria-current="true"
                                  {% endif %}
                                  data-value="{{ language.iso_code }}"
                                >
                                  <div class="disclosure__list-content">
                                    <span>
                                      {{ language.endonym_name | capitalize }}
                                    </span>
                                    <span class="disclosure__link-name body-small">
                                      {{ language.name | capitalize }}
                                    </span>
                                  </div>
                                  {% if language.iso_code == localization.language.iso_code %}
                                    {% render 'icon-checkmark' %}
                                  {% endif %}
                                </a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        </div>
                        <input
                          type="hidden"
                          name="locale_code"
                          value="{{ localization.language.iso_code }}"
                        >
                      </div>
                    {%- endform -%}
                  </footer-localization-form>
                {%- endif -%}
              </div>
            {%- endif -%}
            {% comment %} ----- PAYMENT METHODS ----- {% endcomment %}
            {%- if section.settings.payment_enable -%}
              <ul class="list-payment list-unstyled" role="list">
                {%- for type in shop.enabled_payment_types -%}
                  <li class="list-payment__item">
                    {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
            {% comment %} ----- POLICIES ----- {% endcomment %}
            {%- if section.settings.show_policy -%}
              <ul class="footer-policies list-unstyled">
                {%- for policy in shop.policies -%}
                  {%- if policy != blank -%}
                    <li class="footer-policies__item">
                      <a
                        href="{{ policy.url }}"
                        class="footer-policies__link focus-inset link--hover-underline-secondary body-small"
                      >
                        <span>{{ policy.title }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
          {% assign bottom = false %}
          {%- if section.settings.enable_copyright -%}
            {% assign bottom = true %}
          {%- elsif shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
            {% assign bottom = true %}
          {% endif %}

          {% if bottom == true %}
            <div class="footer-bottom-container__right">
              {% comment %} ----- FOLLOW ON SHOP ----- {% endcomment %}
              {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
                <div class="footer-follow-on-shop">
                  {{ shop | login_button: action: 'follow' }}
                </div>
              {%- endif -%}

              {% comment %} ----- COPYRIGHT ----- {% endcomment %}
              {%- if section.settings.enable_copyright -%}
                <div class="footer-copyright">
                  <span class="footer-copyright__content body-small richtext-link-inside">
                    &copy;
                    {% if section.settings.enable_copyright_date %}
                      {{ 'now' | date: '%Y' }}
                    {% endif %}
                    {{ shop.name | link_to: routes.root_url }}.
                  </span>
                  <span class="footer-copyright__content body-small richtext-link-inside">
                    {{- powered_by_link -}}
                  </span>
                </div>
              {%- endif -%}
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</footer>

