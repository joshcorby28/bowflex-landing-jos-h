{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'section-margin' %}
  {% render 'section-padding' %}
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="customer login register container">
    <div class="login__wrapper">
      <div class="login__col">
        <div class="login__form register__form">
          <div class="page-header">
            <div class="page-header__inner">
              <a
                href="{{ routes.account_login_url }}"
                class="title--page login__title h3 focus-inset"
              >
                <span>{{- 'customer.login_page.title' | t -}}</span>
              </a>
              <h1 class="title--page register__title h3 active">
                {{ 'customer.register.title' | t }}
              </h1>
            </div>
          </div>
          <div class="login__desc body-large">
            {{- 'customer.register.description' | t -}}
          </div>

          {%- form 'create_customer' -%}
            <div class="field">
              <input
                type="text"
                name="customer[first_name]"
                id="RegisterForm-FirstName"
                dir="ltr"
                {% if form.first_name %}
                  value="{{ form.first_name }}"
                {% endif %}
                autocomplete="given-name"
                placeholder="{{- 'customer.register.first_name_placeholder' | t -}}"
              >
              <label for="RegisterForm-FirstName" class="h6">
                {{- 'customer.register.first_name' | t -}}
              </label>
            </div>
            <div class="field">
              <input
                type="text"
                name="customer[last_name]"
                id="RegisterForm-LastName"
                dir="ltr"
                {% if form.last_name %}
                  value="{{ form.last_name }}"
                {% endif %}
                aria-required="true"
                autocomplete="family-name"
                placeholder="{{- 'customer.register.last_name_placeholder' | t -}}"
                required
              >
              <label for="RegisterForm-LastName" class="h6">
                {{- 'customer.register.last_name' | t -}}
              </label>
            </div>
            <div class="field field--email">
              <input
                type="email"
                name="customer[email]"
                id="RegisterForm-email"
                dir="ltr"
                {% if form.email %}
                  value="{{ form.email }}"
                {% endif %}
                spellcheck="false"
                autocapitalize="off"
                autocomplete="email"
                aria-required="true"
                {% if form.errors contains 'email' %}
                  aria-invalid="true"
                  aria-describedby="RegisterForm-email-error"
                {% endif %}
                placeholder="{{ 'customer.login_page.email_placeholder' | t }}"
                required
              >
              <label for="RegisterForm-email" class="h6">
                {{- 'customer.register.email' | t -}}
              </label>
              {%- if form.errors contains 'email' -%}
                <span
                  id="RegisterForm-email-error"
                  class="form__message body-small"
                >
                  {{ form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email }}.
                </span>
              {%- endif -%}
            </div>
            <div class="field field--pass">
              <div class="button-pass-visibility">
                {% render 'icon-eye' %}
                {% render 'icon-eye-close' %}
              </div>
              <input
                type="password"
                name="customer[password]"
                id="RegisterForm-password"
                dir="ltr"
                aria-required="true"
                placeholder="{{ 'customer.login_page.password_placeholder' | t }}"
                {% if form.errors contains 'password' %}
                  aria-invalid="true"
                  aria-describedby="RegisterForm-password-error"
                {% endif %}
                required
              >
              <label for="RegisterForm-password" class="h6">
                {{- 'customer.register.password' | t -}}
              </label>
              {%- if form.errors contains 'password' -%}
                <span
                  id="RegisterForm-password-error"
                  class="form__message body-small"
                >
                  {{ form.errors.translated_fields.password | capitalize }}
                  {{ form.errors.messages.password }}.
                </span>
              {%- endif -%}

              {%- if form.errors contains 'form' -%}
                <span
                  id="RegisterForm-email-error"
                  class="form__message body-small"
                >
                  {{ 'customer.login_page.customer_exist' | t }}
                </span>
              {%- endif -%}
            </div>

            {%- if section.settings.show_terms or section.settings.show_subscribe -%}
              <div class="field--terms">
                {% if section.settings.show_terms and shop.terms_of_service.url != blank %}
                  <div class="field field--checkbox">
                    <input
                      type="checkbox"
                      class="focus-inset"
                      name="terms"
                      id="Terms"
                      required
                    >
                    <label for="Terms">
                      <span class="field__checkbox">
                        {% render 'icon-checkmark' %}
                      </span>
                      <span class="field__label">
                        {{- 'customer.register.terms' | t }}
                        <a href="{{ shop.terms_of_service.url }}" target="_blank">
                          {{- 'customer.register.terms_link' | t -}}
                        </a>
                      </span>
                    </label>
                  </div>
                {% endif %}

                {% if section.settings.show_subscribe %}
                  <div class="field field--checkbox">
                    <input
                      type="checkbox"
                      name="customer[accepts_marketing]"
                      value="true"
                      id="RegisterFormSubscribeConsent"
                    >
                    <label for="RegisterFormSubscribeConsent">
                      <span class="field__checkbox">
                        {% render 'icon-checkmark' %}
                      </span>
                      <span class="field__label">
                        {{ 'customer.register.newsletter' | t }}
                      </span>
                    </label>
                  </div>
                {% endif %}

                <span
                  id="RegisterForm-terms-error"
                  class="form__message register__message-terms"
                >
                  {{- 'customer.register.terms_error' | t -}}
                </span>
              </div>
            {%- endif -%}

            <div class="form__bottom">
              <button
                id="RegisterSubmit"
                class="button button--primary register__create-acc focus-inset"
              >
                <div class="button__content">
                  <span class="button__label" data-label="{{- 'customer.register.submit' | t -}}">
                    {{- 'customer.register.submit' | t -}}
                  </span>
                </div>
              </button>

              {% if section.settings.text != blank %}
                <div class="form__text body-small richtext-link-inside">
                  {{ section.settings.text }}
                </div>
              {% endif %}
            </div>
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.onload = () => {
    typeof PasswordViewer !== 'undefined' && new PasswordViewer();

    const termsCheckbox = document.getElementById('Terms');
    const errorElement = document.getElementById('RegisterForm-terms-error');
    const submitButton = document.getElementById('RegisterSubmit');

    if (!termsCheckbox || !errorElement || !submitButton) return;

    submitButton.addEventListener('click', function (e) {
      if (termsCheckbox.checked) {
        errorElement.style.display = 'none';
      } else {
        errorElement.style.display = 'block';
        e.preventDefault();
      }
    });

    termsCheckbox.addEventListener('change', function (e) {
      if (errorElement.style.display !== 'block') return;

      if (e.target?.checked) {
        errorElement.style.display = 'none';
      }
    });
  };
</script>

