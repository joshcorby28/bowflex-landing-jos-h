    },
    {
      "type": "range",
      "id": "posts_per_row",
      "label": "t:sections.blog-posts.settings.posts_per_row.label",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "posts_count",
      "label": "t:sections.blog-posts.settings.posts_count.label",
      "min": 1,
      "max": 50,
      "step": 1,
