      "id": "ticker_text",
      "label": "t:sections.ticker.settings.text.label",
      "default": "t:sections.ticker.settings.text.default"
    },
    {
      "type": "select",
      "id": "text_size",
      "options": [
        {
          "value": "h4",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.ticker.settings.text_size.label"
    },
    {
      "type": "select",
      "id": "text_font",
      "options": [
        {
          "value": "heading",
          "label": "t:sections.ticker.settings.text_font.options__1.label"
        },
        {
          "value": "accent",
          "label": "t:sections.ticker.settings.text_font.options__2.label"
        },
        {
          "value": "body",
          "label": "t:sections.ticker.settings.text_font.options__3.label"
        }
      ],
      "default": "heading",
      "label": "t:sections.ticker.settings.text_font.label"
    },
    {
      "type": "checkbox",
      "id": "enable_image",
      "default": true,
      "label": "t:sections.ticker.settings.enable_image.label"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.all.image.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.card.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.card.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.card.image_ratio.options__3.label"
        }
      ],
      "default": "square",
      "label": "t:sections.all.card.image_ratio.label"
    },
    {
      "type": "range",
      "id": "ticker_speed",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 5,
      "label": "t:sections.ticker.settings.ticker_speed.label"
    },
    {
      "type": "checkbox",
      "id": "ticker_pause_hover",
      "default": true,
      "label": "t:sections.ticker.settings.ticker_pause_hover.label"
    },
    {
      "type": "select",
      "id": "ticker_direction",
      "options": [
        {
          "value": "left_to_right",
          "label": "t:sections.ticker.settings.ticker_direction.options__1.label"
        },
        {
          "value": "right_to_left",
          "label": "t:sections.ticker.settings.ticker_direction.options__2.label"
        }
      ],
      "default": "left_to_right",
      "label": "t:sections.ticker.settings.ticker_direction.label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.ticker.settings.ticker_link.label",
      "info": "t:sections.ticker.settings.ticker_link.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
