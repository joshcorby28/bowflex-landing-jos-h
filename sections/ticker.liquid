{{ 'section-ticker.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'section-margin' %}
  {% render 'section-padding' %}
{%- endstyle -%}

{%- if section.settings.link != blank -%}
  <a
    href="{{ section.settings.link }}"
    aria-label="{{ 'accessibility.link' | t }}"
    class="ticker__link"
    {% if settings.links_blank and section.settings.link.type == 'external_link' %}
      rel="nofollow"
      target="_blank"
    {% endif %}
  >
{%- endif -%}

<div class="ticker color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding{% if section.settings.ticker_pause_hover %} ticker--pause-hover{% endif %} ticker--{{ section.settings.ticker_direction }}">
  {% liquid
    assign has_image = false
    if section.settings.enable_image and section.settings.image != blank
      assign has_image = true
    endif

    assign target_ticker_line_width = 3000
    assign image_width = 80

    if section.settings.text_size == 'h2'
      assign char_width = 22
    elsif section.settings.text_size == 'h3'
      assign char_width = 18
    elsif section.settings.text_size == 'h4'
      assign char_width = 14
    else
      assign char_width = 28
    endif

    assign text_length = section.settings.ticker_text.size | default: 1
    assign text_width = text_length | times: char_width
    assign block_width = text_width
    if has_image
      assign block_width = text_width | plus: image_width
    endif

    assign ticker_elements_count = target_ticker_line_width | divided_by: block_width | at_least: 1 | plus: 2

    assign min_duration = 20
    assign max_duration = 100
    assign speed = section.settings.ticker_speed
    assign speed_range = 10
    assign duration_range = max_duration | minus: min_duration
    assign duration_temp = speed | times: duration_range | divided_by: speed_range
    assign duration = max_duration | minus: duration_temp

    assign image_loading = 'lazy'
    assign fetch_priority = 'auto'
    if section.index == 1
      assign image_loading = 'eager'
      assign fetch_priority = 'high'
    endif

    assign image_ratio = '1/1'
    assign settings_aspect_ratio = 1
    case section.settings.image_ratio
      when 'landscape'
        assign image_ratio = '3/2'
        assign settings_aspect_ratio = 1.5
      when 'portrait'
        assign image_ratio = '3/4'
        assign settings_aspect_ratio = 0.75
      when 'square'
        assign image_ratio = '1/1'
        assign settings_aspect_ratio = 1
    endcase

    assign aspect_ratio = image_ratio | split: '/'
    assign temp = aspect_ratio[0] | append: '.0'
    assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2

    assign calc_ratio = 1
    if has_image and section.settings.image.aspect_ratio > settings_aspect_ratio
      assign calc_ratio = section.settings.image.aspect_ratio | divided_by: settings_aspect_ratio | round: 2
    endif
  %}

  <div
    class="ticker__wrapper text_length-{{ text_length }} text_width-{{ text_width }} {{ block_width }}"
    style="--ticker-duration: {{ duration }}s;"
  >
    {%- capture image_sizes -%}
      (min-width: 990px) calc({{ calc_ratio }} * 80px), calc({{ calc_ratio }} * 60px)
    {%- endcapture -%}

    {%- capture ticker_line -%}
      <div class="ticker__block">
        {%- if has_image -%}
          <div class="ticker__image-wrapper" style="--padding_bottom: {{ padding_bottom }}%;">
            {{
              section.settings.image
              | image_url: width: section.settings.image.width
              | image_tag:
                loading: image_loading,
                class: 'ticker__image',
                fetchpriority: fetch_priority,
                sizes: image_sizes,
                widths: '80, 160, 240, 480, 960, 990, 1440'
            }}
          </div>
        {%- endif -%}

        {%- if section.settings.ticker_text != blank -%}
          <span class="ticker__text ticker__text--{{ section.settings.text_font }} {{ section.settings.text_size }}">
            {{- section.settings.ticker_text -}}
          </span>
        {%- endif -%}
      </div>
    {%- endcapture -%}

    <div
      class="ticker__line ticker__line--spacer"
      style="visibility: hidden;opacity: 0;position: static;"
    >
      {{ ticker_line }}
    </div>

    <div class="ticker__line{% if speed == 0 %} ticker__line--stopped{% endif %}">
      {%- for i in (1..ticker_elements_count) -%}
        {{ ticker_line }}
      {%- endfor -%}
    </div>

    <div class="ticker__line ticker__line--second{% if speed == 0 %} ticker__line--hidden{% endif %}">
      {%- for i in (1..ticker_elements_count) -%}
        {{ ticker_line }}
      {%- endfor -%}
    </div>
  </div>
</div>

{%- if section.settings.link != blank -%}
  </a>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.ticker.name",
  "class": "section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
