{{ 'section-popular-products.css' | asset_url | stylesheet_tag }}
{% if section.settings.card_layout == 'standard' %}
  {{ 'component-card.css' | asset_url | stylesheet_tag }}
{% else %}
  {{ 'component-card-horizontal.css' | asset_url | stylesheet_tag }}
{% endif %}

{% if section.settings.enable_slider or request.design_mode %}
  <script src="{{ 'popular-products.js' | asset_url }}" defer="defer"></script>
{% endif %}

{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{%- endstyle -%}

<div
  class="popular-products color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding {% if section.settings.enable_animation %} section-animation{% endif %}"
  data-columns="{{ section.settings.products_to_show }}"
  data-mobile-column="{% if section.settings.card_layout == 'standard' %}{{ section.settings.columns_mobile }}{% else %}1{% endif %}"
>
  {% liquid
    assign show_button = false
    if section.settings.button_show and section.settings.button_label != blank
      assign show_button = true
    endif

    assign has_navigation = false
    if section.settings.enable_slider
      if section.settings.product_list == blank
        assign has_navigation = true
      endif

      if section.settings.product_list.count > 1
        assign has_navigation = true
      endif

      assign has_navigation_mobile = false
      if section.settings.product_list == blank
        assign has_navigation_mobile = true
      endif

      if section.settings.card_layout == 'small' and section.settings.product_list.count > 1
        assign has_navigation_mobile = true
      endif

      if section.settings.card_layout == 'standard'
        if section.settings.columns_mobile == '1' and section.settings.product_list.count > 1
          assign has_navigation_mobile = true
        endif

        if section.settings.columns_mobile == '2' and section.settings.product_list.count > 2
          assign has_navigation_mobile = true
        endif
      endif
    endif
  %}

  {%- if section.settings.heading != blank or section.settings.description != blank or show_button or has_navigation -%}
    <div class="popular-products__top container">
      {%- if section.settings.heading != blank
        or section.settings.description != blank
        or show_button
        or has_navigation
      -%}
        <div class="popular-products__top-main{% if has_navigation_mobile %} popular-products__top-main--column-on-mobile{% endif %}">
          {%- if section.settings.heading != blank or section.settings.description != blank -%}
            <div class="popular-products__top-text">
              {% render 'heading-group', section: section, class: 'popular-products' %}
            </div>
          {%- endif -%}

          {%- if show_button or has_navigation -%}
            <div class="popular-products__top-right {% if show_button == false %} popular-products__top-right--hidden-mobile {% endif %}">
              {% if show_button %}
                <a
                  {% if section.settings.button_link %}
                    href="{{ section.settings.button_link }}"
                  {% else %}
                    disabled
                  {% endif %}
                  class="popular-products__button link--underline_arrow"
                >
                  <span>
                    {{ section.settings.button_label }}
                  </span>
                  {% render 'icon-btn-arrow' %}
                </a>
              {% endif %}

              {% if has_navigation %}
                <div class="popular-products__navigation popular-products__navigation--desktop slider-navigation-container no-js-hidden">
                  <button class="popular-products__navigation-button-prev swiper-button-prev">
                    {% render 'icon-btn-arrow' %}
                  </button>
                  <button class="popular-products__navigation-button-next swiper-button-next">
                    {% render 'icon-btn-arrow' %}
                  </button>
                </div>
              {% endif %}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {% if has_navigation_mobile %}
        <div class="popular-products__navigation popular-products__navigation--mobile slider-navigation-container slider-navigation-container--mobile no-js-hidden">
          <button class="popular-products__navigation-button-prev swiper-button-prev">
            {% render 'icon-btn-arrow' %}
          </button>
          <button class="popular-products__navigation-button-next swiper-button-next">
            {% render 'icon-btn-arrow' %}
          </button>
        </div>
      {% endif %}
    </div>
  {%- endif -%}

  <div class="popular-products__wrapper container content">
    <div class="popular-products__layout{% if section.settings.enable_slider %} js-popular-products-slider{% endif %}">
      <ul
        class="
          list-unstyled popular-products__list content grid--{{ section.settings.products_to_show }}
          {% if section.settings.enable_slider == false %}
            popular-products__grid {% if section.settings.card_layout == 'small' %} popular-products__grid_small{% endif %}
          {% endif %}
          {% if section.settings.enable_slider %} popular-products__slider{% endif %}
        "
      >
        {%- for product in section.settings.product_list -%}
          <li class="popular-products__item {% if section.settings.enable_animation %} column-animation {% endif %}">
            {% assign columns = section.settings.products_to_show %}

            {% if section.settings.card_layout == 'standard' %}
              {% render 'product-card',
                product_card_product: product,
                show_vendor: section.settings.show_vendor,
                show_desc: section.settings.show_desc,
                show_iventory: section.settings.show_iventory,
                columns: columns,
                mobile_column: section.settings.columns_mobile,
                section_id: section.id,
                color_scheme: section.settings.color_scheme
              %}
            {% else %}
              {% render 'product-card-horizontal',
                show_image: true,
                product_card_product: product,
                show_vendor: section.settings.show_vendor,
                color_scheme: section.settings.color_scheme
              %}
            {% endif %}
          </li>
        {%- else -%}
          {% liquid
            assign count_placeholders = section.settings.products_to_show
            if section.settings.card_layout == 'small'
              assign count_placeholders = section.settings.products_to_show | times: 2
            endif
          %}
          {%- for i in (1..count_placeholders) -%}
            {% assign placeholder_index = forloop.index | modulo: 4 | plus: 1 %}
            <li class="popular-products__item popular-products__item_placeholder {% if section.settings.enable_animation %} column-animation {% endif %}">
              {% if section.settings.card_layout == 'standard' %}
                {% render 'product-card-placeholder',
                  show_vendor: section.settings.show_vendor,
                  product_number: placeholder_index,
                  color_scheme: section.settings.color_scheme
                %}
              {% else %}
                {% render 'product-card-horizontal-placeholder',
                  show_image: true,
                  show_vendor: section.settings.show_vendor,
                  product_number: placeholder_index,
                  color_scheme: section.settings.color_scheme
                %}
              {% endif %}
            </li>
          {%- endfor -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.popular-products.name",
  "tag": "section",
  "class": "popular-products-section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["*"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.popular-products.settings.heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_level",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_level.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_level.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_level.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_level.label"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "t:sections.popular-products.settings.product_list.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 6,
      "label": "t:sections.popular-products.settings.products_to_show.label"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.all.enable_animation.label",
      "info": "t:sections.all.enable_animation.info",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "default": false,
      "label": "t:sections.popular-products.settings.enable_slider.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.card.header_card.content"
    },
    {
      "type": "select",
      "id": "card_layout",
      "label": "t:sections.popular-products.settings.card_layout.label",
      "options": [
        {
          "value": "standard",
          "label": "t:sections.popular-products.settings.card_layout.options__1.label"
        },
        {
          "value": "small",
          "label": "t:sections.popular-products.settings.card_layout.options__2.label"
        }
      ],
      "default": "standard"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": true,
      "label": "t:sections.all.card.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_desc",
      "default": false,
      "label": "t:sections.all.card.show_desc.label",
      "info": "t:sections.popular-products.settings.show_desc.info"
    },
    {
      "type": "checkbox",
      "id": "show_iventory",
      "default": true,
      "label": "t:sections.all.card.show_iventory.label",
      "info": "t:sections.popular-products.settings.show_iventory.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.mobile_options.header.content",
      "visible_if": "{{ section.settings.card_layout == 'standard' }}"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.all.mobile_options.columns.label",
      "info": "t:sections.popular-products.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.all.mobile_options.columns.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.all.mobile_options.columns.options__2.label"
        }
      ],
      "visible_if": "{{ section.settings.card_layout == 'standard' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.button.header_button.content"
    },
    {
      "type": "checkbox",
      "id": "button_show",
      "default": true,
      "label": "t:sections.all.button.button_show.label"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "t:sections.all.button.button_label.default_shop_all",
      "label": "t:sections.all.button.button_label.label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.all.button.button_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
    {
      "type": "select",
      "id": "padding_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "l",
      "label": "t:sections.all.section-padding.padding_top.label"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-padding.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-padding.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-padding.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-padding.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-padding.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-padding.options__6.label"
        }
      ],
      "default": "l",
      "label": "t:sections.all.section-padding.padding_bottom.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.popular-products.presets.name",
      "category": "t:sections.categories.products"
    }
  ]
}
{% endschema %}
