{{ 'component-card-horizontal.css' | asset_url | stylesheet_tag }}
{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}
{% if section.blocks.size > 1 and section.settings.slider %}
  <script src="{{ 'testimonials.js' | asset_url }}" defer="defer"></script>
{% endif %}

{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{%- endstyle -%}

<div class="testimonials color-{{ section.settings.color_scheme }} background section-{{ section.id }}-padding{% if section.blocks.size <= 1 %} testimonials--no-slider{% endif %}">
  <div class="container">
    {% assign nav = false %}
    {% if section.blocks.size > 0 and section.settings.slider %}
      {% assign nav = true %}
    {% endif %}
    {% if section.settings.heading != blank or section.settings.description != blank or nav %}
      <div class="testimonials__top">
        {%- if section.settings.heading != blank or section.settings.description != blank -%}
          <div class="testimonials__text">
            {% render 'heading-group', section: section, class: 'testimonials' %}
          </div>
        {%- endif -%}
        {%- if section.blocks.size > 0 and section.settings.slider -%}
          <div class="testimonials__navigation slider-navigation-container no-js-hidden {% if section.settings.card_layout == 'small' %} testimonials__navigation_small {% endif %}">
            <button class="testimonials__navigation-button-prev swiper-button-prev">
              {% render 'icon-btn-arrow' %}
            </button>
            <button class="testimonials__navigation-button-next swiper-button-next">
              {% render 'icon-btn-arrow' %}
            </button>
          </div>
        {%- endif -%}
      </div>
    {% endif %}
    <div
      class="testimonials__wrapper {% if section.settings.slider %} testimonials__swiper swiper {% endif %}"
      data-columns="{{ section.settings.columns }}"
    >
      <div class="testimonials__items testimonials__items--{{ section.settings.columns }} {% if section.settings.slider %} swiper-wrapper {% endif %}">
        {% for block in section.blocks %}
          <div
            class="testimonials__item {% if section.settings.slider %} swiper-slide {% endif %}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.product != blank %}
              {% render 'product-card-horizontal',
                show_image: block.settings.show_image,
                product_card_product: block.settings.product,
                show_vendor: block.settings.show_vendor,
                hide_swatches: true,
                show_arrow: false
              %}
            {% endif %}
            {% if block.settings.heading != blank or block.settings.slide_text != blank %}
              <div class="testimonials__item-content">
                {% if block.settings.heading != blank %}
                  <h3 class="testimonials__item-heading body-xl">
                    {{ block.settings.heading }}
                  </h3>
                {% endif %}
                {% if block.settings.slide_text != blank %}
                  <div class="testimonials__item-text body-large">
                    {{ block.settings.slide_text }}
                  </div>
                {% endif %}
              </div>
            {% endif %}
            <div class="testimonials__item-bottom">
              {% liquid
                assign decimal_part = blank
                if block.settings.rating_app and block.settings.product.metafields.reviews.rating != null
                  assign product_rating = block.settings.product.metafields.reviews.rating.value
                  assign product_rating_sides = product_rating | split: '.'
                  assign integer_part = product_rating_sides[0]
                  assign decimal_part = product_rating_sides[1] | slice: 0, 2
                  if decimal_part.size == 1
                    assign decimal_part = decimal_part | append: '0'
                  endif
                else
                  assign integer_part = block.settings.rating
                  assign product_rating = integer_part
                endif
              %}

              <div
                class="testimonials__item-rating"
                aria-label="{{ 'accessibility.rating' | t: rating: product_rating }}"
              >
                {% assign index_star = integer_part %}
                {% for i in (1..integer_part) %}
                  <span>
                    <svg width="18" height="17" viewBox="0 0 18 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M9 0L11.4281 5.65795L17.5595 6.21885L12.9288 10.2765L14.2901 16.2812L9 13.131L3.70993 16.2812L5.07119 10.2765L0.440492 6.21885L6.57186 5.65795L9 0Z" fill="currentColor"/>
                    </svg>
                  </span>
                {% endfor %}
                {% if decimal_part != blank %}
                  {% assign index_star = index_star | plus: 1 %}
                  <span>
                    {% liquid
                      assign width = 18 | times: decimal_part | divided_by: 100.0
                    %}
                    <svg width="18" height="17" viewBox="0 0 18 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <clipPath id="left-half-{{ block.id }}">
                          <rect x="0" y="0" width="{{ width }}" height="17"></rect>
                        </clipPath>
                      </defs>
                      <path d="M9 0L11.4281 5.65795L17.5595 6.21885L12.9288 10.2765L14.2901 16.2812L9 13.131L3.70993 16.2812L5.07119 10.2765L0.440492 6.21885L6.57186 5.65795L9 0Z" fill="currentColor" opacity="0.5"/>
                      <path d="M9 0L11.4281 5.65795L17.5595 6.21885L12.9288 10.2765L14.2901 16.2812L9 13.131L3.70993 16.2812L5.07119 10.2765L0.440492 6.21885L6.57186 5.65795L9 0Z" fill="currentColor" clip-path="url(#left-half-{{ block.id }})"/>
                    </svg>
                  </span>
                {% endif %}
                {% if index_star < 5 %}
                  {% assign index_star = index_star | plus: 1 %}
                  {% for i in (index_star..5) %}
                    <span>
                      <svg width="18" height="17" viewBox="0 0 18 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M9 0L11.4281 5.65795L17.5595 6.21885L12.9288 10.2765L14.2901 16.2812L9 13.131L3.70993 16.2812L5.07119 10.2765L0.440492 6.21885L6.57186 5.65795L9 0Z" fill="currentColor" opacity="0.5"/>
                      </svg>
                    </span>
                  {% endfor %}
                {% endif %}
              </div>
              {% if block.settings.slide_author %}
                <div class="testimonials__item-author">
                  {{ block.settings.slide_author }}
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
