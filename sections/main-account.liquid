{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'component-pagination.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

<div class="customer account">
  <div class="page-header">
    <div class="container">
      <div class="customer__top">
        <h1 class="main-page-title title--page h2">
          {{- 'customer.account.title' | t -}}
        </h1>
        <a
          class="account__log-out link--underline_arrow"
          href="{{ routes.account_logout_url }}"
        >
          <span class="account__log-out-label">
            {{ 'customer.log_out' | t }}
          </span>
          {% render 'icon-btn-arrow' %}
        </a>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="account__wrapper{% if customer.orders == blank or customer.orders.size == 0 %} account__wrapper--without-orders{% endif %}">
      <div class="account__left">
        {% paginate customer.orders by 20 %}
          {%- if customer.orders.size > 0 -%}
            <h2 class="account__subtitle h4">{{- 'customer.orders.title' | t -}}</h2>
            <div class="order-table">
              <div class="visually-hidden">{{ 'customer.orders.title' | t }}</div>
              <div class="row thead">
                <div id="ColumnOrder" class="h6">{{- 'customer.orders.order_number' | t -}}</div>
                <div id="ColumnDate" class="h6">{{- 'customer.orders.date' | t -}}</div>
                <div id="ColumnPayment" class="h6">{{- 'customer.orders.payment_status' | t -}}</div>
                <div id="ColumnFulfillment" class="h6">{{- 'customer.orders.fulfillment_status' | t -}}</div>
                <div id="ColumnTotal" class="h6">{{- 'customer.orders.total' | t -}}</div>
              </div>
              {%- for order in customer.orders -%}
                <a
                  class="row tbody body-large"
                  href="{{ order.customer_url }}"
                  aria-label="{{ 'customer.orders.order_number_link' | t: number: order.name }}"
                >
                  <span id="RowOrder" data-label="{{ 'customer.orders.order_number' | t }}">
                    {{ order.name }}
                  </span>
                  <span data-label="{{ 'customer.orders.date' | t }}">
                    {{ order.created_at | time_tag: format: 'date' }}
                  </span>
                  <span data-label="{{ 'customer.orders.payment_status' | t }}">
                    <span>
                      {{ order.financial_status_label }}
                    </span>
                  </span>
                  <span data-label="{{ 'customer.orders.fulfillment_status' | t }}">
                    {{ order.fulfillment_status_label }}
                  </span>
                  <span data-label="{{ 'customer.orders.total' | t }}" class="order-table__price">
                    {% if settings.currency_code_enabled %}
                      {{ order.total_price | money_with_currency }}
                    {% else %}
                      {{ order.total_price | money }}
                    {% endif %}
                  </span>
                </a>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="account-none">
              <h2 class="account__subtitle h4">{{- 'customer.orders.title' | t -}}</h2>
              <div class="account-none__wrapper">
                <div class="account-none__content">
                  {%- if section.settings.heading_orders != blank -%}
                    <h4 class="h5">{{ section.settings.heading_orders }}</h4>
                  {%- endif -%}
                  {%- if section.settings.text_orders != blank -%}
                    <div class="account-none__text">
                      {{ section.settings.text_orders | newline_to_br }}
                    </div>
                  {%- endif -%}
                </div>
                <a
                  href="{{ routes.collections_url | sort_by: 'best-selling' }}"
                  class="button button--primary account-none__button"
                >
                  <span class="button__label" data-label="{{- 'customer.account.account_button_shop' | t -}}">
                    {{- 'customer.account.account_button_shop' | t -}}
                  </span>
                </a>
              </div>
            </div>
          {%- endif -%}

          {%- if paginate.pages > 1 -%}
            {%- if settings.pagination_type == 'load_more' -%}
              {% render 'load-more',
                next_url: paginate.next.url,
                count_pages: paginate.pages,
                current_page: paginate.current_page
              %}
              <div class="js-hidden">
                {% render 'pagination', paginate: paginate %}
              </div>
            {%- elsif settings.pagination_type == 'infinite_scroll' -%}
              {% render 'infinite-scroll',
                next_url: paginate.next.url,
                count_pages: paginate.pages,
                current_page: paginate.current_page
              %}
              <div class="js-hidden">
                {% render 'pagination', paginate: paginate %}
              </div>
            {% else %}
              {% render 'pagination', paginate: paginate %}
            {%- endif -%}
          {%- endif -%}
        {% endpaginate %}
      </div>

      <div class="account__right">
        {%- if customer.addresses_count > 0 and customer.orders.size == 0 -%}
          <div class="account-none">
            <h2 class="account__subtitle h4">
              {{- 'customer.account.details' | t -}}
            </h2>
            <div class="account-none__wrapper">
              <ul class="account-address__list account-address__default list-unstyled">
                {%- if customer.default_address.name != blank -%}
                  <li class="account-address__item account-address__item-name h5">
                    {{- customer.default_address.name -}}
                  </li>
                {%- endif -%}

                {%- if customer.default_address != blank -%}
                  <li>
                    {%- if customer.default_address.street != blank -%}
                      <span class="account-address__item">{{- customer.default_address.street -}}</span>
                    {%- endif -%}

                    {%- if customer.default_address.company != blank -%}
                      <span class="account-address__item">{{- customer.default_address.company -}}</span>
                    {%- endif -%}

                    {%- if customer.default_address.city != blank -%}
                      <span class="account-address__item">{{- customer.default_address.city -}}</span>
                    {%- endif -%}

                    {%- if customer.default_address.zip != blank -%}
                      <span class="account-address__item">{{- customer.default_address.zip -}}</span>
                    {%- endif -%}

                    {%- if customer.default_address.phone != blank -%}
                      <span class="account-address__item">{{- customer.default_address.phone -}}</span>
                    {%- endif -%}

                    {%- if customer.default_address.country != blank -%}
                      <span class="account-address__item account-address__item-address">
                        {{- customer.default_address.country -}}
                      </span>
                    {%- endif -%}
                  </li>
                {%- endif -%}
              </ul>

              <a
                class="button button--primary account-address__link"
                href="{{ routes.account_addresses_url }}"
              >
                {% liquid
                  assign address_btn_count = customer.addresses_count
                  assign address_btn_label = 'customer.account.view_addresses' | t | append: ' (' | append: address_btn_count | append: ')'
                %}
                <span class="button__label" data-label="{{- address_btn_label -}}">
                  {{- address_btn_label -}}
                </span>
              </a>
            </div>
          </div>
        {%- elsif customer.addresses_count > 0 -%}
          <h2 class="account__subtitle h4">{{ 'customer.account.details' | t }}</h2>
          <div class="account-address">
            <ul class="account-address__list account-address__default list-unstyled">
              {%- if customer.default_address.name != blank -%}
                <li class="account-address__item account-address__item-name h5">
                  {{- customer.default_address.name -}}
                </li>
              {%- endif -%}

              {%- if customer.default_address != blank -%}
                <li>
                  {%- if customer.default_address.street != blank -%}
                    <span class="account-address__item">{{- customer.default_address.street -}}</span>
                  {%- endif -%}

                  {%- if customer.default_address.company != blank -%}
                    <span class="account-address__item">{{- customer.default_address.company -}}</span>
                  {%- endif -%}

                  {%- if customer.default_address.city != blank -%}
                    <span class="account-address__item">{{- customer.default_address.city -}}</span>
                  {%- endif -%}

                  {%- if customer.default_address.zip != blank -%}
                    <span class="account-address__item">{{- customer.default_address.zip -}}</span>
                  {%- endif -%}

                  {%- if customer.default_address.phone != blank -%}
                    <span class="account-address__item">{{- customer.default_address.phone -}}</span>
                  {%- endif -%}

                  {%- if customer.default_address.country != blank -%}
                    <span class="account-address__item account-address__item-address">
                      {{- customer.default_address.country -}}
                    </span>
                  {%- endif -%}
                </li>
              {%- endif -%}
            </ul>
            <a
              class="button button--primary account-address__link"
              href="{{ routes.account_addresses_url }}"
            >
              {% liquid
                assign address_btn_count = customer.addresses_count
                assign address_btn_label = 'customer.account.view_addresses' | t | append: ' (' | append: address_btn_count | append: ')'
              %}
              <span class="button__label" data-label="{{- address_btn_label -}}">
                {{- address_btn_label -}}
              </span>
            </a>
          </div>
        {%- else -%}
          <div class="account-none">
            <h2 class="account__subtitle h4">
              {{ 'customer.account.details' | t }}
            </h2>
            <div class="account-none__wrapper">
              <div class="account-none__content">
                {%- if section.settings.heading_addresses != blank -%}
                  <h4 class="h5">
                    {{- section.settings.heading_addresses -}}
                  </h4>
                {%- endif -%}
                {%- if section.settings.text_addresses != blank -%}
                  <div class="account-none__text">
                    {{ section.settings.text_addresses | newline_to_br }}
                  </div>
                {%- endif -%}
              </div>
              <a
                href="{{ routes.account_addresses_url }}"
                class="button button--primary account-none__button focus-inset"
              >
                <span class="button__label" data-label="{{- 'customer.addresses.add' | t -}}">
                  {{- 'customer.addresses.add' | t -}}
                </span>
              </a>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-account.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main-account.settings.header_1.content"
    },
    {
      "type": "text",
      "id": "heading_orders",
      "default": "t:sections.main-account.settings.heading_orders.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "textarea",
      "id": "text_orders",
      "label": "t:sections.all.text.label",
      "default": "t:sections.main-account.settings.text_orders.default"
    },
    {
      "type": "header",
      "content": "t:sections.main-account.settings.header_2.content"
    },
    {
      "type": "text",
      "id": "heading_addresses",
      "default": "t:sections.main-account.settings.heading_addresses.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "textarea",
      "id": "text_addresses",
      "label": "t:sections.all.text.label",
      "default": "t:sections.main-account.settings.text_addresses.default"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "xs",
          "label": "t:sections.all.section-margin.options__2.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        },
        {
          "value": "xl",
          "label": "t:sections.all.section-margin.options__6.label"
        }
      ],
      "default": "l",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ]
}
{% endschema %}
